{% extends "layouts/base.twig" %}

{% block title %}Login Admin - AORE/RN{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/auth.css?v=20260304-authlight1">
{% endblock %}

{% block content %}
    <section class="auth-hero login-hero site-hero hero-form-layout">
        <div class="site-hero-pattern d-none d-lg-block"></div>
        <div class="container position-relative">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 hero-content d-none d-lg-block">
  {#                   <div class="auth-hero-logo mb-4">
                        <img src="{{ BASE_URL }}assets/images/aore1.png" alt="AORE/RN" class="img-fluid">
                    </div> #}
                    <p class="section-kicker text-white-50 mb-2">Painel administrativo da plataforma AORE/RN</p>
                    <h1 class="section-title text-white mb-3">Requer privilégios administrativos</h1>
                    <p class="section-lead text-white-75 mb-4">Esta área concentra indicadores, conteúdo interno e rotinas de gestão da AORE/RN. O acesso permanece restrito a usuários autorizados com credenciais válidas.</p>
                    <ul class="auth-benefits icon-list text-white-75 mb-4">
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-shield-lock"></i></span>
                            <span>Acesso monitorado e protegido pela equipe AORE/RN</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-activity"></i></span>
                            <span>Indicadores em tempo real e conteúdo interno</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-people"></i></span>
                            <span>Equipe autorizada de gestores e editores</span>
                        </li>
                    </ul>
                    <div class="d-flex flex-wrap gap-3">
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL,
                            label: 'Voltar à página inicial',
                            icon: 'bi-arrow-left',
                            variant: 'solid',
                            size: 'lg'
                        } %}
                        {% include 'site/components/button.twig' with {
                            href: whatsapp.links.general,
                            label: 'WhatsApp',
                            icon: 'bi-whatsapp',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold',
                            target: '_blank'
                        } %}
                    </div>
                </div>
                <div class="col-lg-5 ms-lg-auto hero-panel-col">
                    <div class="auth-card auth-card--light hero-panel hero-panel--light">
{#                         <div class="text-center mb-4">
                            <p class="hero-panel-badge text-white-75"><i class="bi bi-lock-fill me-2"></i>Área restrita</p>
                            <h2 class="h4 fw-bold text-white mb-1">Acesse o painel</h2>
                            <p class="text-white-50 small mb-0">Somente credenciais autorizadas.</p>
                        </div> #}
                        <div class="d-flex justify-content-start mb-3">
                            <p class="hero-panel-badge mb-0">
                                <i class="bi bi-box-arrow-in-right me-2 text-primary"></i>Formulário de login
                            </p>
                        </div>

                        {% if success %}
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="bi bi-check-circle me-2"></i>
                                {% if success == 'account_created' %}
                                    <strong>Conta criada com sucesso!</strong> Agora você pode fazer login.
                                {% else %}
                                    {{ success }}
                                {% endif %}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endif %}

                        {% if error %}
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-circle me-2"></i>
                                {{ error }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endif %}

                        <form method="POST" action="{{ BASE_URL }}login/authenticate-admin" class="auth-form auth-form--light">
                            <div class="mb-3">
                                <label for="username" class="form-label text-white fw-semibold">Usuário</label>
                                <input type="text" class="form-control form-control-lg" id="username" name="username" placeholder="seu.usuario" required autofocus>
                                <small class="text-white-50 d-block mt-1">Apenas administradores têm acesso</small>
                            </div>
                            <div class="mb-4">
                                <label for="password" class="form-label text-white fw-semibold">Senha</label>
                                <input type="password" class="form-control form-control-lg" id="password" name="password" required>
                            </div>
                            {% include 'site/components/button.twig' with {
                                label: 'Entrar no painel',
                                icon: 'bi-box-arrow-in-right',
                                variant: 'solid',
                                size: 'lg',
                                type: 'submit',
                                button_class: 'w-100 fw-bold'
                            } %}
                        </form>

                        <hr class="text-white-25 my-4">
{#                         <p class="text-center text-white-50 small mb-0">
                            Precisa de suporte? <a href="{{ BASE_URL }}contact" class="text-white fw-semibold text-decoration-none">Fale com o comando</a>
                        </p> #}
                        <p class="text-center text-white-50 small mt-3 mb-0">
                            Acesso institucional restrito a usuários autorizados da AORE/RN. Para suporte, <a href="{{ BASE_URL }}contact" class="text-white fw-semibold text-decoration-none">entre em contato com a equipe responsável</a>.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
