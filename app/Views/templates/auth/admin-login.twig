{% extends "layouts/base.twig" %}

{% block title %}Login Admin - CBMRN{% endblock %}

{% block content %}
    <div class="container py-5" style="min-height: calc(100vh - 75px - 200px);">
        <div class="row">
            <div class="col-lg-4 offset-lg-4">
                <div class="card border-0 shadow-lg" style="border-top: 4px solid #df6301;">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <i class="bi bi-speedometer2" style="font-size: 3rem; color: #df6301;"></i>
                            <h2 class="text-center fw-bold mt-3" style="color: #df6301;">Painel Admin</h2>
                            <p class="text-muted small">Acesso restrito a administradores e usuários registrados</p>
                        </div>
                        
                        {% if success %}
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="bi bi-check-circle me-2"></i>
                                {% if success == 'account_created' %}
                                    <strong>Conta criada com sucesso!</strong> Agora você pode fazer login com suas credenciais abaixo.
                                {% else %}
                                    {{ success }}
                                {% endif %}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endif %}

                        {% if error %}
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-circle me-2"></i>
                                {{ error }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endif %}
                        
                        <form method="POST" action="{{ BASE_URL }}login/authenticate-admin">
                            <div class="mb-3">
                                <label for="username" class="form-label fw-bold">Usuário</label>
                                <input type="text" class="form-control form-control-lg" id="username" name="username" placeholder="seu.usuario" required autofocus>
                                <small class="text-muted d-block mt-1">Apenas administradores têm acesso</small>
                            </div>
                            <div class="mb-4">
                                <label for="password" class="form-label fw-bold">Senha</label>
                                <input type="password" class="form-control form-control-lg" id="password" name="password" required>
                            </div>
                            <button type="submit" class="btn btn-lg w-100 fw-bold text-white" style="background-color: #df6301;">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Entrar no Painel
                            </button>
                        </form>
                        
                        <hr class="my-4">
                        
                        <p class="text-center text-muted small mb-0">
                            Não tem uma conta? <a href="{{ BASE_URL }}register" class="fw-bold text-decoration-none" style="color: #df6301;">Registre-se aqui</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
