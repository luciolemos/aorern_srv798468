{% extends 'admin/layouts/base_admin.twig' %}

{% block title %}Painel Institucional{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold admin-page-title">
                <i class="bi bi-buildings me-2 admin-page-icon-brand"></i>Painel institucional
            </h2>
            <p class="text-muted mb-0"><i class="bi bi-calendar3 me-1 admin-page-icon-brand"></i> {{ 'now'|date('d/m/Y') }}</p>
        </div>
        <div class="text-end">
            <small class="text-muted d-block">Último acesso</small>
            <strong class="admin-link-brand">{{ ultimo_login|date('d/m/Y H:i') }}</strong>
        </div>
    </div>
    <hr class="my-4">

    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-success-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-people-fill fs-2 text-success"></i>
                        </div>
                        <span class="badge bg-success bg-opacity-25 text-success">Base associativa</span>
                    </div>
                    <h3 class="fw-bold text-success mb-1">{{ total_pessoal }}</h3>
                    <p class="text-muted mb-0 small">Associados cadastrados</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-primary-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box icon-box-primary rounded-3 p-3">
                            <i class="bi bi-person-badge fs-2 text-white"></i>
                        </div>
                        <span class="badge badge-soft-primary">Acesso interno</span>
                    </div>
                    <h3 class="fw-bold text-primary mb-1">{{ total_usuarios }}</h3>
                    <p class="text-muted mb-0 small">Usuários do painel</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-info-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-journal-text fs-2 text-info"></i>
                        </div>
                        <span class="badge bg-info bg-opacity-25 text-info">Comunicação</span>
                    </div>
                    <h3 class="fw-bold text-info mb-1">{{ posts_publicados }}</h3>
                    <p class="text-muted mb-0 small">Publicações publicadas</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-warning-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-warning bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-hourglass-split fs-2 text-warning"></i>
                        </div>
                        <span class="badge bg-warning bg-opacity-25 text-warning">Pendências</span>
                    </div>
                    <h3 class="fw-bold text-warning mb-1">{{ posts_pendentes + usuarios_pendentes }}</h3>
                    <p class="text-muted mb-0 small">Itens aguardando tratamento</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-uppercase small fw-semibold text-muted mb-2">Comunicação</p>
                    <h4 class="fw-bold mb-1 admin-kpi-value">{{ total_categorias_posts }}</h4>
                    <p class="text-muted mb-0 small">Categorias editoriais</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-uppercase small fw-semibold text-muted mb-2">Galeria</p>
                    <h4 class="fw-bold mb-1 admin-kpi-value">{{ total_categorias_galeria }}</h4>
                    <p class="text-muted mb-0 small">Categorias de acervo</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-uppercase small fw-semibold text-muted mb-2">Diretoria e cargos</p>
                    <h4 class="fw-bold mb-1 admin-kpi-value">{{ total_funcoes }}</h4>
                    <p class="text-muted mb-0 small">Funções cadastradas</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-uppercase small fw-semibold text-muted mb-2">Legado técnico</p>
                    <h4 class="fw-bold mb-1 admin-kpi-value">{{ total_ocorrencias|default(0) }}</h4>
                    <p class="text-muted mb-0 small">Registros herdados monitorados</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-5">
        <div class="card-header bg-white border-bottom admin-card-header-tint-brand">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                <div>
                    <h5 class="mb-0 admin-card-heading-strong">
                        <i class="bi bi-lightning-charge-fill me-2 admin-page-icon-brand"></i> Ações rápidas
                    </h5>
                    <p class="text-muted small mb-0">Atalhos principais para gestão institucional, comunicação e base associativa.</p>
                </div>
                <span class="badge bg-primary bg-opacity-10 text-primary mt-3 mt-md-0">Modo compatível</span>
            </div>
        </div>
        <div class="card-body">
            {% set quickActions = [
                {
                    title: 'Cadastrar associado',
                    description: 'Inclui novos registros na base associativa e mantém o cadastro institucional atualizado.',
                    icon: 'bi-person-plus-fill',
                    href: BASE_URL ~ 'admin/pessoal/cadastrar',
                    badge: 'Associados',
                    accent: 'success'
                },
                {
                    title: 'Gerenciar publicações',
                    description: 'Publica notícias, comunicados e conteúdos oficiais do portal da AORERN.',
                    icon: 'bi-journal-text',
                    href: BASE_URL ~ 'admin/posts',
                    badge: 'Comunicação',
                    accent: 'primary'
                },
                {
                    title: 'Núcleo institucional',
                    description: 'Reúne a gestão inicial de conteúdos permanentes, referências oficiais e estrutura institucional da associação.',
                    icon: 'bi-bank',
                    href: BASE_URL ~ 'admin/institucional',
                    badge: 'Institucional',
                    accent: 'info'
                },
                {
                    title: 'Diretoria e mandatos',
                    description: 'Organiza governança, composição institucional e preparação do histórico de gestões.',
                    icon: 'bi-person-workspace',
                    href: BASE_URL ~ 'admin/diretoria',
                    badge: 'Governança',
                    accent: 'info'
                }
            ] %}

            <div class="row g-3 g-lg-4 quick-action-grid">
                {% for action in quickActions %}
                    <div class="col-sm-6 col-xl-3">
                        <a href="{{ action.href }}" class="quick-action-card quick-action-{{ action.accent }} h-100" aria-label="{{ action.title }}">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="icon-box icon-box-sm">
                                    <i class="bi {{ action.icon }} fs-4"></i>
                                </div>
                                <span class="badge badge-soft-{{ action.accent }}">{{ action.badge }}</span>
                            </div>
                            <h5 class="fw-semibold mb-1">{{ action.title }}</h5>
                            <p class="text-muted small mb-0">{{ action.description }}</p>
                            <span class="quick-action-link mt-3">Acessar <i class="bi bi-arrow-right-short"></i></span>
                        </a>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center admin-card-header-tint-brand">
                    <h5 class="mb-0 admin-card-heading-strong">
                        <i class="bi bi-people-fill me-2 admin-page-icon-brand"></i> Base associativa recente
                    </h5>
                    <a href="{{ BASE_URL }}admin/pessoal" class="text-decoration-none small fw-semibold admin-link-brand">Ver todos</a>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        {% if ultimos_bombeiros is not empty %}
                            {% for func in ultimos_bombeiros %}
                                <div class="list-group-item border-0 px-0 py-2">
                                    <div class="d-flex align-items-center">
                                        {% set associatePhotoSrc = null %}
                                        {% if func.foto is not empty %}
                                            {% if func.foto starts with 'http://' or func.foto starts with 'https://' %}
                                                {% set associatePhotoSrc = func.foto %}
                                            {% else %}
                                                {% set associatePhotoSrc = BASE_URL ~ func.foto %}
                                            {% endif %}
                                        {% elseif func.user_avatar is not empty %}
                                            {% if func.user_avatar starts with 'http://' or func.user_avatar starts with 'https://' %}
                                                {% set associatePhotoSrc = func.user_avatar %}
                                            {% else %}
                                                {% set associatePhotoSrc = BASE_URL ~ func.user_avatar %}
                                            {% endif %}
                                        {% endif %}

                                        {% if associatePhotoSrc %}
                                            <img src="{{ associatePhotoSrc|e('html_attr') }}"
                                                 alt="{{ func.nome|default('Associado')|e('html_attr') }}"
                                                 class="rounded-circle shadow-sm me-3 admin-avatar-square-40">
                                        {% else %}
                                            <span class="rounded-circle d-inline-flex align-items-center justify-content-center bg-success text-white fw-bold me-3 admin-avatar-square-40">
                                                {{ (func.nome|default('?'))[0:1]|upper }}
                                            </span>
                                        {% endif %}
                                        <div class="flex-grow-1">
                                            <p class="mb-0 fw-semibold">{{ func.nome|default('N/A')|e }}</p>
                                            <small class="text-muted">{{ func.funcao_nome|default('Sem função')|e }}</small>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted text-center py-3 mb-0">Nenhum associado cadastrado ainda</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center admin-card-header-tint-primary">
                    <h5 class="mb-0 admin-card-heading-strong">
                        <i class="bi bi-megaphone me-2 text-primary"></i> Comunicação recente
                    </h5>
                    <a href="{{ BASE_URL }}admin/posts" class="text-decoration-none small fw-semibold text-primary">Ver posts</a>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        {% if ultimos_posts is not empty %}
                            {% for post in ultimos_posts %}
                                <div class="list-group-item border-0 px-0 py-2">
                                    <div class="d-flex justify-content-between gap-3">
                                        <div>
                                            <p class="mb-1 fw-semibold">{{ post.titulo|default('Sem título')|e }}</p>
                                            <small class="text-muted">{{ post.categoria_nome|default('Sem categoria')|e }}</small>
                                        </div>
                                        <span class="badge bg-light text-dark text-uppercase">{{ post.status|default('draft')|e }}</span>
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted text-center py-3 mb-0">Nenhuma publicação cadastrada ainda</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center admin-card-header-tint-info">
                    <h5 class="mb-0 admin-card-heading-strong">
                        <i class="bi bi-image me-2 text-info"></i> Acervo visual recente
                    </h5>
                    <a href="{{ BASE_URL }}admin/galeria" class="text-decoration-none small fw-semibold text-info">Ver galeria</a>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        {% if ultimas_imagens is not empty %}
                            {% for imagem in ultimas_imagens %}
                                <div class="list-group-item border-0 px-0 py-2">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="icon-box bg-info bg-opacity-10 rounded-circle p-2">
                                            <i class="bi bi-image text-info"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <p class="mb-1 fw-semibold">{{ imagem.titulo|default('Imagem sem título')|e }}</p>
                                            <small class="text-muted">{{ imagem.categoria_nome|default('Sem categoria')|e }}</small>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted text-center py-3 mb-0">Nenhuma imagem cadastrada ainda</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
