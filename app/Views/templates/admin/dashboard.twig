{% extends 'admin/layouts/base_admin.twig' %}

{% block title %}Dashboard{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
           <h2 class="fw-bold" style="color: var(--admin-primary);">
                <i class="bi bi-speedometer2 me-2" style="color: #df6301;"></i>Painel de controle
            </h2>
            <p class="text-muted mb-0"><i class="bi bi-calendar3 me-1" style="color: #df6301;"></i> {{ 'now'|date('d/m/Y') }}</p>
        </div>
        <div class="text-end">
            <small class="text-muted d-block">Último acesso</small>
            <strong style="color: #df6301;">{{ ultimo_login|date('d/m/Y H:i') }}</strong>
        </div>
    </div>
     <hr class="my-4">

    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-success-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-people-fill fs-2 text-success"></i>
                        </div>
                        <span class="badge bg-success bg-opacity-25 text-success">Ativos</span>
                    </div>
                    <h3 class="fw-bold text-success mb-1">{{ total_pessoal }}</h3>
                    <p class="text-muted mb-0 small">Bombeiros cadastrados</p>
                    <div class="progress mt-3" style="height: 4px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 85%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-info-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-tools fs-2 text-info"></i>
                        </div>
                        <span class="badge bg-info bg-opacity-25 text-info">Disponíveis</span>
                    </div>
                    <h3 class="fw-bold text-info mb-1">{{ total_equipamentos }}</h3>
                    <p class="text-muted mb-0 small">Equipamentos registrados</p>
                    <div class="progress mt-3" style="height: 4px;">
                        <div class="progress-bar bg-info" role="progressbar" style="width: 70%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-danger-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-danger bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-bricks fs-2 text-danger"></i>
                        </div>
                        <span class="badge bg-danger bg-opacity-25 text-danger">Em andamento</span>
                    </div>
                    <h3 class="fw-bold text-danger mb-1">{{ total_obras }}</h3>
                    <p class="text-muted mb-0 small">Obras ativas</p>
                    <div class="progress mt-3" style="height: 4px;">
                        <div class="progress-bar bg-danger" role="progressbar" style="width: 60%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-warning-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-warning bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-tags-fill fs-2 text-warning"></i>
                        </div>
                        <span class="badge bg-warning bg-opacity-25 text-warning">Cadastradas</span>
                    </div>
                    <h3 class="fw-bold text-warning mb-1">{{ total_funcoes }}</h3>
                    <p class="text-muted mb-0 small">Funções disponíveis</p>
                    <div class="progress mt-3" style="height: 4px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 90%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-primary-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box icon-box-primary rounded-3 p-3">
                            <i class="bi bi-journal-medical fs-2 text-white"></i>
                        </div>
                        <span class="badge badge-soft-primary">Consolidadas</span>
                    </div>
                    <h3 class="fw-bold text-primary mb-1">{{ total_ocorrencias|default(0) }}</h3>
                    <p class="text-muted mb-0 small">Ocorrências registradas</p>
                    <div class="progress mt-3" style="height: 4px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 95%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-secondary-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-secondary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-exclamation-octagon fs-2 text-secondary"></i>
                        </div>
                        <span class="badge bg-secondary bg-opacity-25 text-secondary">Abertas</span>
                    </div>
                    <h3 class="fw-bold text-secondary mb-1">{{ ocorrencias_abertas|default(0) }}</h3>
                    <p class="text-muted mb-0 small">Em tratamento</p>
                    <div class="progress mt-3" style="height: 4px;">
                        <div class="progress-bar bg-secondary" role="progressbar" style="width: 50%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-success-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-check2-circle fs-2 text-success"></i>
                        </div>
                        <span class="badge bg-success bg-opacity-25 text-success">Concluídas</span>
                    </div>
                    <h3 class="fw-bold text-success mb-1">{{ ocorrencias_concluidas|default(0) }}</h3>
                    <p class="text-muted mb-0 small">Encerradas com relatório</p>
                    <div class="progress mt-3" style="height: 4px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 80%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-gradient-dark-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box bg-dark bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-person-badge fs-2 text-dark"></i>
                        </div>
                        <span class="badge bg-dark bg-opacity-25 text-dark">Sistema</span>
                    </div>
                    <h3 class="fw-bold text-dark mb-1">{{ total_usuarios|default(0) }}</h3>
                    <p class="text-muted mb-0 small">Usuários cadastrados</p>
                    <div class="progress mt-3" style="height: 4px;">
                        <div class="progress-bar bg-dark" role="progressbar" style="width: 65%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-5">
        <div class="card-header bg-white border-bottom" style="background: linear-gradient(90deg, rgba(223,99,1,0.02), transparent) !important;">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                <div>
                    <h5 class="mb-0" style="font-family: 'Roboto Condensed', sans-serif; font-weight: 700;">
                        <i class="bi bi-lightning-charge-fill me-2" style="color: #df6301;"></i> Ações Rápidas
                    </h5>
                    <p class="text-muted small mb-0">Atalhos críticos para despachar equipes, atualizar efetivo e manter o acervo digital.</p>
                </div>
                <span class="badge bg-primary bg-opacity-10 text-primary mt-3 mt-md-0">Tempo médio &lt; 30s</span>
            </div>
        </div>
        <div class="card-body">
            {% set quickActions = [
                {
                    title: 'Registrar ocorrência',
                    description: 'Gera protocolo, vincula responsável e já aparece no mapa operacional.',
                    icon: 'bi-journal-plus',
                    href: BASE_URL ~ 'admin/livro-ocorrencias/create',
                    badge: 'Livro digital',
                    accent: 'primary'
                },
                {
                    title: 'Painel de ocorrências',
                    description: 'Consulta atendimentos ativos, filtros por município e exportação.',
                    icon: 'bi-activity',
                    href: BASE_URL ~ 'admin/livro-ocorrencias',
                    badge: 'Monitoramento',
                    accent: 'info'
                },
                {
                    title: 'Cadastrar bombeiro',
                    description: 'Atualiza o efetivo com documentos, lotação e contato.',
                    icon: 'bi-person-plus-fill',
                    href: BASE_URL ~ 'admin/pessoal/cadastrar',
                    badge: 'Efetivo',
                    accent: 'success'
                },
                {
                    title: 'Novo equipamento',
                    description: 'Registra itens, vincula categoria e acompanha disponibilidade.',
                    icon: 'bi-tools',
                    href: BASE_URL ~ 'admin/equipamentos/cadastrar',
                    badge: 'Logística',
                    accent: 'warning'
                }
            ] %}

            <div class="row g-3 g-lg-4 quick-action-grid">
                {% for action in quickActions %}
                    <div class="col-sm-6 col-xl-3">
                        <a href="{{ action.href }}" class="quick-action-card quick-action-{{ action.accent }} h-100" aria-label="{{ action.title }}">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="icon-box icon-box-sm">
                                    <i class="bi {{ action.icon }} fs-4"></i>
                                </div>
                                <span class="badge badge-soft-{{ action.accent }}">{{ action.badge }}</span>
                            </div>
                            <h5 class="fw-semibold mb-1">{{ action.title }}</h5>
                            <p class="text-muted small mb-0">{{ action.description }}</p>
                            <span class="quick-action-link mt-3">Acessar <i class="bi bi-arrow-right-short"></i></span>
                        </a>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center" style="background: linear-gradient(90deg, rgba(223,99,1,0.02), transparent) !important;">
                    <h5 class="mb-0" style="font-family: 'Roboto Condensed', sans-serif; font-weight: 700;">
                        <i class="bi bi-clock-history me-2" style="color: #df6301;"></i> Últimos Cadastros
                    </h5>
                    <span class="badge" style="background-color: #df6301;">Recente</span>
                </div>
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small mb-3">Bombeiros</h6>
                    <div class="list-group list-group-flush mb-4">
                        {% if ultimos_bombeiros is not empty %}
                            {% for func in ultimos_bombeiros %}
                                <div class="list-group-item border-0 px-0 py-2">
                                    <div class="d-flex align-items-center">
                                        {% if func.avatar is not empty and func.avatar %}
                                            <img src="{{ BASE_URL }}{{ func.avatar|e('html_attr') }}"
                                                 alt="{{ func.nome|default('')|e('html_attr') }}"
                                                 class="rounded-circle shadow-sm me-3"
                                                 style="width: 40px; height: 40px; object-fit: cover; border: 2px solid #28a745;">
                                        {% else %}
                                            <span class="rounded-circle d-inline-flex align-items-center justify-content-center bg-success text-white fw-bold me-3"
                                                  style="width: 40px; height: 40px; font-size: 16px;">
                                                {{ (func.nome|default('?'))[0:1]|upper }}
                                            </span>
                                        {% endif %}
                                        <div class="flex-grow-1">
                                            <p class="mb-0 fw-semibold">{{ func.nome|default('N/A')|e }}</p>
                                            <small class="text-muted">{{ func.funcao_nome|default('Sem função')|e }}</small>
                                        </div>
                                        {% if func.telefone %}
                                            {% set telefone_digitos = '' %}
                                            {% for c in func.telefone %}
                                                {% if c in '0123456789' %}
                                                    {% set telefone_digitos = telefone_digitos ~ c %}
                                                {% endif %}
                                            {% endfor %}
                                            {% if telefone_digitos|length == 11 %}
                                                <small class="text-muted"><i class="bi bi-telephone me-1"></i>({{ telefone_digitos[0:2] }}) {{ telefone_digitos[2] }} {{ telefone_digitos[3:7] }}-{{ telefone_digitos[7:11] }}</small>
                                            {% else %}
                                                <small class="text-muted"><i class="bi bi-telephone me-1"></i>{{ func.telefone|e }}</small>
                                            {% endif %}
                                        {% else %}
                                            <small class="text-muted">Sem telefone</small>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted text-center py-3">Nenhum bombeiro cadastrado ainda</p>
                        {% endif %}
                    </div>

                    <h6 class="text-muted text-uppercase small mb-3">Equipamentos</h6>
                    <div class="list-group list-group-flush">
                        {% if ultimos_equipamentos is not empty %}
                            {% for eqp in ultimos_equipamentos %}
                                <div class="list-group-item border-0 px-0 py-2">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-box bg-info bg-opacity-10 rounded-circle p-2 me-3">
                                            <i class="bi bi-tools text-info"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <p class="mb-0 fw-semibold">{{ eqp.nome|default('N/A')|e }}</p>
                                            <small class="text-muted">{{ eqp.categoria|default('Sem categoria')|e }}</small>
                                        </div>
                                        <small class="text-muted">ID #{{ eqp.id }}</small>
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted text-center py-3">Nenhum equipamento cadastrado ainda</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center" style="background: linear-gradient(90deg, rgba(220,53,69,0.02), transparent) !important;">
                    <h5 class="mb-0" style="font-family: 'Roboto Condensed', sans-serif; font-weight: 700;">
                        <i class="bi bi-building me-2" style="color: #dc3545;"></i> Obras Recentes
                    </h5>
                    <a href="{{ BASE_URL }}admin/obras" class="text-decoration-none small fw-semibold" style="color: #dc3545;">Ver todas</a>
                </div>
                <div class="card-body">
                    {% if ultimas_obras is not empty %}
                        {% for obra in ultimas_obras %}
                            <div class="card mb-3 border-start border-4 border-danger">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h6 class="mb-1 fw-bold">{{ obra.descricao|default('Obra sem descrição')|e }}</h6>
                                        <span class="badge bg-danger">{{ obra.status|default('Ativa')|e }}</span>
                                    </div>
                                    <p class="text-muted small mb-2">
                                        <i class="bi bi-geo-alt me-1"></i> {{ obra.endereco|default('Endereço não informado')|e }}
                                    </p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            <i class="bi bi-calendar3 me-1"></i>
                                            Início: {{ obra.data_inicio|default('N/A')|e }}
                                        </small>
                                        <a href="{{ BASE_URL }}admin/obras/detalhes/{{ obra.id }}" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-eye me-1"></i> Ver
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="text-center py-5">
                            <i class="bi bi-building display-1 text-muted opacity-25"></i>
                            <p class="text-muted mt-3">Nenhuma obra cadastrada ainda</p>
                            <a href="{{ BASE_URL }}admin/obras/cadastrar" class="btn btn-danger">
                                <i class="bi bi-plus-circle me-1"></i> Cadastrar Obra
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
