{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Informações técnicas - Admin{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div class="mb-4">
        <h2 class="fw-bold" style="color: var(--admin-primary);"><i class="bi bi-info-circle me-2"></i>Informações técnicas</h2>
        <p class="text-muted mb-0">Dados de ambiente para diagnóstico rápido do servidor.</p>
        <hr class="my-4">
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Item</th>
                            <th>Valor</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for key, value in info %}
                            <tr>
                                <td class="fw-semibold">{{ key|e }}</td>
                                <td class="text-break">{{ value|default('—')|e }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

