{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Cadastrar Categoria - Admin{% endblock %}
{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div data-aos="fade-down" class="mb-3">
        <h2 class="fw-bold" style="color: var(--admin-primary);"><i class="bi bi-tags me-2"></i>Cadastrar categoria de equipamento</h2>
        <p class="text-muted mb-0">Cadastre nova categoria de equipamento para o CBMRN</p>
    </div>
    <hr class="my-4">
    <form method="post" action="{{ BASE_URL }}admin/categorias/salvar">
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold">Código da categoria</label>
                <input type="text" name="staff_id" class="form-control" value="CAT-{{ 'now'|date('YmdHis') }}" readonly>
            </div>
            <div class="col-md-9">
                <label class="form-label fw-bold">Descrição da categoria</label>
                <input type="text" name="nome" class="form-control" required placeholder="Ex: Elétricas, Segurança, Proteção">
            </div>
        </div>
      
        <div class="d-flex flex-column flex-md-row gap-2 order-md-2 w-100 w-md-auto justify-content-md-end">
            <a href="{{ BASE_URL }}admin" class="btn btn-primary"><i class="bi bi-speedometer2 me-1"></i> Painel</a>
            <a href="{{ BASE_URL }}admin/categorias" class="btn btn-danger"><i class="bi bi-x-circle me-1"></i> Cancelar</a>
            <button type="submit" class="btn btn-success"><i class="bi bi-save me-1"></i> Salvar</button>
        </div>
    </form>
</div>
{% endblock %}
