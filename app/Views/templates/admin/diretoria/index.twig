{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Diretoria{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div class="mb-4">
        <h2 class="fw-bold" style="color: var(--admin-primary);"><i class="bi bi-person-workspace me-2"></i>Diretoria e composição institucional</h2>
        <p class="text-muted mb-0">Gerencie cargos, titulares e vínculos com mandatos da associação.</p>
        <hr class="my-4">
        <div class="d-flex flex-column flex-md-row gap-2">
            <a href="{{ BASE_URL }}admin/diretoria/cadastrar" class="btn btn-primary text-white">Novo registro</a>
            <a href="{{ BASE_URL }}admin/mandatos" class="btn btn-outline-primary">Mandatos</a>
            <a href="{{ BASE_URL }}admin/pessoal" class="btn btn-outline-secondary">Associados</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="GET" class="row g-3 align-items-end">
                <div class="col-lg-5">
                    <label class="form-label small mb-1"><strong>Busca</strong></label>
                    <input type="text" name="q" class="form-control" value="{{ filters.q|default('')|e('html_attr') }}" placeholder="Cargo, grupo, associado ou função">
                </div>
                <div class="col-lg-3">
                    <label class="form-label small mb-1"><strong>Mandato</strong></label>
                    <select name="term_id" class="form-select">
                        <option value="">Todos</option>
                        {% for term in terms %}
                            <option value="{{ term.id }}" {% if filters.term_id == term.id %}selected{% endif %}>{{ term.nome|e }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-lg-2">
                    <label class="form-label small mb-1"><strong>Status</strong></label>
                    <select name="is_active" class="form-select">
                        <option value="">Todos</option>
                        <option value="1" {% if filters.is_active == '1' %}selected{% endif %}>Ativos</option>
                        <option value="0" {% if filters.is_active == '0' %}selected{% endif %}>Inativos</option>
                    </select>
                </div>
                <div class="col-lg-2 d-flex gap-2">
                    {% if filters.q or filters.term_id or filters.is_active != '' %}
                        <a href="{{ BASE_URL }}admin/diretoria" class="btn btn-outline-secondary flex-grow-1">Limpar</a>
                    {% endif %}
                    <button type="submit" class="btn btn-primary flex-grow-1">Filtrar</button>
                </div>
            </form>
        </div>
    </div>

    {% if membros is empty %}
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Nenhuma composição cadastrada.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>CARGO</th>
                        <th>ASSOCIADO</th>
                        <th>MANDATO</th>
                        <th>ACESSO</th>
                        <th>STATUS</th>
                        <th>ORDEM</th>
                        <th class="text-center">AÇÕES</th>
                    </tr>
                </thead>
                <tbody>
                    {% for membro in membros %}
                        <tr>
                            <td>
                                <div class="fw-semibold">{{ (membro.funcao_nome ?: membro.cargo)|e }}</div>
                                <small class="text-muted">{{ membro.grupo|default('Sem grupo')|e }}</small>
                            </td>
                            <td>{{ membro.associado_nome|default('Não vinculado')|e }}</td>
                            <td>{{ membro.term_nome|default('Sem mandato')|e }}</td>
                            <td>
                                {% if membro.access_role == 'gerente' %}
                                    <span class="badge bg-primary">Diretoria / Secretaria</span>
                                {% elseif membro.access_role == 'operador' %}
                                    <span class="badge bg-info text-dark">Equipe de Apoio</span>
                                {% else %}
                                    <span class="badge bg-light text-muted border">Sem acesso admin</span>
                                {% endif %}
                            </td>
                            <td><span class="badge {{ membro.is_active ? 'bg-success' : 'bg-secondary' }}">{{ membro.is_active ? 'Ativo' : 'Inativo' }}</span></td>
                            <td>{{ membro.ordem }}</td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button class="btn btn-link text-secondary p-0" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" href="{{ BASE_URL }}admin/diretoria/visualizar/{{ membro.id }}">
                                                <i class="bi bi-eye me-2"></i> Visualizar
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="{{ BASE_URL }}admin/diretoria/editar/{{ membro.id }}">
                                                <i class="bi bi-pencil-square me-2"></i> Editar
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item text-danger" href="{{ BASE_URL }}admin/diretoria/deletar/{{ membro.id }}" onclick="return confirm('Remover este registro de diretoria?');">
                                                <i class="bi bi-trash me-2"></i> Excluir
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if pagination and pagination.total > 0 %}
        {% set current = pagination.current_page|default(1) %}
        {% set last = pagination.last_page|default(1) %}
        {% set range = 2 %}
        {% set start = max(1, current - range) %}
        {% set end = min(last, current + range) %}
        {% set queryPairs = [] %}
        {% for key, value in pagination.query|default({}) %}
            {% set queryPairs = queryPairs|merge([key ~ '=' ~ value|url_encode]) %}
        {% endfor %}
        {% set baseQueryString = queryPairs ? queryPairs|join('&') ~ '&' : '' %}

        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3 mt-4">
            <p class="text-muted small mb-0">Exibindo {{ pagination.from|default(0) }}-{{ pagination.to|default(0) }} de {{ pagination.total|default(0) }} registros</p>
            <form method="GET" class="d-flex align-items-center gap-2">
                <input type="hidden" name="page" value="1">
                {% for key, value in pagination.query|default({}) %}
                    {% if key != 'per_page' %}
                        <input type="hidden" name="{{ key }}" value="{{ value|e('html_attr') }}">
                    {% endif %}
                {% endfor %}
                <label class="text-muted small mb-0">Registros por página</label>
                <select name="per_page" class="form-select form-select-sm" onchange="this.form.submit()">
                    {% for option in perPageOptions %}
                        <option value="{{ option.value }}" {% if option.value == perPageSelection %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </form>
        </div>
        <nav aria-label="Paginação" class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item {% if current <= 1 %}disabled{% endif %}"><a class="page-link" href="{% if current <= 1 %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current - 1 }}{% endif %}">&laquo;</a></li>
                {% if start > 1 %}
                    <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page=1">1</a></li>
                    {% if start > 2 %}<li class="page-item disabled"><span class="page-link">…</span></li>{% endif %}
                {% endif %}
                {% for page in start..end %}
                    <li class="page-item {% if page == current %}active{% endif %}">
                        {% if page == current %}<span class="page-link">{{ page }}</span>{% else %}<a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ page }}">{{ page }}</a>{% endif %}
                    </li>
                {% endfor %}
                {% if end < last %}
                    {% if end < last - 1 %}<li class="page-item disabled"><span class="page-link">…</span></li>{% endif %}
                    <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ last }}">{{ last }}</a></li>
                {% endif %}
                <li class="page-item {% if current >= last %}disabled{% endif %}"><a class="page-link" href="{% if current >= last %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current + 1 }}{% endif %}">&raquo;</a></li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}
