{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Editar Post - Admin{% endblock %}
{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div data-aos="fade-down" class="mb-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h2 class="fw-bold" style="color: var(--admin-primary);"><i class="bi bi-pencil-square me-2"></i>Editar Post</h2>
                <p class="text-muted mb-0">Atualize os dados do post</p>
            </div>
            {% if post.status %}
                {% set statusBadgeClass = {
                    'draft': 'bg-secondary',
                    'pending': 'bg-warning text-dark',
                    'in_review': 'bg-info',
                    'published': 'bg-success',
                    'rejected': 'bg-danger'
                } %}
                <div>
                    <span class="badge {{ statusBadgeClass[post.status]|default('bg-secondary') }} text-uppercase" style="font-size: 1rem;">
                        {{ post.status|replace({'_': ' '})|title }}
                    </span>
                </div>
            {% endif %}
        </div>
    </div>

    {% if post.status == 'rejected' and post.reject_reason %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Motivo da Rejeição:</strong>
            <p class="mb-0">{{ post.reject_reason }}</p>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endif %}

    <hr class="my-4">
    <div data-aos="fade-up">
        <form method="post" action="{{ BASE_URL }}admin/posts/update/{{ post.id }}" class="post-form">
            <input type="hidden" name="csrf_token" value="{{ csrf_token|e }}">
            <div class="row g-3">
                <div class="col-12 col-lg-8">
                    <label for="titulo" class="form-label fw-bold">Título <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="titulo" name="titulo" value="{{ post.titulo }}" required>
                    <div class="form-text">Título principal do post</div>
                </div>
                <div class="col-12 col-lg-4">
                    <label for="categoria_id" class="form-label fw-bold">Categoria <span class="text-danger">*</span></label>
                    <select class="form-select" id="categoria_id" name="categoria_id" required>
                        {% for cat in categorias %}
                            <option value="{{ cat.id }}" {{ cat.id == post.categoria_id ? 'selected' : '' }}>{{ cat.nome }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-12 col-lg-6">
                    <label for="slug" class="form-label fw-bold">Slug (URL) <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="slug" name="slug" value="{{ post.slug }}" required>
                    <div class="form-text">{{ BASE_URL }}blog/</div>
                </div>
                <div class="col-12 col-lg-6">
                    <label for="capa_url" class="form-label fw-bold">URL da capa</label>
                    <input type="text" class="form-control" id="capa_url" name="capa_url" value="{{ post.capa_url|default('') }}" placeholder="https://... ou /assets/images/...">
                    <div class="form-text">Opcional. Recomendamos imagens horizontais 1200×675px.</div>
                </div>
                <div class="col-12">
                    <label for="conteudo" class="form-label fw-bold">Conteúdo do post <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="conteudo" name="conteudo" rows="22" required>{{ post.conteudo }}</textarea>
                </div>
            </div>
            <div class="border-top my-4"></div>
            <div class="action-buttons d-flex flex-column flex-md-row gap-2 w-100 w-md-auto justify-content-md-end py-2">
                <a href="{{ BASE_URL }}admin/posts" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Voltar
                </a>
                
                {% if post.status == 'draft' or post.status == 'rejected' %}
                    {# Usuário pode salvar como rascunho ou submeter #}
                    <button type="submit" name="action" value="save_draft" class="btn btn-secondary flex-grow-1 flex-md-grow-0">
                        <i class="bi bi-save me-1"></i> Salvar como Rascunho
                    </button>
                    <button type="submit" name="action" value="save_submit" class="btn btn-success flex-grow-1 flex-md-grow-0">
                        <i class="bi bi-send me-1"></i> Submeter para Revisão
                    </button>
                {% elseif post.status == 'pending' %}
                    {# Post em revisão - apenas atualizar #}
                    <button type="submit" name="action" value="save_update" class="btn btn-primary flex-grow-1 flex-md-grow-0">
                        <i class="bi bi-save me-1"></i> Atualizar
                    </button>
                {% elseif post.status == 'published' %}
                    {# Post publicado - admin pode atualizar #}
                    <button type="submit" name="action" value="save_update" class="btn btn-warning flex-grow-1 flex-md-grow-0">
                        <i class="bi bi-pencil-square me-1"></i> Atualizar Publicado
                    </button>
                {% else %}
                    {# Fallback genérico #}
                    <button type="submit" name="action" value="save_update" class="btn btn-primary flex-grow-1 flex-md-grow-0">
                        <i class="bi bi-save me-1"></i> Atualizar
                    </button>
                {% endif %}
            </div>
        </form>
    </div>
</div>
{% endblock %}
