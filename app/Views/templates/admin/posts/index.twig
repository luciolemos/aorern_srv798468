{% extends 'admin/layouts/base_admin.twig' %}

{% block title %}Posts - Admin{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div>
        <h2 class="fw-bold" style="color: var(--admin-primary);"><i class="bi bi-file-earmark-text me-2"></i> Posts do Blog</h2>
        <p class="text-muted mb-0">Gerencie suas postagens e fluxo de aprovação</p>
        <hr class="my-4">

        <div class="d-flex flex-column flex-md-row gap-2 w-100 w-md-auto justify-content-md-start mb-4">
            <a href="{{ BASE_URL }}admin/posts/create" class="btn btn-primary text-white">
                <i class="bi bi-plus-circle me-1"></i> Novo post
            </a>
            <a href="{{ BASE_URL }}admin/post-categories" class="btn btn-outline-primary">
                <i class="bi bi-tags me-1"></i> Categorias
            </a>
            <a href="{{ BASE_URL }}admin" class="btn btn-outline-secondary">
                <i class="bi bi-speedometer2 me-1"></i> Painel
            </a>
        </div>
    </div>

    <!-- Painel de Filtros Avançado -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light border-bottom">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-funnel me-2"></i> <strong>Busca Avançada</strong></h5>
                {% set hasActiveFilters = q or status or category or author or visibility %}
                {% if hasActiveFilters %}
                    <a href="{{ BASE_URL }}admin/posts" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Limpar Filtros
                    </a>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            <form method="GET" class="row g-3 g-xl-4 align-items-end">
                <input type="hidden" name="per_page" value="{{ perPageSelection|default('')|e('html_attr') }}">
                <!-- Busca por Título -->
                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label small mb-1" for="search"><i class="bi bi-search me-1"></i> <strong>Busca</strong></label>
                    <input
                        type="text"
                        id="search"
                        name="q"
                        class="form-control"
                        placeholder="Título ou conteúdo..."
                        value="{{ q|default('')|e('html_attr') }}"
                    >
                </div>

                <!-- Filtro por Status -->
                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label small mb-1" for="status"><i class="bi bi-bookmark me-1"></i> <strong>Status</strong></label>
                    <select id="status" name="status" class="form-select">
                        <option value="">Todos</option>
                        <option value="draft" {% if status == 'draft' %}selected{% endif %}>Rascunho</option>
                        <option value="pending" {% if status == 'pending' %}selected{% endif %}>Pendente</option>
                        <option value="published" {% if status == 'published' %}selected{% endif %}>Publicado</option>
                        <option value="rejected" {% if status == 'rejected' %}selected{% endif %}>Rejeitado</option>
                    </select>
                </div>

                <!-- Filtro por Categoria -->
                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label small mb-1" for="category"><i class="bi bi-tags me-1"></i> <strong>Categoria</strong></label>
                    <select id="category" name="category" class="form-select">
                        <option value="">Todas</option>
                        {% for cat in categories %}
                            <option value="{{ cat.id }}" {% if category == cat.id %}selected{% endif %}>
                                {{ cat.nome|e }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <!-- Filtro por Autor (apenas para admin/gerente) -->
                {% if userRole != 'usuario' %}
                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label small mb-1" for="author"><i class="bi bi-person me-1"></i> <strong>Autor</strong></label>
                    <select id="author" name="author" class="form-select">
                        <option value="">Todos</option>
                        {% for auth in allAuthors %}
                            <option value="{{ auth.user_id }}" {% if author == auth.user_id %}selected{% endif %}>
                                {{ auth.name|e|default('(sem nome)') }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                {% endif %}

                <!-- Filtro por Visibilidade -->
                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label small mb-1" for="visibility"><i class="bi bi-eye me-1"></i> <strong>Visibilidade</strong></label>
                    <select id="visibility" name="visibility" class="form-select">
                        <option value="">Todos</option>
                        <option value="visible" {% if visibility == 'visible' %}selected{% endif %}>👁️ Visível</option>
                        <option value="hidden" {% if visibility == 'hidden' %}selected{% endif %}>👁️‍🗨️ Oculto</option>
                    </select>
                </div>

                <!-- Botão de Busca -->
                <div class="col-12 col-md-6 col-xl-2">
                    <button type="submit" class="btn btn-primary d-flex align-items-center justify-content-center w-100">
                        <i class="bi bi-search me-1"></i> Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    {% if posts is empty %}
        <div class="alert alert-info alert-dismissible fade show">
            <i class="bi bi-info-circle me-2"></i> Nenhum post encontrado
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>TÍTULO</th>
                        <th class="d-none d-sm-table-cell" style="width: 120px;">STATUS</th>
                        <th class="d-none d-md-table-cell" style="width: 100px;">CATEGORIA</th>
                        <th class="d-none d-lg-table-cell" style="width: 100px;">AUTOR</th>
                        <th class="d-none d-lg-table-cell" style="width: 120px;">DATA</th>
                        <th class="text-center" style="width: 180px;">AÇÕES</th>
                    </tr>
                </thead>
                <tbody>
                    {% for post in posts %}
                    <tr>
                        <td>
                            <i class="bi bi-file-earmark-text text-primary me-1"></i>
                            {{ post.titulo|upper|e }}
                        </td>
                        <td class="d-none d-sm-table-cell">
                            {% set statusBadgeClass = {
                                'draft': 'bg-secondary',
                                'pending': 'bg-warning text-dark',
                                'in_review': 'bg-info',
                                'published': 'bg-success',
                                'rejected': 'bg-danger'
                            } %}
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge {{ statusBadgeClass[post.status]|default('bg-secondary') }} text-uppercase" style="font-size: 0.75rem;">
                                    {{ statusLabels[post.status]|default(post.status) }}
                                </span>
                                {% if post.status == 'published' %}
                                    {% if post.is_hidden|default(0) == 1 %}
                                        <span title="Post oculto do blog" data-bs-toggle="tooltip">
                                            <i class="bi bi-eye-slash text-warning" style="font-size: 0.9rem;"></i>
                                        </span>
                                    {% else %}
                                        <span title="Post visível no blog" data-bs-toggle="tooltip">
                                            <i class="bi bi-eye text-success" style="font-size: 0.9rem;"></i>
                                        </span>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </td>
                        <td class="d-none d-md-table-cell">
                            {% if post.categoria_nome %}
                                <span class="badge text-uppercase" style="background-color: {{ post.categoria_cor|default('#556b2f') }}; color: #fff; font-size: 0.7rem;">
                                    {{ post.categoria_nome|e }}
                                </span>
                            {% else %}
                                <span class="text-muted small">-</span>
                            {% endif %}
                        </td>
                        <td class="d-none d-lg-table-cell">
                            <small>{{ post.autor|e }}</small>
                        </td>
                        <td class="d-none d-lg-table-cell">
                            <small class="text-muted">{{ post.criado_em|date('d/m/Y') }}</small>
                        </td>
                        <td class="text-center">
                            {# Verifica se há ações disponíveis para este post #}
                            {% set hasActions = false %}
                            {% if post.status == 'draft' and (userRole == 'admin' or (userRole == 'usuario' and post.user_id == user_id)) %}
                                {% set hasActions = true %}
                            {% elseif post.status == 'pending' and userRole != 'usuario' %}
                                {% set hasActions = true %}
                            {% elseif post.status == 'published' and userRole == 'admin' %}
                                {% set hasActions = true %}
                            {% elseif post.status == 'rejected' and (userRole == 'admin' or (userRole == 'usuario' and post.user_id == user_id)) %}
                                {% set hasActions = true %}
                            {% endif %}

                            {% if hasActions %}
                                <div class="dropdown">
                                    <button class="btn btn-link text-secondary p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Ações">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        {% if post.status == 'draft' and (userRole == 'admin' or (userRole == 'usuario' and post.user_id == user_id)) %}
                                            <li>
                                                <a class="dropdown-item" href="{{ BASE_URL }}admin/posts/edit/{{ post.id }}">
                                                    <i class="bi bi-pencil-square me-2"></i> Editar Rascunho
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="{{ BASE_URL }}admin/posts/submit/{{ post.id }}">
                                                    <i class="bi bi-send me-2"></i> Submeter para Revisão
                                                </a>
                                            </li>

                                        {% elseif post.status == 'pending' and userRole != 'usuario' %}
                                            <li>
                                                <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#reviewModal{{ post.id }}">
                                                    <i class="bi bi-eye me-2"></i> Revisar Post
                                                </button>
                                            </li>
                                            {% if userRole == 'admin' %}
                                                <li>
                                                    <a class="dropdown-item" href="{{ BASE_URL }}admin/posts/approve/{{ post.id }}">
                                                        <i class="bi bi-check-circle me-2"></i> Aprovar e Publicar
                                                    </a>
                                                </li>
                                            {% endif %}
                                            <li>
                                                <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#rejectModal{{ post.id }}">
                                                    <i class="bi bi-x-circle me-2"></i> Rejeitar
                                                </button>
                                            </li>

                                        {% elseif post.status == 'published' and userRole == 'admin' %}
                                            <li>
                                                <a class="dropdown-item" href="{{ BASE_URL }}admin/posts/edit/{{ post.id }}">
                                                    <i class="bi bi-pencil-square me-2"></i> Editar Post
                                                </a>
                                            </li>
                                            {% if post.is_hidden|default(0) == 0 %}
                                                <li>
                                                    <a class="dropdown-item" href="{{ BASE_URL }}admin/posts/hide/{{ post.id }}" onclick="return confirm('Ocultar este post do blog?');">
                                                        <i class="bi bi-eye-slash me-2"></i> Ocultar do Blog
                                                    </a>
                                                </li>
                                            {% else %}
                                                <li>
                                                    <a class="dropdown-item" href="{{ BASE_URL }}admin/posts/show/{{ post.id }}" onclick="return confirm('Reexibir este post no blog?');">
                                                        <i class="bi bi-eye me-2"></i> Exibir no Blog
                                                    </a>
                                                </li>
                                            {% endif %}
                                            <li>
                                                <a class="dropdown-item" href="{{ BASE_URL }}admin/posts/delete/{{ post.id }}" onclick="return confirm('Deseja excluir este post permanentemente?')">
                                                    <i class="bi bi-trash me-2"></i> Deletar
                                                </a>
                                            </li>

                                        {% elseif post.status == 'rejected' and (userRole == 'admin' or (userRole == 'usuario' and post.user_id == user_id)) %}
                                            <li>
                                                <a class="dropdown-item" href="{{ BASE_URL }}admin/posts/edit/{{ post.id }}">
                                                    <i class="bi bi-pencil-square me-2"></i> Reabrir e Corrigir
                                                </a>
                                            </li>
                                            {% if userRole == 'admin' %}
                                                <li>
                                                    <a class="dropdown-item" href="{{ BASE_URL }}admin/posts/delete/{{ post.id }}" onclick="return confirm('Deseja excluir este post permanentemente?')">
                                                        <i class="bi bi-trash me-2"></i> Deletar
                                                    </a>
                                                </li>
                                            {% endif %}
                                        {% endif %}
                                    </ul>
                                </div>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Modais de Revisão e Rejeição (fora do loop da tabela) -->
        {% for post in posts %}
            {% if post.status == 'pending' %}
                <!-- Modal de Revisão -->
                <div class="modal fade" id="reviewModal{{ post.id }}" tabindex="-1" aria-labelledby="reviewModalLabel{{ post.id }}" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header border-bottom">
                                <h5 class="modal-title" id="reviewModalLabel{{ post.id }}">Revisar Post</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                            </div>
                            <div class="modal-body">
                                <h6 class="fw-bold">{{ post.titulo|e }}</h6>
                                <p class="small text-muted mb-3">Autor: <strong>{{ post.autor|e }}</strong> | Criado em: {{ post.criado_em|date('d/m/Y H:i') }}</p>
                                <div class="alert alert-light border" style="max-height: 300px; overflow-y: auto;">
                                    {{ post.conteudo|striptags|slice(0, 500) }}{% if post.conteudo|length > 500 %}...{% endif %}
                                </div>
                            </div>
                            <div class="modal-footer border-top">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                                {% if userRole == 'admin' %}
                                    <a href="{{ BASE_URL }}admin/posts/approve/{{ post.id }}" class="btn btn-success">
                                        <i class="bi bi-check-circle me-1"></i> Aprovar
                                    </a>
                                {% endif %}
                                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal{{ post.id }}" data-bs-dismiss="modal">
                                    <i class="bi bi-x-circle me-1"></i> Rejeitar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal de Rejeição -->
                <div class="modal fade" id="rejectModal{{ post.id }}" tabindex="-1" aria-labelledby="rejectModalLabel{{ post.id }}" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header border-bottom bg-light">
                                <h5 class="modal-title text-danger" id="rejectModalLabel{{ post.id }}">
                                    <i class="bi bi-exclamation-triangle me-2"></i>Rejeitar Post
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                            </div>
                            <form method="POST" action="{{ BASE_URL }}admin/posts/reject/{{ post.id }}">
                                <div class="modal-body">
                                    <input type="hidden" name="csrf_token" value="{{ csrf_token|default('') }}">
                                    <p class="mb-3"><strong>Post:</strong> {{ post.titulo|e }}</p>
                                    <label for="reject_reason{{ post.id }}" class="form-label fw-bold">Motivo da Rejeição:</label>
                                    <textarea id="reject_reason{{ post.id }}" name="reject_reason" class="form-control" rows="4" required placeholder="Descreva detalhadamente o motivo da rejeição..."></textarea>
                                </div>
                                <div class="modal-footer border-top">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                    <button type="submit" class="btn btn-danger">
                                        <i class="bi bi-x-circle me-1"></i> Confirmar Rejeição
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            {% endif %}
        {% endfor %}
    {% endif %}

    {% if pagination and pagination.total > 0 %}
        {% set current = pagination.current_page|default(1) %}
        {% set last = pagination.last_page|default(1) %}
        {% set range = 2 %}
        {% set start = max(1, current - range) %}
        {% set end = min(last, current + range) %}
        {% set queryPairs = [] %}
        {% for key, value in pagination.query|default({}) %}
            {% set queryPairs = queryPairs|merge([key ~ '=' ~ value|url_encode]) %}
        {% endfor %}
        {% set baseQueryString = queryPairs ? queryPairs|join('&') ~ '&' : '' %}

        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3 mt-4">
            <p class="text-muted small mb-0">Exibindo {{ pagination.from|default(0) }}–{{ pagination.to|default(0) }} de {{ pagination.total|default(0) }} registros</p>
            <form method="GET" class="d-flex align-items-center gap-2">
                <input type="hidden" name="page" value="1">
                {% for key, value in pagination.query|default({}) %}
                    {% if key != 'per_page' %}
                        <input type="hidden" name="{{ key }}" value="{{ value|e('html_attr') }}">
                    {% endif %}
                {% endfor %}
                <label class="text-muted small mb-0">Registros por página</label>
                <select name="per_page" class="form-select form-select-sm" onchange="this.form.submit()">
                    {% for option in perPageOptions %}
                        <option value="{{ option.value }}" {% if option.value == perPageSelection %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </form>
        </div>

        <nav aria-label="Paginação" class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item {% if current <= 1 %}disabled{% endif %}">
                    <a class="page-link" href="{% if current <= 1 %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current - 1 }}{% endif %}" aria-label="Anterior">
                        &laquo;
                    </a>
                </li>

                {% if start > 1 %}
                    <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page=1">1</a></li>
                    {% if start > 2 %}
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    {% endif %}
                {% endif %}

                {% for page in start..end %}
                    <li class="page-item {% if page == current %}active{% endif %}">
                        {% if page == current %}
                            <span class="page-link">{{ page }}</span>
                        {% else %}
                            <a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ page }}">{{ page }}</a>
                        {% endif %}
                    </li>
                {% endfor %}

                {% if end < last %}
                    {% if end < last - 1 %}
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    {% endif %}
                    <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ last }}">{{ last }}</a></li>
                {% endif %}

                <li class="page-item {% if current >= last %}disabled{% endif %}">
                    <a class="page-link" href="{% if current >= last %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current + 1 }}{% endif %}" aria-label="Próxima">
                        &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}
