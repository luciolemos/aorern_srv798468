{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Nova Categoria - Admin{% endblock %}
{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div data-aos="fade-down" class="mb-4">
        <h2 class="fw-bold" style="color: var(--admin-primary);"><i class="bi bi-tags me-2"></i>Cadastrar categoria de post</h2>
        <p class="text-muted mb-0">Cadastre nova categoria de post para o Blog</p>
    </div>
    <hr class="my-4">
    <div class="d-flex flex-column flex-md-row gap-2 w-100 w-md-auto justify-content-md-start mb-4">
            <a href="{{ BASE_URL }}admin/posts" class="btn btn-primary text-white">
               <i class="bi bi-journal-text"></i> Posts
            </a>

            <a href="{{ BASE_URL }}admin/post-categories" class="btn btn-outline-primary">
                <i class="bi bi-tags"></i> Categorias
            </a>

            <a href="{{ BASE_URL }}admin" class="btn btn-outline-secondary">
                <i class="bi bi-speedometer2 me-1"></i> Painel
            </a>
    </div>
    <form action="{{ BASE_URL }}admin/post-categories/store" method="post">
        <input type="hidden" name="csrf_token" value="{{ csrf_token|e }}">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label fw-bold">Código da categoria</label>
                <input type="text" name="staff_id" class="form-control" value="POSTCAT-{{ 'now'|date('YmdHis') }}" readonly>
            </div>
            <div class="col-md-5">
                <label class="form-label fw-bold">Nome da categoria</label>
                <input type="text" name="nome" class="form-control" required data-slug-source>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Slug</label>
                <input type="text" name="slug" class="form-control text-lowercase" placeholder="ex: operacoes" data-slug-target maxlength="140">
                <div class="form-text">Link amigável utilizado nas URLs do blog.</div>
            </div>
            <div class="col-md-5">
                <label class="form-label fw-bold">Cor do badge</label>
                <div class="d-flex gap-2 align-items-center color-picker-wrapper" data-color-picker>
                    <input type="color"
                           name="badge_color"
                           class="form-control form-control-color flex-shrink-0"
                           value="#df6301"
                           title="Escolha a cor do badge"
                           data-color-input
                           required>
                    <input type="text"
                           class="form-control text-uppercase"
                           value="#DF6301"
                           maxlength="7"
                           data-color-hex
                           placeholder="#DF6301">
                </div>
                <div class="form-text">Selecione ou informe um valor hexadecimal (#RRGGBB).</div>
            </div>
            <div class="col-md-7">
                <label class="form-label fw-bold">Descrição da categoria</label>
                <input type="text" name="descricao" class="form-control" placeholder="Descrição breve (opcional)"></input>
            </div>
        </div>
        <div class="border-top my-4"></div>
        <div class="d-flex flex-column flex-md-row gap-2 justify-content-md-end">
            <a href="{{ BASE_URL }}admin/post-categories" class="btn btn-outline-danger"><i class="bi bi-x-circle me-1"></i> Cancelar</a>
            <button type="submit" class="btn btn-success"><i class="bi bi-save me-1"></i> Salvar</button>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
    {{ parent() }}
    <script>
        document.querySelectorAll('[data-color-picker]').forEach(function(wrapper) {
            const colorInput = wrapper.querySelector('[data-color-input]');
            const hexInput = wrapper.querySelector('[data-color-hex]');
            if (!colorInput || !hexInput) return;

            const normalize = (value) => {
                const upper = value.toUpperCase();
                return /^#([A-F0-9]{6})$/.test(upper) ? upper : null;
            };

            const syncFromColor = () => {
                hexInput.value = colorInput.value.toUpperCase();
            };

            const syncFromHex = () => {
                const normalized = normalize(hexInput.value.trim());
                if (normalized) {
                    colorInput.value = normalized;
                    hexInput.value = normalized;
                } else {
                    hexInput.value = colorInput.value.toUpperCase();
                }
            };

            colorInput.addEventListener('input', syncFromColor);
            hexInput.addEventListener('blur', syncFromHex);
        });

        (function() {
            const source = document.querySelector('[data-slug-source]');
            const target = document.querySelector('[data-slug-target]');
            if (!source || !target) {
                return;
            }

            let userEdited = target.value.trim().length > 0;

            const slugify = (value) => {
                return value
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .replace(/[^a-zA-Z0-9]+/g, '-')
                    .replace(/^-+|-+$/g, '')
                    .toLowerCase();
            };

            target.addEventListener('input', () => {
                userEdited = target.value.trim().length > 0;
            });

            source.addEventListener('input', () => {
                if (userEdited) {
                    return;
                }
                target.value = slugify(source.value);
            });
        })();
    </script>
{% endblock %}
