{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Editar Cão Operacional - Admin{% endblock %}
{% block content %}
{% set avatarSrc = null %}
{% if dog.avatar %}
    {% if dog.avatar starts with 'http' %}
        {% set avatarSrc = dog.avatar %}
    {% else %}
        {% set avatarSrc = BASE_URL ~ dog.avatar %}
    {% endif %}
{% endif %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div class="mb-4 d-flex flex-column flex-md-row gap-3 align-items-start align-items-md-center">
        <div>
            <a href="{{ BASE_URL }}admin/dogs" class="btn btn-link text-decoration-none px-0 text-muted">
                <i class="bi bi-arrow-left"></i> Voltar para cães
            </a>
            <h2 class="fw-bold mt-2 text-primary"><i class="bi bi-pencil-square me-2"></i>Editar cão operacional</h2>
            <p class="text-muted mb-0">Atualize dados administrativos e garanta que o status operacional reflita a situação real.</p>
        </div>
        {% if avatarSrc %}
            <img src="{{ avatarSrc|e('html_attr') }}" alt="{{ dog.name|e('html_attr') }}" class="rounded shadow-sm ms-md-auto" style="width: 120px; height: 120px; object-fit: cover;">
        {% endif %}
    </div>

    <form method="post" action="{{ BASE_URL }}admin/dogs/update/{{ dog.id }}" class="card border-0 shadow-sm" enctype="multipart/form-data">
        <input type="hidden" name="csrf_token" value="{{ csrf_token|e }}">
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Nome operacional</label>
                    <input type="text" class="form-control" name="name" value="{{ dog.name|e('html_attr') }}" required data-slug-source>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Slug</label>
                    <input type="text" class="form-control text-lowercase" name="slug" value="{{ dog.slug|e('html_attr') }}" maxlength="140" data-slug-target>
                    <div class="form-text">Mantenha o identificador amigável deste cão.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Raça</label>
                    <select name="breed_id" class="form-select" required>
                        {% for breed in breeds %}
                            <option value="{{ breed.id }}" {% if breed.id == dog.breed_id %}selected{% endif %}>{{ breed.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Sexo</label>
                    {% set selectedSex = dog.sex|default('unknown') %}
                    <select name="sex" class="form-select">
                        {% for value, label in sexOptions %}
                            <option value="{{ value }}" {% if value == selectedSex %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Peso (kg)</label>
                    <input type="number" step="0.1" min="0" class="form-control" name="weight_kg" value="{{ dog.weight_kg|default('')|e('html_attr') }}">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Data de nascimento</label>
                    {% set birthDateValue = dog.birth_date ? dog.birth_date|date('Y-m-d') : '' %}
                    <input type="date" class="form-control" name="birth_date" value="{{ birthDateValue|e('html_attr') }}">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Cidade de nascimento</label>
                    <input type="text" class="form-control" name="birth_city" value="{{ dog.birth_city|default('')|e('html_attr') }}">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Estado (UF)</label>
                    <input type="text" class="form-control text-uppercase" name="birth_state" maxlength="2" value="{{ dog.birth_state|default('')|e('html_attr') }}">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Função operacional</label>
                    {% set selectedFunction = dog.operational_function|default('') %}
                    <select name="operational_function" class="form-select">
                        <option value="">Selecione</option>
                        {% for value, label in functionOptions %}
                            <option value="{{ value }}" {% if value == selectedFunction %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Fase de treinamento</label>
                    {% set selectedTraining = dog.training_phase|default('') %}
                    <select name="training_phase" class="form-select">
                        <option value="">Não definido</option>
                        {% for value, label in trainingOptions %}
                            <option value="{{ value }}" {% if value == selectedTraining %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Status</label>
                    {% set selectedStatus = dog.status|default('available') %}
                    <select name="status" class="form-select">
                        {% for value, label in statusOptions %}
                            <option value="{{ value }}" {% if value == selectedStatus %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Atualizar retrato</label>
                    <input type="file" class="form-control" name="avatar" accept="image/jpeg,image/png,image/webp">
                    <div class="form-text">Enviar um novo arquivo substitui o retrato atual. Deixe em branco para manter.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Marcas identificadoras</label>
                    <textarea name="identifying_marks" rows="3" class="form-control">{{ dog.identifying_marks|default('')|e }}</textarea>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Observações gerais</label>
                    <textarea name="notes" rows="5" class="form-control">{{ dog.notes|default('')|e }}</textarea>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light d-flex flex-column flex-md-row gap-2 justify-content-md-end">
            <a href="{{ BASE_URL }}admin/dogs" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Cancelar</a>
            <button type="submit" class="btn btn-warning text-white"><i class="bi bi-save me-1"></i> Atualizar cão</button>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
    {{ parent() }}
    <script>
        (function() {
            const source = document.querySelector('[data-slug-source]');
            const target = document.querySelector('[data-slug-target]');
            if (!source || !target) {
                return;
            }

            let userEdited = target.value.trim().length > 0;

            const slugify = (value) => {
                return value
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .replace(/[^a-zA-Z0-9]+/g, '-')
                    .replace(/^-+|-+$/g, '')
                    .toLowerCase();
            };

            target.addEventListener('input', () => {
                userEdited = target.value.trim().length > 0;
            });

            source.addEventListener('input', () => {
                if (userEdited) {
                    return;
                }
                target.value = slugify(source.value);
            });
        })();
    </script>
{% endblock %}
