{% extends 'admin/layouts/base_admin.twig' %}

{% block title %}Usuários - Admin{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div>
        <h2 class="fw-bold" style="color: var(--admin-primary);"><i class="bi bi-people-fill me-2"></i> Usuários do Sistema</h2>
        <p class="text-muted mb-0">Gerencie usuários, roles e permissões</p>
        <hr class="my-4">

        <div class="d-flex flex-column flex-md-row gap-2 w-100 w-md-auto justify-content-md-start mb-4">
            <a href="{{ BASE_URL }}admin/auth/register" class="btn btn-primary text-white">
                <i class="bi bi-plus-circle me-1"></i> Novo Usuário
            </a>
            <a href="{{ BASE_URL }}admin" class="btn btn-outline-secondary ms-md-auto">
                <i class="bi bi-speedometer2 me-1"></i> Painel
            </a>
        </div>
    </div>

    <!-- Painel de Filtros Avançado -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light border-bottom">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-funnel me-2"></i> <strong>Filtros Avançados</strong></h5>
                {% set hasActiveFilters = q or role or status %}
                {% if hasActiveFilters %}
                    <a href="{{ BASE_URL }}admin/usuarios" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Limpar Filtros
                    </a>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            <form method="GET" class="row g-3 g-xl-4 align-items-end">
                <input type="hidden" name="per_page" value="{{ perPageSelection|default('')|e('html_attr') }}">
                <!-- Busca -->
                <div class="col-12 col-md-6 col-xl-4">
                    <label class="form-label small mb-1" for="search"><i class="bi bi-search me-1"></i> <strong>Busca</strong></label>
                    <input
                        type="text"
                        id="search"
                        name="q"
                        class="form-control"
                        placeholder="Nome ou email..."
                        value="{{ q|default('')|e('html_attr') }}"
                    >
                </div>

                <!-- Filtro por Role -->
                <div class="col-12 col-md-3 col-xl-3">
                    <label class="form-label small mb-1" for="role"><i class="bi bi-shield me-1"></i> <strong>Role</strong></label>
                    <select id="role" name="role" class="form-select">
                        <option value="">Todas</option>
                        <option value="admin" {% if role == 'admin' %}selected{% endif %}>Admin</option>
                        <option value="gerente" {% if role == 'gerente' %}selected{% endif %}>Gerente</option>
                        <option value="operador" {% if role == 'operador' %}selected{% endif %}>Operador</option>
                        <option value="usuario" {% if role == 'usuario' %}selected{% endif %}>Usuário</option>
                    </select>
                </div>

                <!-- Filtro por Status -->
                <div class="col-12 col-md-3 col-xl-3">
                    <label class="form-label small mb-1" for="status"><i class="bi bi-check-circle me-1"></i> <strong>Status</strong></label>
                    <select id="status" name="status" class="form-select">
                        <option value="">Todos</option>
                        <option value="ativo" {% if status == 'ativo' %}selected{% endif %}>Ativo</option>
                        <option value="pendente" {% if status == 'pendente' %}selected{% endif %}>Pendente</option>
                        <option value="bloqueado" {% if status == 'bloqueado' %}selected{% endif %}>Bloqueado</option>
                    </select>
                </div>

                <!-- Botão de Busca -->
                <div class="col-12 col-md-6 col-xl-2 d-grid">
                    <button type="submit" class="btn btn-primary d-flex align-items-center justify-content-center w-100">
                        <i class="bi bi-search me-1"></i> Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    {% if usuarios is empty %}
        <div class="alert alert-info alert-dismissible fade show">
            <i class="bi bi-info-circle me-2"></i> Nenhum usuário encontrado
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-center" style="width: 50px;">ID</th>
                        <th>Usuário</th>
                        <th class="d-none d-lg-table-cell">Email</th>
                        <th class="d-none d-xxl-table-cell" style="width: 80px;">Role</th>
                        <th class="d-none d-md-table-cell" style="width: 80px;">Status</th>
                        <th class="d-none d-xxl-table-cell" style="width: 100px;">Último Login</th>
                        <th class="d-none d-xxl-table-cell" style="width: 100px;">Cadastrado</th>
                        <th class="text-center" style="width: 50px;">Ações</th>
                    </tr>
                    </thead>
                    <tbody>
                        {% for usuario in usuarios %}
                        <tr>
                            <td class="text-center">{{ usuario.id }}</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    {% if usuario.avatar %}
                                        <img src="{{ BASE_URL }}{{ usuario.avatar }}" alt="{{ usuario.username }}" class="rounded" style="width: 48px; height: 48px; object-fit: cover; border-radius: .25rem;">
                                    {% else %}
                                        <div class="rounded bg-primary d-inline-flex justify-content-center align-items-center text-white" style="width: 48px; height: 48px; font-weight: 700; border-radius: .25rem;">
                                            {{ usuario.username[0]|upper }}
                                        </div>
                                    {% endif %}
                                    <span class="fw-semibold">{{ usuario.username }}</span>
                                </div>
                            </td>
                            <td class="d-none d-lg-table-cell"><small>{{ usuario.email }}</small></td>
                            <td class="d-none d-xxl-table-cell"><small>{{ usuario.role }}</small></td>
                            <td class="d-none d-md-table-cell">
                                {% set status = usuario.status ?? (usuario.ativo ? 'ativo' : 'pendente') %}
                                {% if status == 'ativo' %}
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Ativo</span>
                                {% elseif status == 'bloqueado' %}
                                    <span class="badge bg-danger"><i class="bi bi-slash-circle me-1"></i>Bloqueado</span>
                                {% else %}
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Pendente</span>
                                {% endif %}
                            </td>
                            <td class="text-muted small d-none d-xxl-table-cell">{{ usuario.ultimo_login ? usuario.ultimo_login|date('d/m/Y H:i') : '-' }}</td>
                            <td class="text-muted small d-none d-xxl-table-cell">{{ usuario.created_at|date('d/m/Y') }}</td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Ações">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        {% if status == 'pendente' %}
                                            <li>
                                                <form method="POST" action="{{ BASE_URL }}admin/usuarios/ativar" class="d-inline">
                                                    <input type="hidden" name="id" value="{{ usuario.id }}">
                                                    <button type="submit" class="dropdown-item">
                                                        <i class="bi bi-check-circle me-2"></i> Aprovar
                                                    </button>
                                                </form>
                                            </li>
                                            <li>
                                                <form method="POST" action="{{ BASE_URL }}admin/usuarios/desativar" class="d-inline">
                                                    <input type="hidden" name="id" value="{{ usuario.id }}">
                                                    <button type="submit" class="dropdown-item">
                                                        <i class="bi bi-slash-circle me-2"></i> Bloquear
                                                    </button>
                                                </form>
                                            </li>
                                        {% elseif status == 'ativo' %}
                                            <li>
                                                <form method="POST" action="{{ BASE_URL }}admin/usuarios/desativar" class="d-inline">
                                                    <input type="hidden" name="id" value="{{ usuario.id }}">
                                                    <button type="submit" class="dropdown-item">
                                                        <i class="bi bi-pause-circle me-2"></i> Bloquear
                                                    </button>
                                                </form>
                                            </li>
                                        {% else %}
                                            <li>
                                                <form method="POST" action="{{ BASE_URL }}admin/usuarios/ativar" class="d-inline">
                                                    <input type="hidden" name="id" value="{{ usuario.id }}">
                                                    <button type="submit" class="dropdown-item">
                                                        <i class="bi bi-play-circle me-2"></i> Ativar
                                                    </button>
                                                </form>
                                            </li>
                                        {% endif %}
                                        <li>
                                            <form method="POST" action="{{ BASE_URL }}admin/usuarios/deletar" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir este usuário?')">
                                                <input type="hidden" name="id" value="{{ usuario.id }}">
                                                <button type="submit" class="dropdown-item">
                                                    <i class="bi bi-trash me-2"></i> Excluir
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if pagination and pagination.total > 0 %}
                {% set current = pagination.current_page|default(1) %}
                {% set last = pagination.last_page|default(1) %}
                {% set range = 2 %}
                {% set start = max(1, current - range) %}
                {% set end = min(last, current + range) %}
                {% set queryPairs = [] %}
                {% for key, value in pagination.query|default({}) %}
                    {% set queryPairs = queryPairs|merge([key ~ '=' ~ value|url_encode]) %}
                {% endfor %}
                {% set baseQueryString = queryPairs ? queryPairs|join('&') ~ '&' : '' %}

                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3 mt-4">
                    <p class="text-muted small mb-0">
                        Exibindo {{ pagination.from|default(0) }}–{{ pagination.to|default(0) }} de {{ pagination.total|default(0) }} registros
                    </p>
                    <form method="GET" class="d-flex align-items-center gap-2">
                        <input type="hidden" name="page" value="1">
                        {% for key, value in pagination.query|default({}) %}
                            {% if key != 'per_page' %}
                                <input type="hidden" name="{{ key }}" value="{{ value|e('html_attr') }}">
                            {% endif %}
                        {% endfor %}
                        <label class="text-muted small mb-0">Registros por página</label>
                        <select name="per_page" class="form-select form-select-sm" onchange="this.form.submit()">
                            {% for option in perPageOptions %}
                                <option value="{{ option.value }}" {% if option.value == perPageSelection %}selected{% endif %}>{{ option.label }}</option>
                            {% endfor %}
                        </select>
                    </form>
                </div>

                <nav aria-label="Paginação" class="mt-3">
                    <ul class="pagination justify-content-center mb-0">
                            <li class="page-item {% if current <= 1 %}disabled{% endif %}">
                                <a class="page-link" href="{% if current <= 1 %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current - 1 }}{% endif %}" aria-label="Anterior">
                                    &laquo;
                                </a>
                            </li>

                            {% if start > 1 %}
                                <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page=1">1</a></li>
                                {% if start > 2 %}
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                {% endif %}
                            {% endif %}

                            {% for page in start..end %}
                                <li class="page-item {% if page == current %}active{% endif %}">
                                    {% if page == current %}
                                        <span class="page-link">{{ page }}</span>
                                    {% else %}
                                        <a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ page }}">{{ page }}</a>
                                    {% endif %}
                                </li>
                            {% endfor %}

                            {% if end < last %}
                                {% if end < last - 1 %}
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                {% endif %}
                                <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ last }}">{{ last }}</a></li>
                            {% endif %}

                            <li class="page-item {% if current >= last %}disabled{% endif %}">
                                <a class="page-link" href="{% if current >= last %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current + 1 }}{% endif %}" aria-label="Próxima">
                                    &raquo;
                                </a>
                            </li>
                        </ul>
                </nav>
            {% endif %}
        {% endif %}
    </div>

{% endblock %}
