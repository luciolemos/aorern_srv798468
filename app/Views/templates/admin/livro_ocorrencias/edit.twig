{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Editar ocorrência - Livro{% endblock %}

{% block styles %}
<style>
    .livro-autocomplete { position: relative; }
    .livro-autocomplete .autocomplete-results {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid rgba(15, 23, 42, 0.12);
        border-radius: 0 0 .5rem .5rem;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.15);
        z-index: 1050;
        max-height: 260px;
        overflow-y: auto;
    }
    .livro-autocomplete .autocomplete-results button {
        width: 100%;
        border: 0;
        background: transparent;
        text-align: left;
        padding: .65rem .9rem;
        font-size: 0.9rem;
    }
    .livro-autocomplete .autocomplete-results button:hover {
        background: rgba(85, 107, 47, 0.08);
    }
</style>
{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4" data-module="livro-ocorrencias">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <p class="text-uppercase small text-muted mb-1">Protocolo {{ registro.protocolo }}</p>
            <h1 class="h3 fw-bold" style="color: var(--admin-primary, #556b2f);">
                <i class="bi bi-journal-arrow-up me-2"></i>
                Atualizar ocorrência
            </h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ BASE_URL }}admin/livro-ocorrencias" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </div>
    </div>
    <hr class="mt-4">

    {% set formData = old ?? registro %}
    {% if old is not null and old.data_ocorrencia is defined %}
        {% set dataInputValue = old.data_ocorrencia %}
    {% else %}
        {% set dataInputValue = registro.data_ocorrencia_formatted|default('') %}
    {% endif %}
    {% if old is not null and old.closed_at is defined %}
        {% set closedInputValue = old.closed_at %}
    {% else %}
        {% set closedInputValue = registro.closed_at_formatted|default('') %}
    {% endif %}

    <div class="alert alert-warning d-flex align-items-start gap-2" role="alert">
        <i class="bi bi-info-circle-fill fs-4"></i>
        <div>
            O status é calculado automaticamente: permanece aberto até que uma data de encerramento seja definida.
        </div>
    </div>

    <form method="post" action="{{ BASE_URL }}admin/livro-ocorrencias/update/{{ registro.id }}" class="row g-4" novalidate>
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-3">
                            <label class="form-label text-uppercase small fw-semibold">Protocolo</label>
                            <input type="text" class="form-control" value="{{ registro.protocolo }}" disabled>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-uppercase small fw-semibold">Data e hora *</label>
                            <input type="datetime-local" class="form-control" name="data_ocorrencia" value="{{ dataInputValue|default('')|e('html_attr') }}" required>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label text-uppercase small fw-semibold">Município *</label>
                            <div class="livro-autocomplete" data-autocomplete="municipios">
                                <input type="hidden" name="municipio_codigo" value="{{ formData.municipio_codigo|default(registro.municipio_codigo)|e('html_attr') }}" data-autocomplete-code>
                                <input type="hidden" name="municipio_label" value="{{ formData.municipio_label|default(registro.municipio_nome)|e('html_attr') }}" data-autocomplete-label>
                                <input type="text" class="form-control" placeholder="Digite para localizar o município" value="{{ formData.municipio_label|default(registro.municipio_nome)|e('html_attr') }}" data-autocomplete-input autocomplete="off" required>
                                <div class="autocomplete-results d-none" data-autocomplete-results></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-uppercase small fw-semibold">Subgrupamento *</label>
                            <select name="subgrupamento" class="form-select" required>
                                {% for grupo in subgrupamentos %}
                                    <option value="{{ grupo }}" {{ formData.subgrupamento|default(registro.subgrupamento) == grupo ? 'selected' : '' }}>{{ grupo }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-uppercase small fw-semibold">Tipo de ocorrência *</label>
                            {% set selectedTipoId = formData.tipo_id|default(registro.tipo_id) %}
                            <select name="tipo_id" class="form-select" required>
                                {% for tipo in tipoOptions %}
                                    <option value="{{ tipo.id }}" {{ selectedTipoId == tipo.id ? 'selected' : '' }}>
                                        {{ tipo.nome }}{% if tipo.ativo is defined and not tipo.ativo %} (inativo){% endif %}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-uppercase small fw-semibold">Encerramento (opcional)</label>
                            <input
                                type="datetime-local"
                                class="form-control"
                                name="closed_at"
                                value="{{ closedInputValue|default('')|e('html_attr') }}">
                            <div class="form-text">Defina para marcar a ocorrência como concluída.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-uppercase small fw-semibold">Status atual</label>
                            <div class="border rounded px-3 py-2 bg-light d-flex align-items-center gap-2">
                                <span class="badge {{ registro.status == 'concluida' ? 'bg-success' : 'bg-warning text-dark' }} text-uppercase">{{ registro.status_label }}</span>
                                {% if registro.closed_at %}
                                    <small class="text-muted">Encerrado em {{ registro.closed_at|date('d/m/Y H\hi') }}</small>
                                {% else %}
                                    <small class="text-muted">Aberto desde {{ registro.data_ocorrencia|date('d/m/Y H\hi') }}</small>
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-uppercase small fw-semibold">Descrição operacional *</label>
                                <textarea
                                    name="descricao"
                                    id="descricao_editor"
                                    rows="6"
                                    class="form-control"
                                    data-livro-editor
                                    data-editor-required="true"
                                    data-editor-min="10"
                                    data-editor-height="520"
                                    placeholder="Relate a ocorrência com detalhes"
                                    required>{{ formData.descricao|default(registro.descricao)|raw }}</textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-uppercase small fw-semibold">Relatório de conclusão</label>
                                <textarea
                                    name="relatorio_conclusao"
                                    id="relatorio_editor"
                                    rows="4"
                                    class="form-control"
                                    data-livro-editor
                                    data-editor-min="0"
                                    data-editor-height="380"
                                    placeholder="Opcional — utilize após encerramento">{{ formData.relatorio_conclusao|default(registro.relatorio_conclusao)|raw }}</textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 d-flex flex-column flex-md-row gap-2 justify-content-end">
            <a href="{{ BASE_URL }}admin/livro-ocorrencias" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-success">
                <i class="bi bi-save me-1"></i>
                Salvar alterações
            </button>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
    {% include 'admin/livro_ocorrencias/partials/editor_scripts.twig' %}
    <script src="{{ BASE_URL }}assets/js/livro-ocorrencias.js" defer></script>
{% endblock %}
