{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Cadastrar Associado - Admin{% endblock %}
{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
   <!-- Cabeçalho -->
    <div data-aos="fade-down" class="mb-4">
        <h2 class="fw-bold admin-page-title"><i class="bi bi-person-plus me-2"></i>Cadastrar associado</h2>
        <p class="text-muted mb-0">Cadastre um novo registro para a base associativa da AORERN</p>
    </div>
    <hr class="my-4">
    
    <!-- Formulário -->
    <form method="post" action="{{ BASE_URL }}admin/pessoal/salvar" enctype="multipart/form-data">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <div class="row">
            <!-- Coluna Principal -->
            <div class="col-lg-12">
                <!-- Card Dados Pessoais -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 fw-bold admin-section-title">
                            <i class="bi bi-person-vcard me-2"></i>Dados Pessoais
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Código do associado</label>
                                <input type="text" class="form-control" name="staff_id" readonly
                                       value="{{ staff_id }}">
                            </div>

                            <div class="col-md-8">
                                <label class="form-label fw-bold">Nome Completo <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="nome" required placeholder="Digite o nome completo">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">CPF <span class="text-danger">*</span></label>
                                <input type="text" class="form-control cpf-mask" name="cpf" required
                                       maxlength="14" placeholder="000.000.000-00">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Data Nascimento</label>
                                <input type="date" class="form-control" name="nascimento">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Celular</label>
                                <input type="text" class="form-control phone-mask" name="telefone"
                                       maxlength="16" placeholder="(00) 00000-0000">
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold">
                                    <i class="bi bi-image me-1"></i>Foto do associado
                                </label>
                                <input type="file" class="form-control" name="foto"
                                       accept="image/jpeg,image/png,image/webp" 
                                    onchange="previewFoto(this)">
                                <small class="text-muted">JPG, PNG ou WebP • Máximo 50MB (opcional)</small>
                                
                                <!-- Preview -->
                                <div class="mt-2 d-none" id="fotoPreviewContainer">
                                    <img id="fotoPreview" src="" alt="Preview"
                                         class="rounded shadow-sm admin-photo-preview">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card Vínculo associativo -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 fw-bold admin-section-title">
                            <i class="bi bi-diagram-3 me-2"></i>Vínculo associativo
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Função <span class="text-danger">*</span></label>
                                <select name="funcao_id" class="form-select" required>
                                    <option value="" disabled selected>Selecione a função</option>
                                    {% for funcao in funcoes %}
                                        <option value="{{ funcao.id }}">{{ funcao.nome }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Data de ingresso <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" name="data_admissao" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Status</label>
                                <select name="status" class="form-select">
                                    <option value="Ativo" selected>Ativo</option>
                                    <option value="Afastado">Afastado</option>
                                    <option value="Férias">Férias</option>
                                    <option value="Demitido">Demitido</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Status associativo</label>
                                <select name="status_associativo" class="form-select">
                                    {% for option in statusAssociativoOptions %}
                                        <option value="{{ option }}" {% if option == 'provisorio' %}selected{% endif %}>
                                            {{ option == 'efetivo' ? 'Sócio Efetivo' : (option == 'honorario' ? 'Sócio Honorário' : (option == 'fundador' ? 'Sócio Fundador' : (option == 'benemerito' ? 'Sócio Benemérito' : (option == 'veterano' ? 'Sócio Veterano' : (option == 'aluno' ? 'Sócio Aluno' : 'Sócio Provisório'))))) }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card Observações -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 fw-bold admin-section-title">
                            <i class="bi bi-list-columns-reverse me-2"></i>Observações
                        </h5>
                    </div>
                    <div class="card-body">
                        <textarea name="observacoes" rows="4" class="form-control" placeholder="Informações adicionais sobre o associado..."></textarea>
                </div>
            </div>

            <!-- Separador -->
            <div class="col-12">
                <div class="border-top my-4"></div>
            </div>

            <!-- Botões de Ação -->
            <div class="col-12">
                <div class="d-flex flex-column flex-md-row gap-2 order-md-2 w-100 w-md-auto justify-content-md-end">
                    <a href="{{ BASE_URL }}admin" class="btn btn-theme-surface"><i class="bi bi-speedometer2 me-1"></i> Painel</a>
                    <a href="{{ BASE_URL }}admin/pessoal" class="btn btn-theme-outline-neutral"><i class="bi bi-x-circle me-1"></i> Cancelar</a>
                    <button type="submit" class="btn btn-theme"><i class="bi bi-save me-1"></i> Salvar</button>
                </div>
            </div>
        </div>            <!-- Sidebar Informações -->
{#             <div class="col-lg-4">
                <!-- Card de Ajuda -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom">
                                        <h5 class="mb-0 fw-bold admin-section-title">
                            <i class="bi bi-info-circle me-2"></i>Informações
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="small text-muted mb-2">
                            <i class="bi bi-check-circle text-success me-1"></i>
                            Campos com <span class="text-danger">*</span> são obrigatórios
                        </p>
                        <p class="small text-muted mb-2">
                            <i class="bi bi-check-circle text-success me-1"></i>
                            O código é gerado automaticamente
                        </p>
                        <p class="small text-muted mb-2">
                            <i class="bi bi-check-circle text-success me-1"></i>
                            A foto é opcional mas recomendada
                        </p>
                        <p class="small text-muted mb-0">
                            <i class="bi bi-check-circle text-success me-1"></i>
                            Todos os dados podem ser editados posteriormente
                        </p>
                    </div>
                </div>
            </div> #}
        </div>
    </form>
</div>

<script>
function previewFoto(input) {
    const preview = document.getElementById('fotoPreview');
    const container = document.getElementById('fotoPreviewContainer');
    
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
            container.classList.remove('d-none');
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>

{% endblock %}
