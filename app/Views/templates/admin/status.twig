{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Status do Sistema - Admin{% endblock %}
{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div class="mb-4">
        <h2 class="fw-bold" style="color: var(--admin-primary);">
            <i class="bi bi-check-circle me-2"></i>Status do Sistema
        </h2>
        <p class="text-muted mb-0">Verificação de integridade e conectividade dos componentes essenciais.</p>
        <hr class="my-4">
    </div>

    {% set checks = [
        {'key': 'env', 'label': 'Arquivo .env', 'description': 'Leitura das variáveis de ambiente'},
        {'key': 'db', 'label': 'Banco de dados', 'description': 'Conexão com o banco principal'},
        {'key': 'smtp', 'label': 'SMTP', 'description': 'Conectividade de envio de e-mail'},
        {'key': 'recaptcha', 'label': 'reCAPTCHA', 'description': 'Disponibilidade da proteção de formulários'}
    ] %}

    <div class="row g-3 mb-4">
        {% for item in checks %}
            {% set ok = attribute(status, item.key)|default(false) %}
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                            <h6 class="mb-0 fw-semibold">{{ item.label }}</h6>
                            <span class="badge {{ ok ? 'bg-success' : 'bg-danger' }}">
                                {{ ok ? 'OK' : 'FALHA' }}
                            </span>
                        </div>
                        <p class="small text-muted mb-0">{{ item.description }}</p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Componente</th>
                            <th>Resultado</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in checks %}
                            {% set ok = attribute(status, item.key)|default(false) %}
                            <tr>
                                <td class="fw-semibold">{{ item.label }}</td>
                                <td>
                                    <span class="badge {{ ok ? 'bg-success' : 'bg-danger' }}">
                                        <i class="bi {{ ok ? 'bi-check-circle' : 'bi-x-circle' }} me-1"></i>
                                        {{ ok ? 'Disponível' : 'Indisponível' }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
