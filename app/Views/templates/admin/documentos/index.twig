{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Documentos Institucionais{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div class="mb-4">
        <h2 class="fw-bold admin-page-title"><i class="bi bi-file-earmark-text me-2"></i>Documentos institucionais</h2>
        <p class="text-muted mb-0">Gerencie estatuto, atas, ofícios, políticas e materiais oficiais da AORERN.</p>
        <hr class="my-4">
        <div class="d-flex flex-column flex-md-row gap-2">
            <a href="{{ BASE_URL }}admin/documentos/cadastrar" class="btn btn-primary text-white"><i class="bi bi-plus-circle me-1"></i>Novo documento</a>
            <a href="{{ BASE_URL }}admin/institucional" class="btn btn-outline-primary"><i class="bi bi-bank me-1"></i>Núcleo institucional</a>
            <a href="{{ BASE_URL }}admin" class="btn btn-outline-secondary"><i class="bi bi-speedometer2 me-1"></i>Painel</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="GET" class="row g-3 align-items-end">
                <div class="col-lg-5">
                    <label class="form-label small mb-1"><strong>Busca</strong></label>
                    <input type="text" name="q" class="form-control" value="{{ filters.q|default('')|e('html_attr') }}" placeholder="Título, resumo ou slug">
                </div>
                <div class="col-lg-3">
                    <label class="form-label small mb-1"><strong>Tipo</strong></label>
                    <select name="type" class="form-select">
                        <option value="">Todos</option>
                        {% for option in typeOptions %}
                            <option value="{{ option }}" {% if filters.type == option %}selected{% endif %}>{{ option|replace({'_': ' '})|title }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-lg-2">
                    <label class="form-label small mb-1"><strong>Status</strong></label>
                    <select name="status" class="form-select">
                        <option value="">Todos</option>
                        {% for option in statusOptions %}
                            <option value="{{ option }}" {% if filters.status == option %}selected{% endif %}>{{ option|title }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-lg-2 d-flex gap-2">
                    {% if filters.q or filters.status or filters.type %}
                        <a href="{{ BASE_URL }}admin/documentos" class="btn btn-outline-secondary flex-grow-1">Limpar</a>
                    {% endif %}
                    <button type="submit" class="btn btn-primary flex-grow-1">Filtrar</button>
                </div>
            </form>
        </div>
    </div>

    {% if documentos is empty %}
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Nenhum documento cadastrado.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>PREVIEW</th>
                        <th>TÍTULO</th>
                        <th>CATEGORIA</th>
                        <th>STATUS</th>
                        <th>PUBLICAÇÃO</th>
                        <th>ORDEM EDITORIAL</th>
                        <th class="text-center">AÇÕES</th>
                    </tr>
                </thead>
                <tbody>
                    {% for documento in documentos %}
                        <tr>
                            <td class="admin-doc-thumb-cell">
                                {% if documento.arquivo_url and documento.tipo == 'marca' and ('.svg' in documento.arquivo_url or '.png' in documento.arquivo_url or '.jpg' in documento.arquivo_url or '.jpeg' in documento.arquivo_url) %}
                                    <div class="rounded-3 border bg-white overflow-hidden d-flex align-items-center justify-content-center admin-doc-thumb-box">
                                        <img src="{{ documento.arquivo_url|e('html_attr') }}" alt="{{ documento.titulo|e('html_attr') }}" class="admin-doc-thumb-img">
                                    </div>
                                {% else %}
                                    <div class="rounded-3 border bg-light d-flex align-items-center justify-content-center text-primary admin-doc-thumb-box">
                                        <i class="bi {{ documento.tipo == 'estatuto' ? 'bi-bank' : (documento.tipo == 'ata' ? 'bi-journal-richtext' : (documento.tipo == 'oficio' ? 'bi-envelope-paper' : (documento.tipo == 'politica' ? 'bi-shield-lock' : (documento.tipo == 'termo' ? 'bi-file-earmark-medical' : (documento.tipo == 'formulario' ? 'bi-ui-checks-grid' : (documento.tipo == 'marca' ? 'bi-palette2' : 'bi-file-earmark-text')))))) }} fs-4"></i>
                                    </div>
                                {% endif %}
                            </td>
                            <td>
                                <div class="fw-semibold">{{ documento.titulo|e }}</div>
                                <small class="text-muted">{{ documento.slug|e }}</small>
                                {% if documento.resumo %}
                                    <div class="small text-muted mt-1">{{ documento.resumo|length > 110 ? documento.resumo|slice(0, 110) ~ '…' : documento.resumo }}</div>
                                {% endif %}
                            </td>
                            <td><span class="badge bg-light text-dark border">{{ documento.tipo == 'marca' ? 'Identidade visual' : documento.tipo|replace({'_': ' '})|title }}</span></td>
                            <td><span class="badge {{ documento.status == 'published' ? 'bg-success' : (documento.status == 'archived' ? 'bg-secondary' : 'bg-warning text-dark') }}">{{ documento.status|title }}</span></td>
                            <td>{{ documento.publicado_em ? documento.publicado_em|date('d/m/Y H:i') : '-' }}</td>
                            <td><span class="fw-semibold">{{ '%02d'|format(documento.ordem) }}</span></td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button class="btn btn-link text-secondary p-0" type="button" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        {% if documento.arquivo_url %}
                                            <li><a class="dropdown-item" href="{{ documento.arquivo_url|e('html_attr') }}" target="_blank"><i class="bi bi-paperclip me-2"></i>Abrir arquivo</a></li>
                                        {% endif %}
                                        {% if documento.link_externo %}
                                            <li><a class="dropdown-item" href="{{ documento.link_externo|e('html_attr') }}" target="_blank"><i class="bi bi-box-arrow-up-right me-2"></i>Link externo</a></li>
                                        {% endif %}
                                        <li><a class="dropdown-item" href="{{ BASE_URL }}admin/documentos/editar/{{ documento.id }}"><i class="bi bi-pencil-square me-2"></i>Editar</a></li>
                                        <li><a class="dropdown-item text-danger" href="{{ BASE_URL }}admin/documentos/deletar/{{ documento.id }}" onclick="return confirm('Remover este documento?');"><i class="bi bi-trash me-2"></i>Excluir</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if pagination and pagination.total > 0 %}
        {% set current = pagination.current_page|default(1) %}
        {% set last = pagination.last_page|default(1) %}
        {% set range = 2 %}
        {% set start = max(1, current - range) %}
        {% set end = min(last, current + range) %}
        {% set queryPairs = [] %}
        {% for key, value in pagination.query|default({}) %}
            {% set queryPairs = queryPairs|merge([key ~ '=' ~ value|url_encode]) %}
        {% endfor %}
        {% set baseQueryString = queryPairs ? queryPairs|join('&') ~ '&' : '' %}

        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3 mt-4">
            <p class="text-muted small mb-0">Exibindo {{ pagination.from|default(0) }}-{{ pagination.to|default(0) }} de {{ pagination.total|default(0) }} documentos</p>
            <form method="GET" class="d-flex align-items-center gap-2">
                <input type="hidden" name="page" value="1">
                {% for key, value in pagination.query|default({}) %}
                    {% if key != 'per_page' %}
                        <input type="hidden" name="{{ key }}" value="{{ value|e('html_attr') }}">
                    {% endif %}
                {% endfor %}
                <label class="text-muted small mb-0">Registros por página</label>
                <select name="per_page" class="form-select form-select-sm" onchange="this.form.submit()">
                    {% for option in perPageOptions %}
                        <option value="{{ option.value }}" {% if option.value == perPageSelection %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </form>
        </div>
        <nav aria-label="Paginação" class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item {% if current <= 1 %}disabled{% endif %}"><a class="page-link" href="{% if current <= 1 %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current - 1 }}{% endif %}">&laquo;</a></li>
                {% if start > 1 %}
                    <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page=1">1</a></li>
                    {% if start > 2 %}<li class="page-item disabled"><span class="page-link">…</span></li>{% endif %}
                {% endif %}
                {% for page in start..end %}
                    <li class="page-item {% if page == current %}active{% endif %}">
                        {% if page == current %}<span class="page-link">{{ page }}</span>{% else %}<a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ page }}">{{ page }}</a>{% endif %}
                    </li>
                {% endfor %}
                {% if end < last %}
                    {% if end < last - 1 %}<li class="page-item disabled"><span class="page-link">…</span></li>{% endif %}
                    <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ last }}">{{ last }}</a></li>
                {% endif %}
                <li class="page-item {% if current >= last %}disabled{% endif %}"><a class="page-link" href="{% if current >= last %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current + 1 }}{% endif %}">&raquo;</a></li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}
