{% extends 'admin/layouts/base_admin.twig' %}

{% block title %}Funções - Admin{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div data-aos="fade-down">
        <h2 class="text-primary"><i class="bi bi-list-columns-reverse me-2"></i> Cargos e funções</h2>
        <p class="lead text-muted">Lista de cargos/funções na estrutura organizacional do CBMRN</p>
        <hr class="my-4">
        <div class="d-flex flex-column flex-md-row gap-2 w-100 justify-content-md-start align-items-md-center mt-4 mb-4">
            <a href="{{ BASE_URL }}admin/funcoes/cadastrar" class="btn btn-primary text-white">
                <i class="bi bi-plus-circle"></i> Nova função
            </a>
            <a href="{{ BASE_URL }}admin" class="btn btn-outline-secondary ms-md-auto">
                <i class="bi bi-speedometer2 me-1"></i> Painel
            </a>
        </div>
    </div>

    <div data-aos="fade-up">
        <form method="GET" class="mb-4">
            <div class="input-group">
                <input
                    type="text"
                    name="q"
                    class="form-control"
                    placeholder="Buscar cargo/função por DESCRIÇÃO..."
                    value="{{ q|default('')|e('html_attr') }}"
                    autofocus
                >
                <input type="hidden" name="per_page" value="{{ perPageSelection|default('')|e('html_attr') }}">
                {% if q is not empty %}
                    <a href="{{ BASE_URL }}admin/funcoes" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i>
                    </a>
                {% endif %}
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search me-1"></i> Buscar
                </button>
            </div>
        </form>
    </div>

    {% if funcoes is empty %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i> Não há função com esse nome em nossa base de dados.
        </div>
    {% else %}
        <div class="table-responsive" data-aos="fade-up">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-center">#</th>
                        <th>CÓD DA FUNÇÃO</th>
                        <th>DESCRIÇÃO</th>
                        <th class="text-center">AÇÕES</th>
                    </tr>
                </thead>
                <tbody>
                    {% for f in funcoes %}
                        <tr>
                            <td class="text-center"><i class="bi bi-tags text-primary"></i></td>
                            <td>{{ f.staff_id|e }}</td>
                            <td>{{ f.nome|e }}</td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Ações">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" href="{{ BASE_URL }}admin/funcoes/editar/{{ f.id }}">
                                                <i class="bi bi-pencil-square me-2"></i> Editar
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="{{ BASE_URL }}admin/funcoes/deletar/{{ f.id }}" onclick="return confirm('Deseja excluir esta função?')">
                                                <i class="bi bi-trash me-2"></i> Excluir
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if pagination and pagination.total > 0 %}
        {% set current = pagination.current_page|default(1) %}
        {% set last = pagination.last_page|default(1) %}
        {% set range = 2 %}
        {% set start = max(1, current - range) %}
        {% set end = min(last, current + range) %}
        
        {% set queryPairs = [] %}
        {% for key, value in pagination.query|default({}) %}
            {% set queryPairs = queryPairs|merge([key ~ '=' ~ value|url_encode]) %}
        {% endfor %}
        {% set baseQueryString = queryPairs ? queryPairs|join('&') ~ '&' : '' %}
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3 mt-4">
            <p class="text-muted mb-0 small">
                Exibindo {{ pagination.from|default(0) }}-{{ pagination.to|default(0) }} de {{ pagination.total|default(0) }} registros
            </p>
            <form method="GET" class="d-flex align-items-center gap-2">
                <input type="hidden" name="page" value="1">
                {% for key, value in pagination.query|default({}) %}
                    {% if key != 'per_page' %}
                        <input type="hidden" name="{{ key }}" value="{{ value|e('html_attr') }}">
                    {% endif %}
                {% endfor %}
                <label class="text-muted small mb-0">Registros por página</label>
                <select name="per_page" class="form-select form-select-sm" onchange="this.form.submit()">
                    {% for option in perPageOptions %}
                        <option value="{{ option.value }}" {% if option.value == perPageSelection %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </form>
        </div>
        <nav aria-label="Paginação" class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item {% if current <= 1 %}disabled{% endif %}">
                    <a class="page-link" href="{% if current <= 1 %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current - 1 }}{% endif %}" tabindex="-1" aria-disabled="{% if current <= 1 %}true{% else %}false{% endif %}">
                        &laquo;
                    </a>
                </li>

                {% if start > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page=1">1</a>
                    </li>
                    {% if start > 2 %}
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    {% endif %}
                {% endif %}

                {% for page in start..end %}
                    <li class="page-item {% if page == current %}active{% endif %}">
                        {% if page == current %}
                            <span class="page-link">{{ page }}</span>
                        {% else %}
                            <a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ page }}">{{ page }}</a>
                        {% endif %}
                    </li>
                {% endfor %}

                {% if end < last %}
                    {% if end < last - 1 %}
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    {% endif %}
                    <li class="page-item">
                        <a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ last }}">{{ last }}</a>
                    </li>
                {% endif %}

                <li class="page-item {% if current >= last %}disabled{% endif %}">
                    <a class="page-link" href="{% if current >= last %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current + 1 }}{% endif %}" aria-disabled="{% if current >= last %}true{% else %}false{% endif %}">
                        &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    {% endif %}

</div>
{% endblock %}
