{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Patrocinadores{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div class="mb-4">
        <h2 class="fw-bold admin-page-title"><i class="bi bi-megaphone me-2"></i>Patrocinadores</h2>
        <p class="text-muted mb-0">Gerencie empresas colaboradoras exibidas no carrossel da home.</p>
        <hr class="my-4">
        <a href="{{ BASE_URL }}admin/patrocinadores/cadastrar" class="btn btn-primary text-white">
            <i class="bi bi-plus-circle me-1"></i>Novo patrocinador
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="GET" class="row g-3 align-items-end">
                <input type="hidden" name="per_page" value="{{ perPageSelection|default('')|e('html_attr') }}">
                <div class="col-lg-6">
                    <label class="form-label small mb-1"><strong>Busca</strong></label>
                    <input type="text" name="q" class="form-control" placeholder="Nome, telefone ou e-mail" value="{{ filters.q|default('')|e('html_attr') }}">
                </div>
                <div class="col-lg-3">
                    <label class="form-label small mb-1"><strong>Situação</strong></label>
                    <select name="ativo" class="form-select">
                        <option value="">Todos</option>
                        <option value="1" {% if filters.ativo == '1' %}selected{% endif %}>Ativo</option>
                        <option value="0" {% if filters.ativo == '0' %}selected{% endif %}>Inativo</option>
                    </select>
                </div>
                <div class="col-lg-3 d-flex gap-2">
                    {% if filters.q or filters.ativo != '' %}
                        <a href="{{ BASE_URL }}admin/patrocinadores" class="btn btn-outline-secondary flex-grow-1">Limpar</a>
                    {% endif %}
                    <button type="submit" class="btn btn-primary flex-grow-1">Filtrar</button>
                </div>
            </form>
        </div>
    </div>

    {% if patrocinadores is empty %}
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Nenhum patrocinador cadastrado.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>EMPRESA</th>
                        <th class="d-none d-lg-table-cell">CONTATO</th>
                        <th class="d-none d-lg-table-cell">ORDEM</th>
                        <th class="d-none d-md-table-cell">STATUS</th>
                        <th class="text-center">AÇÕES</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in patrocinadores %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    {% if item.logo_path %}
                                        <img src="{{ BASE_URL }}{{ item.logo_path }}" alt="{{ item.nome|e('html_attr') }}" class="rounded border" style="width:48px;height:48px;object-fit:cover;">
                                    {% else %}
                                        <div class="rounded bg-light border d-inline-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    {% endif %}
                                    <div>
                                        <div class="fw-semibold">{{ item.nome|e }}</div>
                                        <small class="text-muted">{{ item.descricao_curta|default('-')|e }}</small>
                                    </div>
                                </div>
                            </td>
                            <td class="d-none d-lg-table-cell">
                                <div><strong>Telefone:</strong> {{ item.telefone|default('-')|e }}</div>
                                <div><strong>WhatsApp:</strong> {{ item.whatsapp|default('-')|e }}</div>
                            </td>
                            <td class="d-none d-lg-table-cell">{{ item.ordem }}</td>
                            <td class="d-none d-md-table-cell">
                                <span class="badge {{ item.ativo ? 'bg-success' : 'bg-secondary' }}">{{ item.ativo ? 'Ativo' : 'Inativo' }}</span>
                            </td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button class="btn btn-link text-secondary p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" href="{{ BASE_URL }}admin/patrocinadores/editar/{{ item.id }}">
                                                <i class="bi bi-pencil-square me-2"></i>Editar
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form method="POST" action="{{ BASE_URL }}admin/patrocinadores/deletar/{{ item.id }}" onsubmit="return confirm('Excluir este patrocinador?');">
                                                <input type="hidden" name="csrf_token" value="{{ csrf_token|e('html_attr') }}">
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="bi bi-trash me-2"></i>Excluir
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if pagination and pagination.total > 0 %}
        {% set current = pagination.current_page|default(1) %}
        {% set last = pagination.last_page|default(1) %}
        {% set range = 2 %}
        {% set start = max(1, current - range) %}
        {% set end = min(last, current + range) %}
        {% set queryPairs = [] %}
        {% for key, value in pagination.query|default({}) %}
            {% set queryPairs = queryPairs|merge([key ~ '=' ~ value|url_encode]) %}
        {% endfor %}
        {% set baseQueryString = queryPairs ? queryPairs|join('&') ~ '&' : '' %}

        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3 mt-4">
            <p class="text-muted small mb-0">Exibindo {{ pagination.from|default(0) }}-{{ pagination.to|default(0) }} de {{ pagination.total|default(0) }} registros</p>
            <form method="GET" class="d-flex align-items-center gap-2">
                <input type="hidden" name="page" value="1">
                {% for key, value in pagination.query|default({}) %}
                    {% if key != 'per_page' %}
                        <input type="hidden" name="{{ key }}" value="{{ value|e('html_attr') }}">
                    {% endif %}
                {% endfor %}
                <label class="text-muted small mb-0">Registros por página</label>
                <select name="per_page" class="form-select form-select-sm" onchange="this.form.submit()">
                    {% for option in perPageOptions %}
                        <option value="{{ option.value }}" {% if option.value == perPageSelection %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                </select>
            </form>
        </div>
        <nav aria-label="Paginação" class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item {% if current <= 1 %}disabled{% endif %}">
                    <a class="page-link" href="{% if current <= 1 %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current - 1 }}{% endif %}">&laquo;</a>
                </li>
                {% if start > 1 %}
                    <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page=1">1</a></li>
                    {% if start > 2 %}<li class="page-item disabled"><span class="page-link">…</span></li>{% endif %}
                {% endif %}
                {% for page in start..end %}
                    <li class="page-item {% if page == current %}active{% endif %}">
                        {% if page == current %}<span class="page-link">{{ page }}</span>{% else %}<a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ page }}">{{ page }}</a>{% endif %}
                    </li>
                {% endfor %}
                {% if end < last %}
                    {% if end < last - 1 %}<li class="page-item disabled"><span class="page-link">…</span></li>{% endif %}
                    <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ last }}">{{ last }}</a></li>
                {% endif %}
                <li class="page-item {% if current >= last %}disabled{% endif %}">
                    <a class="page-link" href="{% if current >= last %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current + 1 }}{% endif %}">&raquo;</a>
                </li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}

