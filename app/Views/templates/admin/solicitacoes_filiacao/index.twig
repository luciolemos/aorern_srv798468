{% extends 'admin/layouts/base_admin.twig' %}

{% block title %}Solicitações de Filiação - Admin{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div>
        <h2 class="fw-bold admin-page-title"><i class="bi bi-person-vcard me-2"></i> Solicitações de filiação</h2>
        <p class="text-muted mb-0">Fila de ex-alunos do NPOR de Natal/RN que desejam se afiliar à AORE/RN.</p>
        <hr class="my-4">
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light border-bottom">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-funnel me-2"></i><strong>Busca</strong></h5>
                {% if q or status or statusAssociativo or uf or cidade %}
                    <a href="{{ BASE_URL }}admin/solicitacoes-filiacao" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Limpar filtros
                    </a>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            <form method="GET" class="row g-3 align-items-end">
                <input type="hidden" name="per_page" value="{{ perPageSelection|default('')|e('html_attr') }}">
                <div class="col-12 col-lg-4">
                    <label class="form-label small mb-1" for="search"><i class="bi bi-search me-1"></i><strong>Busca</strong></label>
                    <input type="text" id="search" name="q" class="form-control" placeholder="Nome, e-mail, CPF, ano NPOR ou usuário..." value="{{ q|default('')|e('html_attr') }}">
                </div>
                <div class="col-12 col-md-4 col-lg-2">
                    <label class="form-label small mb-1" for="status"><i class="bi bi-check-circle me-1"></i><strong>Status</strong></label>
                    <select id="status" name="status" class="form-select">
                        <option value="">Todos</option>
                        <option value="pendente" {% if status == 'pendente' %}selected{% endif %}>Pendente</option>
                        <option value="complementacao" {% if status == 'complementacao' %}selected{% endif %}>Complementação</option>
                        <option value="aprovada" {% if status == 'aprovada' %}selected{% endif %}>Aprovada</option>
                        <option value="rejeitada" {% if status == 'rejeitada' %}selected{% endif %}>Rejeitada</option>
                    </select>
                </div>
                <div class="col-12 col-md-4 col-lg-2">
                    <label class="form-label small mb-1" for="status_associativo"><i class="bi bi-award me-1"></i><strong>Status associativo</strong></label>
                    <select id="status_associativo" name="status_associativo" class="form-select">
                        <option value="">Todos</option>
                        <option value="provisorio" {% if statusAssociativo == 'provisorio' %}selected{% endif %}>Sócio Provisório</option>
                        <option value="efetivo" {% if statusAssociativo == 'efetivo' %}selected{% endif %}>Sócio Efetivo</option>
                        <option value="honorario" {% if statusAssociativo == 'honorario' %}selected{% endif %}>Sócio Honorário</option>
                        <option value="fundador" {% if statusAssociativo == 'fundador' %}selected{% endif %}>Sócio Fundador</option>
                        <option value="benemerito" {% if statusAssociativo == 'benemerito' %}selected{% endif %}>Sócio Benemérito</option>
                        <option value="veterano" {% if statusAssociativo == 'veterano' %}selected{% endif %}>Sócio Veterano</option>
                        <option value="aluno" {% if statusAssociativo == 'aluno' %}selected{% endif %}>Sócio Aluno</option>
                    </select>
                </div>
                <div class="col-12 col-md-4 col-lg-1">
                    <label class="form-label small mb-1" for="uf"><i class="bi bi-signpost-2 me-1"></i><strong>UF</strong></label>
                    <select id="uf" name="uf" class="form-select">
                        <option value="">Todas</option>
                        {% for ufOption in ufs|default([]) %}
                            <option value="{{ ufOption|e('html_attr') }}" {% if uf == ufOption %}selected{% endif %}>{{ ufOption|e }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-12 col-md-4 col-lg-2">
                    <label class="form-label small mb-1" for="cidade"><i class="bi bi-geo-alt me-1"></i><strong>Cidade</strong></label>
                    <select id="cidade" name="cidade" class="form-select">
                        <option value="">Todas</option>
                        {% for cidadeOption in cidades %}
                            <option value="{{ cidadeOption|e('html_attr') }}" {% if cidade == cidadeOption %}selected{% endif %}>{{ cidadeOption|e }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-12 col-md-4 col-lg-2 d-grid">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i> Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    {% if solicitacoes is empty %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Nenhuma solicitação encontrada.
        </div>
    {% else %}
        <div class="row g-3">
            {% for solicitacao in solicitacoes %}
                {% set currentStatus = solicitacao.status|default('pendente') %}
                {% set statusAssociativoLabel = solicitacao.status_associativo == 'efetivo' ? 'Sócio Efetivo' : (solicitacao.status_associativo == 'honorario' ? 'Sócio Honorário' : (solicitacao.status_associativo == 'fundador' ? 'Sócio Fundador' : (solicitacao.status_associativo == 'benemerito' ? 'Sócio Benemérito' : (solicitacao.status_associativo == 'veterano' ? 'Sócio Veterano' : (solicitacao.status_associativo == 'aluno' ? 'Sócio Aluno' : 'Sócio Provisório'))))) %}
                <div class="col-12">
                        <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex flex-column flex-xl-row justify-content-between gap-3">
                                <div class="flex-grow-1">
                                    <div class="d-flex flex-column flex-lg-row gap-3 mb-3">
                                        <div class="flex-shrink-0 text-center">
                                            {% if solicitacao.avatar_url %}
                                                <img src="{{ solicitacao.avatar_url|e('html_attr') }}"
                                                     alt="{{ solicitacao.nome_completo|e('html_attr') }}"
                                                     class="rounded shadow-sm admin-application-avatar">
                                            {% else %}
                                                <span class="rounded d-inline-flex align-items-center justify-content-center text-white fw-bold shadow-sm admin-application-avatar-fallback">
                                                    {{ solicitacao.nome_completo|default('?')|slice(0, 1)|upper }}
                                                </span>
                                            {% endif %}
                                            <div class="small fw-semibold text-muted mt-2">
                                                Al {{ solicitacao.numero_militar|default('--')|e }} {{ solicitacao.nome_guerra|default('-')|e }}
                                            </div>
                                            <div class="small text-muted">
                                                NPOR/{{ solicitacao.ano_npor|default('--')|e }}
                                            </div>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                                <h5 class="mb-0 fw-bold">{{ solicitacao.nome_completo|e }}</h5>
                                                {% if currentStatus == 'aprovada' %}
                                                    <span class="badge bg-success">Aprovada</span>
                                                {% elseif currentStatus == 'rejeitada' %}
                                                    <span class="badge bg-danger">Rejeitada</span>
                                                {% elseif currentStatus == 'complementacao' %}
                                                    <span class="badge bg-info text-dark">Complementação</span>
                                                {% else %}
                                                    <span class="badge bg-warning text-dark">Pendente</span>
                                                {% endif %}
                                                <span class="badge bg-light text-dark border">{{ statusAssociativoLabel }}</span>
                                            </div>
                                            <div class="small text-muted">
                                                Recebida em {{ solicitacao.criado_em ? solicitacao.criado_em|date('d/m/Y H:i') : '-' }}
                                            </div>
                                            <div class="small text-muted mt-2">
                                                <div><strong>Posto/Graduação:</strong> {{ solicitacao.posto_graduacao|default('-')|e }}</div>
                                                <div><strong>Arma/Quadro/Serviço:</strong> {{ solicitacao.arma_quadro|default('-')|e }}</div>
                                                <div><strong>Local de nascimento:</strong> {{ solicitacao.localizacao_label|default('-')|e }}</div>
                                                <div><strong>Data de nascimento:</strong> {{ solicitacao.data_nascimento ? solicitacao.data_nascimento|date('d/m/Y') : '-' }}</div>
                                                <div><strong>RG:</strong> {{ solicitacao.rg|default('-')|e }}</div>
                                                <div><strong>CPF:</strong> {{ solicitacao.cpf|e }}</div>
                                                <div><strong>E-mail:</strong> {{ solicitacao.email|e }}</div>
                                                <div><strong>Telefone:</strong> {{ solicitacao.telefone|default('-')|e }}</div>
                                                <div><strong>Nome do pai:</strong> {{ solicitacao.nome_pai|default('-')|e }}</div>
                                                <div><strong>Nome da mãe:</strong> {{ solicitacao.nome_mae|default('-')|e }}</div>
                                                <div><strong>Turma:</strong> {{ solicitacao.turma_npor|default('-')|e }}</div>
                                                <div><strong>Usuário:</strong> {{ solicitacao.username_desejado|e }}</div>
                                                {% if solicitacao.documentos is not empty %}
                                                    <div class="mt-2"><strong>Documentos comprobatórios</strong></div>
                                                    {% if solicitacao.preview_documento %}
                                                        <div class="mt-2">
                                                            <a href="{{ solicitacao.preview_documento.url|e('html_attr') }}" target="_blank" rel="noopener" class="text-decoration-none">
                                                                <img src="{{ solicitacao.preview_documento.url|e('html_attr') }}"
                                                                     alt="{{ solicitacao.preview_documento.name|default('Documento de imagem')|e('html_attr') }}"
                                                                     class="img-fluid rounded border shadow-sm admin-doc-preview-image">
                                                            </a>
                                                        </div>
                                                    {% endif %}
                                                    <div class="d-flex flex-column gap-2 mt-2">
                                                        {% for documento in solicitacao.documentos %}
                                                            {% set isPdf = documento.mime_type|default('') == 'application/pdf' %}
                                                            <a href="{{ documento.url|default(BASE_URL ~ documento.path)|e('html_attr') }}" target="_blank" rel="noopener" class="text-decoration-none d-flex align-items-center gap-2">
                                                                <span class="badge {{ isPdf ? 'bg-danger' : (documento.is_image ? 'bg-secondary' : 'bg-dark') }}">{{ isPdf ? 'PDF' : (documento.is_image ? 'IMG' : 'ARQ') }}</span>
                                                                <span><i class="bi bi-paperclip me-1"></i>{{ documento.name|default('Documento')|e }}</span>
                                                            </a>
                                                        {% endfor %}
                                                    </div>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>

                                    {% if solicitacao.last_notification_status %}
                                        <div class="mt-3 p-3 rounded border small {{ solicitacao.last_notification_status == 'sent' ? 'bg-success-subtle border-success-subtle text-success-emphasis' : 'bg-warning-subtle border-warning-subtle text-warning-emphasis' }}">
                                            <strong>
                                                <i class="bi {{ solicitacao.last_notification_status == 'sent' ? 'bi-envelope-check' : 'bi-envelope-exclamation' }} me-1"></i>
                                                {{ solicitacao.notification_type_label|default('Notificação') }}
                                            </strong><br>
                                            Status do e-mail:
                                            {{ solicitacao.last_notification_status == 'sent' ? 'enviado' : 'falhou' }}
                                            {% if solicitacao.last_notification_at %}
                                                em {{ solicitacao.last_notification_at|date('d/m/Y H:i') }}
                                            {% endif %}
                                            {% if solicitacao.last_notification_error %}
                                                <br><span class="text-break"><strong>Detalhe:</strong> {{ solicitacao.last_notification_error|e }}</span>
                                            {% endif %}
                                        </div>
                                    {% endif %}

                                    {% if solicitacao.observacoes %}
                                        <div class="mt-3 p-3 rounded bg-light border small">
                                            <strong>Observações do solicitante</strong><br>
                                            {{ solicitacao.observacoes|nl2br }}
                                        </div>
                                    {% endif %}

                                    {% if solicitacao.observacoes_admin %}
                                        <div class="mt-3 p-3 rounded bg-light border small">
                                            <strong>Observações internas</strong><br>
                                            {{ solicitacao.observacoes_admin|nl2br }}
                                        </div>
                                    {% endif %}
                                </div>

                                <div class="border-start ps-xl-3 admin-panel-min-width">
                                    {% if currentStatus in ['pendente', 'complementacao'] %}
                                        <form method="POST" action="{{ BASE_URL }}admin/solicitacoes-filiacao/aprovar/{{ solicitacao.id }}" class="mb-3">
                                            <label class="form-label small fw-semibold">Status associativo inicial</label>
                                            <select name="status_associativo" class="form-select form-select-sm mb-2">
                                                <option value="provisorio" selected>Sócio Provisório</option>
                                                <option value="efetivo">Sócio Efetivo</option>
                                                <option value="honorario">Sócio Honorário</option>
                                                <option value="fundador">Sócio Fundador</option>
                                                <option value="benemerito">Sócio Benemérito</option>
                                                <option value="veterano">Sócio Veterano</option>
                                                <option value="aluno">Sócio Aluno</option>
                                            </select>
                                            <label class="form-label small fw-semibold">Observação interna para aprovação</label>
                                            <textarea name="observacoes_admin" class="form-control form-control-sm mb-2" rows="3" placeholder="Opcional. Ex.: documentação conferida, aprovado pela diretoria."></textarea>
                                            <button type="submit" class="btn btn-success w-100">
                                                <i class="bi bi-check-circle me-1"></i> Aprovar filiação
                                            </button>
                                        </form>
                                        <form method="POST" action="{{ BASE_URL }}admin/solicitacoes-filiacao/solicitar-complementacao/{{ solicitacao.id }}" class="mb-3">
                                            <label class="form-label small fw-semibold">Orientação para complementação</label>
                                            <textarea name="observacoes_admin" class="form-control form-control-sm mb-2" rows="3" placeholder="Ex.: enviar certificado do NPOR, documento de identidade ou comprovação complementar."></textarea>
                                            <button type="submit" class="btn btn-outline-primary w-100">
                                                <i class="bi bi-files me-1"></i> Solicitar complementação
                                            </button>
                                        </form>
                                        <form method="POST" action="{{ BASE_URL }}admin/solicitacoes-filiacao/rejeitar/{{ solicitacao.id }}">
                                            <label class="form-label small fw-semibold">Motivo da rejeição</label>
                                            <textarea name="observacoes_admin" class="form-control form-control-sm mb-2" rows="3" placeholder="Opcional. Ex.: dados insuficientes ou documentação pendente."></textarea>
                                            <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Deseja rejeitar esta solicitação de filiação?');">
                                                <i class="bi bi-x-circle me-1"></i> Rejeitar solicitação
                                            </button>
                                        </form>
                                    {% else %}
                                        <div class="small text-muted">
                                            {% if currentStatus == 'aprovada' %}
                                                <strong>Aprovada em:</strong> {{ solicitacao.aprovado_em ? solicitacao.aprovado_em|date('d/m/Y H:i') : '-' }}<br>
                                                <strong>Status associativo:</strong> {{ solicitacao.status_associativo == 'efetivo' ? 'Sócio Efetivo' : (solicitacao.status_associativo == 'honorario' ? 'Sócio Honorário' : (solicitacao.status_associativo == 'fundador' ? 'Sócio Fundador' : (solicitacao.status_associativo == 'benemerito' ? 'Sócio Benemérito' : (solicitacao.status_associativo == 'veterano' ? 'Sócio Veterano' : (solicitacao.status_associativo == 'aluno' ? 'Sócio Aluno' : 'Sócio Provisório'))))) }}<br>
                                                <strong>Acesso ao portal:</strong> {{ solicitacao.user_id ? 'Liberado' : 'Aguardando ato administrativo' }}<br>
                                                <strong>ID associado:</strong> {{ solicitacao.pessoal_id|default('-') }}
                                            {% else %}
                                                <strong>Rejeitada em:</strong> {{ solicitacao.rejeitado_em ? solicitacao.rejeitado_em|date('d/m/Y H:i') : '-' }}
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {% if pagination and pagination.total > 0 %}
            {% set current = pagination.current_page|default(1) %}
            {% set last = pagination.last_page|default(1) %}
            {% set range = 2 %}
            {% set start = max(1, current - range) %}
            {% set end = min(last, current + range) %}
            {% set queryPairs = [] %}
            {% for key, value in pagination.query|default({}) %}
                {% set queryPairs = queryPairs|merge([key ~ '=' ~ value|url_encode]) %}
            {% endfor %}
            {% set baseQueryString = queryPairs ? queryPairs|join('&') ~ '&' : '' %}

            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3 mt-4">
                <p class="text-muted small mb-0">
                    Exibindo {{ pagination.from|default(0) }}–{{ pagination.to|default(0) }} de {{ pagination.total|default(0) }} registros
                </p>
                <form method="GET" class="d-flex align-items-center gap-2">
                    <input type="hidden" name="page" value="1">
                    {% for key, value in pagination.query|default({}) %}
                        {% if key != 'per_page' %}
                            <input type="hidden" name="{{ key }}" value="{{ value|e('html_attr') }}">
                        {% endif %}
                    {% endfor %}
                    <label class="text-muted small mb-0">Registros por página</label>
                    <select name="per_page" class="form-select form-select-sm" onchange="this.form.submit()">
                        {% for option in perPageOptions %}
                            <option value="{{ option.value }}" {% if option.value == perPageSelection %}selected{% endif %}>{{ option.label }}</option>
                        {% endfor %}
                    </select>
                </form>
            </div>

            <nav aria-label="Paginação" class="mt-3">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item {% if current <= 1 %}disabled{% endif %}">
                        <a class="page-link" href="{% if current <= 1 %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current - 1 }}{% endif %}">&laquo;</a>
                    </li>
                    {% if start > 1 %}
                        <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page=1">1</a></li>
                        {% if start > 2 %}
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        {% endif %}
                    {% endif %}
                    {% for page in start..end %}
                        <li class="page-item {% if page == current %}active{% endif %}">
                            {% if page == current %}
                                <span class="page-link">{{ page }}</span>
                            {% else %}
                                <a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ page }}">{{ page }}</a>
                            {% endif %}
                        </li>
                    {% endfor %}
                    {% if end < last %}
                        {% if end < last - 1 %}
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        {% endif %}
                        <li class="page-item"><a class="page-link" href="{{ pagination.path }}?{{ baseQueryString }}page={{ last }}">{{ last }}</a></li>
                    {% endif %}
                    <li class="page-item {% if current >= last %}disabled{% endif %}">
                        <a class="page-link" href="{% if current >= last %}#{% else %}{{ pagination.path }}?{{ baseQueryString }}page={{ current + 1 }}{% endif %}">&raquo;</a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
