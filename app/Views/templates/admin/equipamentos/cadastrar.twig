{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Cadastrar Equipamento - Admin{% endblock %}
{% block content %}
<div class="container-fluid px-3 px-md-4 py-4">
    <div data-aos="fade-down" class="mb-3">
        <h2 class="fw-bold" style="color: var(--admin-primary);"><i class="bi bi-tools me-2"></i>Cadastrar equipamento</h2>
        <p class="text-muted mb-0">Cadastre novo equipamento para o CBMRN</p>
    </div>
    <hr class="my-4">

    <form method="post" action="{{ BASE_URL }}admin/equipamentos/salvar">
       
           <div class="row mb-4">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Código do equipamento</label>
                    <input type="text" class="form-control" name="staff_id" readonly value="EQP-{{ 'now'|date('YmdHis') }}">
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Nome da ferramenta ou equipamento *</label>
                    <input type="text" name="nome" required class="form-control" placeholder="Furadeira de bancada">
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Número de série</label>
                    <input type="text" name="serial_number" class="form-control">
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Categoria *</label>
                    <select name="categoria_id" class="form-select" required>
                        <option value="" disabled selected>Selecione a categoria</option>
                        {% for cat in categorias %}
                            <option value="{{ cat.id }}">{{ cat.nome }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Marca</label>
                    <select name="marca" class="form-select">
                        <option value="">-- Selecione uma marca --</option>
                        <optgroup label="Marcas Premium">
                            <option value="DeWalt">DeWalt</option>
                            <option value="Milwaukee">Milwaukee</option>
                            <option value="Makita">Makita</option>
                            <option value="Bosch Professional">Bosch Professional</option>
                            <option value="Festool">Festool</option>
                        </optgroup>
                        <optgroup label="Marcas de Qualidade">
                            <option value="Stanley">Stanley</option>
                            <option value="Black & Decker">Black & Decker</option>
                            <option value="Ryobi">Ryobi</option>
                            <option value="Hilti">Hilti</option>
                            <option value="Metabo">Metabo</option>
                        </optgroup>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Modelo</label>
                    <input type="text" name="modelo" class="form-control">
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Data de aquisição</label>
                    <input type="date" name="data_fabricacao" class="form-control">
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Estado</label>
                    <select name="estado" class="form-select">
                        <option value="">-- Selecione um estado --</option>
                        <option value="Nova">Nova</option>
                        <option value="Usada">Usada</option>
                        <option value="Restaurada">Restaurada</option>
                        <option value="Danificada">Danificada</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Estoque</label>
                    <input type="number" name="quantidade_estoque" class="form-control" value="0" required>
                </div>
            </div>
        
        <div class="d-flex flex-column flex-md-row gap-2 order-md-2 w-100 w-md-auto justify-content-md-end">
            <a href="{{ BASE_URL }}admin" class="btn btn-primary"><i class="bi bi-speedometer2 me-1"></i> Painel</a>
            <a href="{{ BASE_URL }}admin/equipamentos" class="btn btn-danger"><i class="bi bi-x-circle me-1"></i> Cancelar</a>
            <button type="submit" class="btn btn-success"><i class="bi bi-save me-1"></i> Salvar</button>
        </div>
    </form>
</div>
{% endblock %}
