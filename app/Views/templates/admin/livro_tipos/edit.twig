{% extends 'admin/layouts/base_admin.twig' %}
{% block title %}Editar tipo de ocorrência{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-md-4 py-4" data-module="livro-tipos">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <p class="text-uppercase small text-muted mb-1">Tipo #{{ registro.id }}</p>
            <h1 class="h3 fw-bold" style="color: var(--admin-primary, #556b2f);">
                <i class="bi bi-pencil-square me-2"></i>
                Atualizar tipo de ocorrência
            </h1>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ BASE_URL }}admin/livro-tipos" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </div>
    </div>
    <hr class="mt-4">

    {% set form = old ?? registro %}

    <form method="post" action="{{ BASE_URL }}admin/livro-tipos/update/{{ registro.id }}" class="row g-4" novalidate>
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-uppercase small fw-semibold">Nome *</label>
                            <input type="text" name="nome" class="form-control" value="{{ form.nome|default('')|e('html_attr') }}" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase small fw-semibold">Slug</label>
                            <input type="text" name="slug" class="form-control" value="{{ form.slug|default('')|e('html_attr') }}" placeholder="ex: busca-e-salvamento" data-slug-field>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-uppercase small fw-semibold">Descrição</label>
                            <textarea name="descricao" rows="3" class="form-control" placeholder="Breve orientação sobre quando usar este tipo.">{{ form.descricao|default('')|e('html') }}</textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-uppercase small fw-semibold">Cor do badge</label>
                            <div class="input-group">
                                <span class="input-group-text p-0">
                                    <span class="d-inline-flex w-100 h-100" style="width: 38px;" data-color-preview></span>
                                </span>
                                <input type="text" name="badge_color" class="form-control" value="{{ form.badge_color|default('#556b2f')|e('html_attr') }}" placeholder="#F97316" data-color-input>
                                <input type="color" class="form-control form-control-color" value="{{ form.badge_color|default('#556b2f')|e('html_attr') }}" title="Selecionar cor" data-color-picker>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-uppercase small fw-semibold">Status</label>
                            <select name="ativo" class="form-select">
                                <option value="1" {{ form.ativo|default(1) ? 'selected' : '' }}>Ativo</option>
                                <option value="0" {{ not form.ativo|default(1) ? 'selected' : '' }}>Inativo</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="alert alert-light border w-100 mb-0 small">
                                <strong>{{ registro.ocorrencias_total|default(0) }}</strong> ocorrência(s) vinculadas a este tipo.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 d-flex flex-column flex-md-row gap-2 justify-content-end">
            <a href="{{ BASE_URL }}admin/livro-tipos" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-success">
                <i class="bi bi-save me-1"></i>
                Salvar alterações
            </button>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const root = document.querySelector('[data-module="livro-tipos"]');
        if (!root) return;

        const nameInput = root.querySelector('input[name="nome"]');
        const slugInput = root.querySelector('[data-slug-field]');
        const colorInput = root.querySelector('[data-color-input]');
        const preview = root.querySelector('[data-color-preview]');
        const colorPicker = root.querySelector('[data-color-picker]');

        const slugify = (value) => {
            return value
                .normalize('NFD')
                .replace(/[^\w\s-]/g, '')
                .trim()
                .toLowerCase()
                .replace(/[\s_-]+/g, '-')
                .replace(/^-+|-+$/g, '');
        };

        if (nameInput && slugInput) {
            nameInput.addEventListener('input', () => {
                if (slugInput.value.trim() === '') {
                    slugInput.value = slugify(nameInput.value);
                }
            });
        }

        const normalizeHex = (value) => {
            if (!value) return '';
            const match = value.trim().match(/^#?([0-9a-fA-F]{6})$/);
            return match ? `#${match[1].toUpperCase()}` : '';
        };

        const applyPreview = (hex) => {
            if (!preview) return;
            const color = hex || '#ffffff';
            preview.style.background = color;
            preview.style.minWidth = '38px';
            preview.style.borderRadius = '.35rem';
        };

        const syncFromText = () => {
            if (!colorInput) return;
            const normalized = normalizeHex(colorInput.value);
            if (normalized) {
                colorInput.value = normalized;
                if (colorPicker) {
                    colorPicker.value = normalized;
                }
            }
            applyPreview(normalized);
        };

        if (colorInput) {
            colorInput.addEventListener('input', syncFromText);
            syncFromText();
        }

        if (colorPicker) {
            colorPicker.addEventListener('input', () => {
                const normalized = normalizeHex(colorPicker.value) || '#DF6301';
                if (colorInput) {
                    colorInput.value = normalized;
                }
                applyPreview(normalized);
            });
        }
    });
</script>
{% endblock %}
