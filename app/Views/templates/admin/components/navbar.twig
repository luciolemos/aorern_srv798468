{# Navbar ADMIN- Importando do PHP original para manter compatibilidade #}
<nav class="navbar navbar-expand-lg navbar-dark admin-navbar">
    <div class="container-fluid px-4 d-flex align-items-center justify-content-between admin-navbar__shell">
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-outline-light d-none d-lg-inline-flex align-items-center justify-content-center" type="button" id="sidebarCollapseBtn" aria-label="Alternar largura do menu lateral" title="Alternar menu lateral">
                <i class="bi bi-layout-sidebar-inset fs-5"></i>
            </button>
            <button class="navbar-toggler d-lg-none" type="button" id="sidebarToggle" aria-label="Mostrar menu lateral">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
        <div class="d-flex align-items-center gap-3 ms-auto">
            {% set pendingCount = notifications.pending_users|default(0) %}
            {% set pendingMembershipApplications = notifications.pending_membership_applications|default(0) %}
            {% set occurrenceCount = notifications.occurrences_in_progress|default(0) %}
            {% set pendingPostsCount = notifications.posts_pending_review|default(0) %}
            {% set totalAlerts = pendingCount + pendingMembershipApplications + occurrenceCount + pendingPostsCount %}
            <div class="dropdown">
                <button class="btn admin-navbar-action admin-navbar-action--icon position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Abrir notificações" title="Notificações">
                    <i class="bi {{ totalAlerts > 0 ? 'bi-bell-fill text-warning' : 'bi-bell' }} fs-6"></i>
                    {% if totalAlerts > 0 %}
                        <span class="badge bg-danger rounded-pill position-absolute top-0 start-100 translate-middle admin-navbar-badge" data-digits="{{ totalAlerts|length }}">{{ totalAlerts }}</span>
                    {% endif %}
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm admin-navbar-dropdown admin-notifications-menu">
                    <li class="px-3 py-2 border-bottom">
                        <small class="text-uppercase text-muted fw-semibold">Alertas</small>
                    </li>
                    <li>
                        <a class="dropdown-item d-flex justify-content-between align-items-center" href="{{ BASE_URL }}admin/usuarios?status=pendente">
                            <span><i class="bi bi-people me-2"></i>Contas pendentes</span>
                            {% if pendingCount > 0 %}
                                <span class="badge bg-danger rounded-pill">{{ pendingCount }}</span>
                            {% else %}
                                <span class="badge bg-success-subtle text-success">OK</span>
                            {% endif %}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item d-flex justify-content-between align-items-center" href="{{ BASE_URL }}admin/solicitacoes-filiacao?status=pendente">
                            <span><i class="bi bi-person-vcard me-2"></i>Filiações pendentes</span>
                            {% if pendingMembershipApplications > 0 %}
                                <span class="badge bg-warning text-dark rounded-pill">{{ pendingMembershipApplications }}</span>
                            {% else %}
                                <span class="badge bg-success-subtle text-success">OK</span>
                            {% endif %}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item d-flex justify-content-between align-items-center" href="{{ BASE_URL }}admin/posts?status=pending">
                            <span><i class="bi bi-pencil-square me-2"></i>Posts pendentes de revisão</span>
                            {% if pendingPostsCount > 0 %}
                                <span class="badge bg-info text-dark rounded-pill">{{ pendingPostsCount }}</span>
                            {% else %}
                                <span class="badge bg-success-subtle text-success">OK</span>
                            {% endif %}
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item d-flex justify-content-between align-items-center" href="{{ BASE_URL }}admin/dashboard">
                            <span><i class="bi bi-archive me-2"></i>Registros legados monitorados</span>
                            {% if occurrenceCount > 0 %}
                                <span class="badge bg-warning text-dark rounded-pill">{{ occurrenceCount }}</span>
                            {% else %}
                                <span class="badge bg-success-subtle text-success">OK</span>
                            {% endif %}
                        </a>
                    </li>
                    {% if totalAlerts == 0 %}
                        <li><span class="dropdown-item-text text-muted small">Nenhum alerta pendente.</span></li>
                    {% endif %}
                </ul>
            </div>
            <div class="dropdown">
                <button class="btn admin-navbar-action admin-user-menu dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    {% if user.avatar %}
                        <img src="{{ BASE_URL }}{{ user.avatar }}" alt="{{ user.name }}" class="admin-user-menu__avatar rounded-circle">
                    {% else %}
                        <span class="admin-user-menu__avatar admin-user-menu__avatar--fallback rounded-circle d-inline-flex justify-content-center align-items-center bg-white text-dark">
                            {{ user.initial }}
                        </span>
                    {% endif %}
                    <span class="admin-user-menu__identity d-none d-xl-flex flex-column lh-1 text-start">
                        <span class="fw-semibold">{{ user.name }}</span>
                        <small class="opacity-75">{{ user.email }}</small>
                    </span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end admin-navbar-dropdown">
                    <li><a class="dropdown-item" href="{{ BASE_URL }}" target="_blank" rel="noopener"><i class="bi bi-house-door me-2"></i>Abrir site público</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item" href="{{ BASE_URL }}admin/perfil"><i class="bi bi-person-circle me-2"></i>Perfil</a></li>
                    <li><a class="dropdown-item" href="{{ BASE_URL }}admin/configuracoes"><i class="bi bi-gear-wide-connected me-2"></i>Preferências</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="{{ BASE_URL }}admin/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Sair</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>
