<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}AORE/RN{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% if meta_description is defined and meta_description %}
        <meta name="description" content="{{ meta_description|e('html_attr') }}">
    {% endif %}
    {% if meta_canonical is defined and meta_canonical %}
        <link rel="canonical" href="{{ meta_canonical|e('html_attr') }}">
    {% endif %}
    {% if meta_og_title is defined and meta_og_title %}
        <meta property="og:title" content="{{ meta_og_title|e('html_attr') }}">
    {% endif %}
    {% if meta_og_description is defined and meta_og_description %}
        <meta property="og:description" content="{{ meta_og_description|e('html_attr') }}">
    {% endif %}
    {% if meta_og_url is defined and meta_og_url %}
        <meta property="og:url" content="{{ meta_og_url|e('html_attr') }}">
    {% endif %}
    {% if meta_og_type is defined and meta_og_type %}
        <meta property="og:type" content="{{ meta_og_type|e('html_attr') }}">
    {% endif %}
    {% if meta_og_image is defined and meta_og_image %}
        <meta property="og:image" content="{{ meta_og_image|e('html_attr') }}">
    {% endif %}
    {% if fb_app_id is defined and fb_app_id %}
        <meta property="fb:app_id" content="{{ fb_app_id|e('html_attr') }}">
    {% endif %}
    <link rel="icon" type="image/png" sizes="32x32" href="{{ BASE_URL }}assets/images/favicon/aorern/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ BASE_URL }}assets/images/favicon/aorern/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ BASE_URL }}assets/images/favicon/aorern/apple-touch-icon.png">
    <link rel="shortcut icon" href="{{ BASE_URL }}assets/images/favicon/aorern/favicon.ico">
    
    <!-- CSS -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&family=Roboto+Condensed:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/system/variables.css">
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/system/components.css">
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/institutional-theme.css">
    <link rel="stylesheet" href="{{ asset('assets/css/navbar-universal.css') }}?v=20260516-navbar-active-6">
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/footer-robust.css">
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/main.css?v=20260516-overflow-fix-1">
    
    {% block styles %}{% endblock %}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/system/forms-unified.css">
</head>

<body class="d-flex flex-column min-vh-100 has-public-navbar site-body">
    {{ toast_html|raw }}
    {% include 'components/navbar.twig' %}

    <main class="flex-fill p-0">
        {% block content %}{% endblock %}
    </main>

    {% include 'components/footer.twig' %}

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="{{ asset('assets/js/navbar-public.js') }}?v=20260516-mobile-nav-fix-5" defer></script>
    <script src="{{ BASE_URL }}assets/js/toast-init.js" defer></script>
    <script>
        AOS.init({
            duration: 800,
            easing: 'ease-in-out-quad',
            once: true,
            mirror: false
        });
    </script>
    
    {% block scripts %}{% endblock %}
</body>
</html>
