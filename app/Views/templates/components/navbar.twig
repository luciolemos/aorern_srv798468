{% set currentRoute = current_path|default('') %}
{% set navItems = [
    {'slug': '', 'label': 'Início', 'icon': 'bi-house-door', 'url': BASE_URL},
    {'slug': 'about', 'label': 'Sobre', 'icon': 'bi-info-circle', 'url': BASE_URL ~ 'about'},
    {
        'slug': 'institucional',
        'label': 'Institucional',
        'icon': 'bi-building-gear',
        'url': BASE_URL ~ 'institucional',
        'isDropdown': true,
        'items': [
            {'slug': 'institucional/missao', 'label': 'Missão', 'icon': 'bi-bullseye', 'url': BASE_URL ~ 'institucional/missao'},
            {'slug': 'institucional/valores', 'label': 'Valores', 'icon': 'bi-gem', 'url': BASE_URL ~ 'institucional/valores'},
            {'slug': 'institucional/visao', 'label': 'Visão de Futuro', 'icon': 'bi-binoculars', 'url': BASE_URL ~ 'institucional/visao'},
            {'slug': 'institucional/brasao', 'label': 'Brasão Institucional', 'icon': 'bi-shield-check', 'url': BASE_URL ~ 'institucional/brasao'},
            {'slug': 'institucional/hino', 'label': 'Hino do CBMRN', 'icon': 'bi-music-note-beamed', 'url': BASE_URL ~ 'institucional/hino'},
            {'slug': 'institucional/pac', 'label': 'PAC Cinotécnico', 'icon': 'bi-clipboard-check', 'url': BASE_URL ~ 'institucional/pac'},
            {'slug': 'institucional/links', 'label': 'Links Úteis', 'icon': 'bi-link-45deg', 'url': BASE_URL ~ 'institucional/links'}
        ]
    },
    {'slug': 'galeria', 'label': 'Galeria', 'icon': 'bi-images', 'url': BASE_URL ~ 'galeria'},
    {'slug': 'blog', 'label': 'Blog', 'icon': 'bi-newspaper', 'url': BASE_URL ~ 'blog'},
    {'slug': 'contact', 'label': 'Contato', 'icon': 'bi-envelope', 'url': BASE_URL ~ 'contact'}
] %}

<nav class="navbar navbar-expand-lg navbar-dark navbar-site shadow-sm">
    <div class="container-fluid px-4">
        <a class="navbar-brand d-flex align-items-center gap-2" href="{{ BASE_URL }}">
            {# <img src="{{ BASE_URL }}assets/images/brasao_cbmrn_oficial.png" alt="CBMRN" class="navbar-logo"> #}
            <span class="fw-bold text-white">CBMRN</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSite" aria-controls="navbarSite" aria-expanded="false" aria-label="Alternar navegação">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="navbarSite">
            <ul class="navbar-nav gap-1 align-items-lg-center">
                {% for item in navItems %}
                    {% set isDropdown = item.isDropdown|default(false) %}
                    {% set isActive = (item.slug == '' and currentRoute == '') or (item.slug != '' and currentRoute starts with item.slug) %}
                    {% if isDropdown %}
                        {% set dropdownActive = false %}
                        {% for child in item.items %}
                            {% if currentRoute starts with child.slug %}
                                {% set dropdownActive = true %}
                            {% endif %}
                        {% endfor %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle {{ dropdownActive ? 'active' : '' }}" href="{{ item.url }}" id="dropdown-{{ loop.index }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi {{ item.icon }} me-2"></i>{{ item.label }}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark shadow-lg" aria-labelledby="dropdown-{{ loop.index }}">
                                {% for child in item.items %}
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute starts with child.slug ? 'active' : '' }}" href="{{ child.url }}">
                                            <i class="bi {{ child.icon }}"></i>
                                            <div>
                                                <span class="fw-semibold">{{ child.label }}</span>
                                            </div>
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a class="nav-link {{ isActive ? 'active' : '' }}" href="{{ item.url }}">
                                <i class="bi {{ item.icon }} me-2"></i>{{ item.label }}
                            </a>
                        </li>
                    {% endif %}
                {% endfor %}
                {% if not session.user_id %}
                    <li class="nav-item">
                        <a class="nav-link text-uppercase fw-semibold" href="{{ BASE_URL }}login/admin">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Login
                        </a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm text-uppercase fw-bold" href="{{ BASE_URL }}admin">
                            <i class="bi bi-speedometer2 me-1"></i>Admin
                        </a>
                    </li>
                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-light btn-sm text-danger fw-bold" href="{{ BASE_URL }}login/logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Sair
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<style>
    .navbar-site {
        background: linear-gradient(135deg, #df6301 0%, #c55501 100%);
        min-height: 80px;
        font-family: 'Montserrat', 'Inter', Arial, sans-serif !important;
    }
    .navbar-site .navbar-logo {
        height: 46px;
        width: auto;
        filter: drop-shadow(0 3px 8px rgba(0,0,0,0.25));
    }
    .navbar-site .nav-link {
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.12em;
        color: rgba(255,255,255,0.82);
        padding: 0.65rem 1rem;
        position: relative;
        transition: color 0.2s ease;
    }
    .navbar-site .nav-link::after {
        content: '';
        position: absolute;
        left: 1rem;
        right: 1rem;
        bottom: 0.25rem;
        height: 2px;
        background: rgba(255,255,255,0.9);
        opacity: 0;
        transition: opacity 0.2s ease;
    }
    .navbar-site .nav-link.active,
    .navbar-site .nav-link:hover {
        color: #fff;
        background-color: transparent !important;
    }
    .navbar-site .nav-link.active::after,
    .navbar-site .nav-link:hover::after {
        opacity: 1;
    }
    .navbar-site .dropdown-menu {
        background: #1f1f1f;
        border: 1px solid rgba(255,255,255,0.12);
        min-width: 280px;
        padding: 0.35rem;
    }
    .navbar-site .dropdown-item {
        color: rgba(255,255,255,0.85);
        border-radius: 0.45rem;
        padding: 0.6rem 0.85rem;
        transition: background 0.2s ease, color 0.2s ease;
    }
    .navbar-site .dropdown-item i {
        color: #df6301;
    }
    .navbar-site .dropdown-item.active,
    .navbar-site .dropdown-item:hover {
        background: rgba(223,99,1,0.15);
        color: #fff;
    }
    @media (max-width: 991.98px) {
        .navbar-site .navbar-nav {
            width: 100%;
            margin-top: 1rem;
            padding: 0 0.85rem;
        }
        .navbar-site .nav-link {
            width: 100%;
            border-radius: 0.5rem;
            border: 1px solid rgba(255,255,255,0.15);
            border-left: 4px solid transparent;
            background-color: rgba(255,255,255,0.04);
        }
        .navbar-site .nav-link::after {
            display: none;
        }
        .navbar-site .nav-link.active,
        .navbar-site .nav-link:hover {
            border-left-color: rgba(255,255,255,0.85);
            background: rgba(255,255,255,0.12);
        }
        .navbar-site .dropdown-menu {
            background: transparent;
            border: none;
            padding: 0;
        }
        .navbar-site .dropdown-item {
            background: rgba(0,0,0,0.45);
            border: 1px solid rgba(255,255,255,0.08);
            margin-bottom: 0.35rem;
        }
    }
</style>
