{% set currentRoute = current_path|default('') %}
{% set isAdminOnly = session.user_role == 'admin' %}
{% set navItems = [
    {'slug': '', 'label': 'Início', 'icon': 'bi-house-door', 'url': BASE_URL},
    {'slug': 'about', 'label': 'Sobre', 'icon': 'bi-info-circle', 'url': BASE_URL ~ 'about'},
    {
        'slug': 'institucional',
        'label': 'Institucional',
        'icon': 'bi-building-gear',
        'url': BASE_URL ~ 'institucional',
        'isDropdown': true,
        'groups': [
            {
                'title': 'Essencial',
                'items': [
                    {'slug': 'institucional/missao', 'label': 'Missão', 'icon': 'bi-bullseye', 'url': BASE_URL ~ 'institucional/missao'},
                    {'slug': 'institucional/visao', 'label': 'Visão de futuro', 'icon': 'bi-binoculars', 'url': BASE_URL ~ 'institucional/visao'},
                    {'slug': 'institucional/valores', 'label': 'Valores', 'icon': 'bi-gem', 'url': BASE_URL ~ 'institucional/valores'},
                    {'slug': 'institucional/governanca', 'label': 'Governança', 'icon': 'bi-diagram-3', 'url': BASE_URL ~ 'institucional/governanca'}
                ]
            },
            {
                'title': 'Identidade',
                'items': [
                    {'slug': 'institucional/brasao', 'label': 'Selo institucional', 'icon': 'bi-shield-check', 'url': BASE_URL ~ 'institucional/brasao'},
                    {'slug': 'institucional/identidade-visual', 'label': 'Identidade visual', 'icon': 'bi-palette2', 'url': BASE_URL ~ 'institucional/identidade-visual'},
                    {'slug': 'institucional/hino', 'label': 'Hino da AORE/RN', 'icon': 'bi-music-note-beamed', 'url': BASE_URL ~ 'institucional/hino'},
                    {'slug': 'institucional/downloads-marca', 'label': 'Downloads de marca', 'icon': 'bi-download', 'url': BASE_URL ~ 'institucional/downloads-marca'}
                ]
            },
            {
                'title': 'Transparência',
                'items': [
                    {'slug': 'institucional/documentos', 'label': 'Documentos oficiais', 'icon': 'bi-file-earmark-text', 'url': BASE_URL ~ 'institucional/documentos'},
                    {'slug': 'docs', 'label': 'Documentação técnica', 'icon': 'bi-journal-text', 'url': BASE_URL ~ 'docs', 'restricted_admin': true},
                    {'slug': 'privacidade', 'label': 'Privacidade', 'icon': 'bi-shield-lock', 'url': BASE_URL ~ 'privacidade'},
                    {'slug': 'termos', 'label': 'Termos de uso', 'icon': 'bi-file-earmark-text', 'url': BASE_URL ~ 'termos'}
                ]
            },
            {
                'title': 'Acesso rápido',
                'items': [
                    {'slug': 'institucional/busca', 'label': 'Busca institucional', 'icon': 'bi-search', 'url': BASE_URL ~ 'institucional/busca'},
                    {'slug': 'institucional/links', 'label': 'Links úteis', 'icon': 'bi-link-45deg', 'url': BASE_URL ~ 'institucional/links'}
                ]
            }
        ],
        'items': [
            {'slug': 'institucional/missao', 'label': 'Missão', 'icon': 'bi-bullseye', 'url': BASE_URL ~ 'institucional/missao'},
            {'slug': 'institucional/valores', 'label': 'Valores', 'icon': 'bi-gem', 'url': BASE_URL ~ 'institucional/valores'},
            {'slug': 'institucional/visao', 'label': 'Visão de Futuro', 'icon': 'bi-binoculars', 'url': BASE_URL ~ 'institucional/visao'},
            {'slug': 'institucional/brasao', 'label': 'Selo Institucional', 'icon': 'bi-shield-check', 'url': BASE_URL ~ 'institucional/brasao'},
            {'slug': 'institucional/identidade-visual', 'label': 'Identidade Visual', 'icon': 'bi-palette2', 'url': BASE_URL ~ 'institucional/identidade-visual'},
            {'slug': 'institucional/downloads-marca', 'label': 'Downloads de Marca', 'icon': 'bi-download', 'url': BASE_URL ~ 'institucional/downloads-marca'},
            {'slug': 'institucional/hino', 'label': 'Hino da AORE/RN', 'icon': 'bi-music-note-beamed', 'url': BASE_URL ~ 'institucional/hino'},
            {'slug': 'institucional/documentos', 'label': 'Documentos Oficiais', 'icon': 'bi-file-earmark-text', 'url': BASE_URL ~ 'institucional/documentos'},
            {'slug': 'docs', 'label': 'Documentação técnica', 'icon': 'bi-journal-text', 'url': BASE_URL ~ 'docs', 'restricted_admin': true},
            {'slug': 'institucional/governanca', 'label': 'Governança', 'icon': 'bi-diagram-3', 'url': BASE_URL ~ 'institucional/governanca'},
            {'slug': 'institucional/busca', 'label': 'Busca Institucional', 'icon': 'bi-search', 'url': BASE_URL ~ 'institucional/busca'},
            {'slug': 'institucional/links', 'label': 'Links Úteis', 'icon': 'bi-link-45deg', 'url': BASE_URL ~ 'institucional/links'},
            {'slug': 'privacidade', 'label': 'Privacidade', 'icon': 'bi-shield-lock', 'url': BASE_URL ~ 'privacidade'},
            {'slug': 'termos', 'label': 'Termos de Uso', 'icon': 'bi-file-earmark-text', 'url': BASE_URL ~ 'termos'}
        ]
    },
    {'slug': 'galeria', 'label': 'Galeria', 'icon': 'bi-images', 'url': BASE_URL ~ 'galeria'},
    {'slug': 'blog', 'label': 'Blog', 'icon': 'bi-newspaper', 'url': BASE_URL ~ 'blog'},
    {'slug': 'contact', 'label': 'Contato', 'icon': 'bi-envelope', 'url': BASE_URL ~ 'contact'}
] %}

<nav class="navbar navbar-expand-lg navbar-dark navbar-site shadow-sm" data-navbar-type="public">
    <div class="container-fluid px-4 navbar-site__shell">
        <a class="navbar-brand d-flex align-items-center gap-2" href="{{ BASE_URL }}">
            <img src="{{ BASE_URL }}assets/images/aorern-medalhao-verde-aorer6-oficial-3200_1.png" alt="AORE/RN" class="navbar-logo">
            <span class="navbar-site__brand-text fw-bold text-white">AORE/RN</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSite" aria-controls="navbarSite" aria-expanded="false" aria-label="Alternar navegação">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="navbarSite">
            <ul class="navbar-nav gap-1 align-items-lg-center">
                {% for item in navItems %}
                    {% set isDropdown = item.isDropdown|default(false) %}
                    {% set isActive = (item.slug == '' and currentRoute == '') or (item.slug != '' and currentRoute starts with item.slug) %}
                    {% if isDropdown %}
                        {% set dropdownActive = false %}
                        {% for child in item.items %}
                            {% if currentRoute starts with child.slug %}
                                {% set dropdownActive = true %}
                            {% endif %}
                        {% endfor %}
                        <li class="nav-item dropdown d-none d-lg-block">
                            <a class="nav-link nav-link-dropdown {{ dropdownActive ? 'active' : '' }}" href="{{ item.url }}" id="dropdown-{{ loop.index }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="d-inline-flex align-items-center gap-2">
                                    <span><i class="bi {{ item.icon }} me-2"></i>{{ item.label }}</span>
                                    <i class="bi bi-chevron-down navbar-site__dropdown-indicator" aria-hidden="true"></i>
                                </span>
                            </a>
                            {% if item.groups is defined %}
                                <div class="dropdown-menu dropdown-menu-dark shadow-lg dropdown-menu-institucional dropdown-menu-institucional--mega p-0" aria-labelledby="dropdown-{{ loop.index }}">
                                    <div class="dropdown-mega__header">
                                        <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute == item.slug ? 'active' : '' }}" href="{{ item.url }}">
                                            <i class="bi bi-grid"></i>
                                            <span class="fw-semibold">Visão geral institucional</span>
                                        </a>
                                    </div>
                                    <div class="dropdown-mega__grid">
                                        {% for group in item.groups %}
                                            <section class="dropdown-mega__group">
                                                <h6 class="dropdown-mega__group-title">{{ group.title }}</h6>
                                                <div class="dropdown-mega__links">
                                                    {% for child in group.items %}
                                                        {% if not child.restricted_admin|default(false) or isAdminOnly %}
                                                            <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute starts with child.slug ? 'active' : '' }}" href="{{ child.url }}">
                                                                <i class="bi {{ child.icon }}"></i>
                                                                <span class="fw-semibold">{{ child.label }}</span>
                                                            </a>
                                                        {% endif %}
                                                    {% endfor %}
                                                </div>
                                            </section>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% else %}
                                <ul class="dropdown-menu dropdown-menu-dark shadow-lg dropdown-menu-institucional" aria-labelledby="dropdown-{{ loop.index }}">
                                    <li class="dropdown-item-full">
                                        <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute == item.slug ? 'active' : '' }}" href="{{ item.url }}">
                                            <i class="bi bi-grid"></i>
                                            <span class="fw-semibold">Visão geral institucional</span>
                                        </a>
                                    </li>
                                    {% for child in item.items %}
                                        {% if not child.restricted_admin|default(false) or isAdminOnly %}
                                            <li>
                                                <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute starts with child.slug ? 'active' : '' }}" href="{{ child.url }}">
                                                    <i class="bi {{ child.icon }}"></i>
                                                    <span class="fw-semibold">{{ child.label }}</span>
                                                </a>
                                            </li>
                                        {% endif %}
                                    {% endfor %}
                                </ul>
                            {% endif %}
                        </li>
                        <li class="nav-item nav-item-mobile-dropdown d-lg-none">
                            <button class="nav-link mobile-subnav-trigger collapsed {{ dropdownActive ? 'active' : '' }}" type="button" data-mobile-subnav-target="#mobile-subnav-{{ loop.index }}" aria-expanded="false" aria-controls="mobile-subnav-{{ loop.index }}">
                                <span class="mobile-subnav-trigger__content"><i class="bi {{ item.icon }} me-2"></i>{{ item.label }}</span>
                                <i class="bi bi-chevron-down mobile-subnav-trigger__icon"></i>
                            </button>
                            <div class="collapse mobile-subnav" id="mobile-subnav-{{ loop.index }}" data-mobile-subnav>
                                <ul class="list-unstyled mb-0">
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute == item.slug ? 'active' : '' }}" href="{{ item.url }}">
                                            <i class="bi bi-grid"></i>
                                            <span class="fw-semibold">Visão geral institucional</span>
                                        </a>
                                    </li>
                                    {% for child in item.items %}
                                        {% if not child.restricted_admin|default(false) or isAdminOnly %}
                                            <li>
                                                <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute starts with child.slug ? 'active' : '' }}" href="{{ child.url }}">
                                                    <i class="bi {{ child.icon }}"></i>
                                                    <span class="fw-semibold">{{ child.label }}</span>
                                                </a>
                                            </li>
                                        {% endif %}
                                    {% endfor %}
                                </ul>
                            </div>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a class="nav-link {{ isActive ? 'active' : '' }}" href="{{ item.url }}">
                                <span class="navbar-site__nav-label"><i class="bi {{ item.icon }} me-2"></i>{{ item.label }}</span>
                            </a>
                        </li>
                    {% endif %}
                {% endfor %}
                {% if not session.user_id %}
                    <li class="nav-item d-none d-lg-block">
                        <a class="nav-link text-uppercase fw-semibold" href="{{ BASE_URL }}login/admin">
                            <span class="navbar-site__nav-label"><i class="bi bi-box-arrow-in-right me-2"></i>Login</span>
                        </a>
                    </li>
                    {% set associeDropdownActive = currentRoute starts with 'register' or currentRoute starts with 'error/temporariamente-indisponivel' %}
                    <li class="nav-item dropdown d-none d-lg-block">
                        <a class="nav-link nav-link-dropdown {{ associeDropdownActive ? 'active' : '' }}" href="#" id="dropdown-associe-se" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="d-inline-flex align-items-center gap-2">
                                <span><i class="bi bi-person-plus me-2"></i>Associe-se</span>
                                <i class="bi bi-chevron-down navbar-site__dropdown-indicator" aria-hidden="true"></i>
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end navbar-site__dropdown-menu" aria-labelledby="dropdown-associe-se">
                            <li>
                                <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute starts with 'register' ? 'active' : '' }}" href="{{ BASE_URL }}register">
                                    <i class="bi bi-mortarboard"></i>
                                    <span class="fw-semibold">Sou ex-aluno do NPOR do 16º BI Mtz</span>
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute starts with 'error/temporariamente-indisponivel' ? 'active' : '' }}" href="{{ BASE_URL }}error/temporariamente-indisponivel">
                                    <i class="bi bi-envelope"></i>
                                    <span class="fw-semibold">Não sou ex-aluno de NPOR</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item nav-item-mobile-dropdown d-lg-none">
                        <button class="nav-link mobile-subnav-trigger collapsed {{ associeDropdownActive ? 'active' : '' }}" type="button" data-mobile-subnav-target="#mobile-subnav-associe-se" aria-expanded="false" aria-controls="mobile-subnav-associe-se">
                            <span class="mobile-subnav-trigger__content"><i class="bi bi-person-plus me-2"></i>Associe-se</span>
                            <i class="bi bi-chevron-down mobile-subnav-trigger__icon"></i>
                        </button>
                        <div class="collapse mobile-subnav" id="mobile-subnav-associe-se" data-mobile-subnav>
                            <ul class="list-unstyled mb-0">
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute starts with 'register' ? 'active' : '' }}" href="{{ BASE_URL }}register">
                                        <i class="bi bi-mortarboard"></i>
                                        <span class="fw-semibold">Sou ex-aluno do NPOR do 16º BI Mtz</span>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2 {{ currentRoute starts with 'error/temporariamente-indisponivel' ? 'active' : '' }}" href="{{ BASE_URL }}error/temporariamente-indisponivel">
                                        <i class="bi bi-envelope"></i>
                                        <span class="fw-semibold">Não sou ex-aluno de NPOR</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item nav-item-auth-mobile d-lg-none">
                        <a class="nav-link text-uppercase fw-semibold" href="{{ BASE_URL }}login/admin">
                            <span class="navbar-site__nav-label"><i class="bi bi-box-arrow-in-right me-2"></i>Login</span>
                        </a>
                    </li>
                {% else %}
                    {% set isAdminSession = session.user_role in ['admin', 'gerente', 'operador'] %}
                    <li class="nav-item d-none d-lg-block">
                        <a class="nav-link text-uppercase fw-semibold" href="{{ isAdminSession ? BASE_URL ~ 'admin' : BASE_URL ~ 'associado' }}">
                            <span class="navbar-site__nav-label"><i class="bi {{ isAdminSession ? 'bi-speedometer2' : 'bi-person-badge' }} me-2"></i>{{ isAdminSession ? 'Painel' : 'Área do associado' }}</span>
                        </a>
                    </li>
                    <li class="nav-item d-none d-lg-block">
                        <a class="nav-link text-uppercase fw-semibold" href="{{ BASE_URL }}login/logout">
                            <span class="navbar-site__nav-label"><i class="bi bi-box-arrow-right me-2"></i>Sair</span>
                        </a>
                    </li>
                    <li class="nav-item nav-item-auth-mobile d-lg-none">
                        <a class="btn btn-outline-light btn-sm text-uppercase fw-bold navbar-mobile-action" href="{{ isAdminSession ? BASE_URL ~ 'admin' : BASE_URL ~ 'associado' }}">
                            <i class="bi {{ isAdminSession ? 'bi-speedometer2' : 'bi-person-badge' }} me-1"></i>{{ isAdminSession ? 'Admin' : 'Associado' }}
                        </a>
                    </li>
                    <li class="nav-item nav-item-auth-mobile d-lg-none ms-lg-3">
                        <a class="btn btn-light btn-sm text-danger fw-bold navbar-mobile-action" href="{{ BASE_URL }}login/logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Sair
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>
