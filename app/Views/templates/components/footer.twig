            </div>

            <div class="col-lg-4 col-md-6">
                <h6 class="text-uppercase fw-bold mb-3 site-footer__heading">Institucional</h6>
                <ul class="list-unstyled mb-4 site-footer__links">
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}about">Sobre</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}blog">Notícias</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}contact">Contato</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}institucional">Institucional</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}institucional/identidade-visual">Identidade Visual</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}institucional/downloads-marca">Downloads de Marca</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}institucional/documentos">Documentos Oficiais</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}institucional/governanca">Governança</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}institucional/busca">Busca Institucional</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}privacidade">Política de Privacidade</a></li>
                    <li class="mb-2"><a class="text-decoration-none text-white" href="{{ BASE_URL }}termos">Termos de Uso</a></li>
                </ul>
            </div>
            

            <div class="col-lg-4 col-md-12">
                <h6 class="text-uppercase fw-bold mb-4 site-footer__heading">Contato direto</h6>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-geo-alt-fill fs-5 text-white"></i>
                    <div>
                        <p class="mb-1 fw-semibold text-white">Endereço</p>
                        <p class="mb-0 small text-white-50">{{ institutional_contact.address.line_1 }}<br>{{ institutional_contact.address.line_2 }}</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-telephone-fill fs-5 text-white"></i>
                    <div>
                        <p class="mb-1 fw-semibold text-white">Telefone</p>
                        <p class="mb-0 small text-white-50">{{ institutional_contact.phone.display }}</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-whatsapp fs-5 text-white"></i>
                    <div>
                        <p class="mb-1 fw-semibold text-white">WhatsApp</p>
                        <p class="mb-0 small text-white-50">{{ whatsapp.display }}</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-4">
                    <i class="bi bi-envelope-fill fs-5 text-white"></i>
                    <div>
                        <p class="mb-1 fw-semibold text-white">E-mail</p>
                        <p class="mb-0 small text-white-50">
                            {{ institutional_contact.emails.primary }}
                            {% if institutional_contact.emails.secondary %}
                                <br>{{ institutional_contact.emails.secondary }}
                            {% endif %}
                        </p>
                    </div>
                </div>                
            </div>
        </div>

        <hr class="border-secondary mt-4">
        <div class="text-center text-muted small">
            <p class="mb-0">&copy; {{ 'now'|date('Y') }} - AORE/RN<br>Todos os direitos reservados</p>
        </div>
    </div>
</footer>
