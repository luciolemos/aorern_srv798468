{% extends "layouts/base.twig" %}

{% block title %}Acesso negado - AORE/RN{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/error-pages.css">
{% endblock %}

{% block content %}
    <section class="error-shell">
        <div class="container">
            <div class="error-panel">
                <div class="error-panel__body">
                    <div class="row align-items-center g-4">
                        <div class="col-lg-7">
                            <div class="error-code">
                                <i class="bi bi-shield-lock-fill"></i>
                                <span>Erro 403</span>
                            </div>
                            <h1 class="error-title">Acesso restrito ao ambiente solicitado</h1>
                            <p class="error-lead">
                                A requisicao foi recebida, mas nao ha permissao suficiente para acessar este conteudo. Caso a operacao seja institucionalmente necessaria, contate o comando ou a administracao do sistema.
                            </p>
                            <div class="error-meta">
                                <div class="error-meta__item">
                                    <i class="bi bi-person-badge"></i>
                                    <span>Permissao insuficiente ou sessao sem privilegios</span>
                                </div>
                                <div class="error-meta__item">
                                    <i class="bi bi-whatsapp"></i>
                                    <span>Suporte institucional: {{ whatsapp.display }}</span>
                                </div>
                            </div>
                            <div class="error-actions">
                                {% include 'site/components/button.twig' with {
                                    href: BASE_URL,
                                    label: 'Voltar ao portal',
                                    icon: 'bi-house-door',
                                    variant: 'solid',
                                    size: 'lg',
                                    button_class: 'fw-bold'
                                } %}
                                {% include 'site/components/button.twig' with {
                                    href: BASE_URL ~ 'login/admin',
                                    label: 'Acessar login',
                                    icon: 'bi-box-arrow-in-right',
                                    variant: 'outline',
                                    size: 'lg',
                                    button_class: 'fw-bold'
                                } %}
                            </div>
                        </div>
                        <div class="col-lg-5">
                            <div class="error-visual text-center">
                                <img src="{{ BASE_URL }}assets/images/aore1.png" alt="Brasão institucional da AORE/RN" class="error-badge">
                                <p class="error-note">AORE/RN · Controle de acesso institucional</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
