{% extends "layouts/base.twig" %}

{% block title %}Sobre Nós - CBMRN{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/about.css">
{% endblock %}

{% block content %}
    <section class="about-hero site-hero">
        <div class="site-hero-pattern"></div>
        <div class="container position-relative">
            <div class="row align-items-center g-5">
                <div class="col-lg-7 hero-content">
                    <p class="section-kicker text-white-50 mb-2">Quem somos</p>
                    <h1 class="section-title text-white mb-3">2º SUBGRUPAMENTO DE BOMBEIROS MILITAR (2º SGB)</h1>
                    <p class="section-lead text-white-75 mb-4">
                        A atuação do <strong>2º SGB</strong> apoia-se em uma 
                        doutrina moderna, treinamento permanente e integração com forças parceiras, 
                        assegurando respostas rápidas e eficazes diante dos mais variados cenários de emergência.
                        Baseado em Goianinha/RN e inaugurado em setembro de 2024, o 2º SGB reforça a presença do Corpo de 
                        Bombeiros Militar do RN no Litoral Sul e Região Agreste do estado, encurtando o tempo de resposta e levando 
                        segurança especializada para 25 municípios potiguares.
                    </p>
                    <div class="d-flex flex-wrap gap-3 about-hero-actions">
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL ~ 'contact',
                            label: 'Conheça nossa atuação',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold'
                        } %}
                        {% include 'site/components/button.twig' with {
                            href: '#nossos-pilares',
                            label: 'Missão & valores',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold text-dark'
                        } %}
                    </div>
                </div>
                <div class="col-lg-5 hero-panel-col">
                    {% include 'site/components/hero-panel.twig' with {
                        eyebrow: 'Marcos recentes',
                        title: 'Nossa trajetória',
                        theme: 'light',
                        items: [
                            {
                                icon: 'bi bi-fire',
                                title: '2024 · Inauguração oficial do 2º SGB/2º GBM',
                                description: 'Estrutura moderna dedicada ao Litoral Sul e Agreste',
                                item_class: 'py-2'
                            },
                            {
                                icon: 'bi bi-geo-alt',
                                title: '25 municípios atendidos',
                                description: 'Cobertura contínua e integrada com outras forças',
                                item_class: 'py-2'
                            },
                            {
                                icon: 'bi bi-lightning-charge',
                                title: 'Operações 24/7',
                                description: 'Equipes prontas para combate a incêndio e salvamento',
                                item_class: 'py-2'
                            }
                        ]
                    } %}
                </div>
            </div>
        </div>
    </section>

    <section id="nossos-pilares" class="about-pillars py-5">
        <div class="container">
            {% include 'site/components/section-header.twig' with {
                kicker: 'Nossa essência',
                title: 'Missão, cobertura e compromisso',
                subtitle: 'Responder com rapidez, prevenir com inteligência e cuidar das pessoas.

Garantimos proteção à vida, ao patrimônio e ao meio ambiente por meio de planejamento baseado em cenários, equipes altamente treinadas e tecnologia aplicada à gestão operacional.',
                align: 'center',
                kicker_class: 'text-uppercase small text-muted mb-2',
                title_class: 'fw-bold text-primary mb-3',
                subtitle_class: 'text-muted mb-0',
                extra_class: 'mb-5'
            } %}

            {% set about_pillars = [
                {
                    icon: 'bi bi-compass',
                    title: 'Missão',
                    description: 'Proteger vidas e patrimônios por meio de operações especializadas, treinamento constante e atendimento humano à comunidade.'
                },
                {
                    icon: 'bi bi-geo-alt',
                    title: 'Cobertura geográfica',
                    description: 'Atuamos em 25 municípios do Litoral Sul e Agreste, reduzindo tempos de chegada e integrando ações com defesas civis municipais.'
                },
                {
                    icon: 'bi bi-shield-check',
                    title: 'Compromisso contínuo',
                    description: 'Operamos 24/7 com protocolos claros, frota revisada e equipes capacitadas para incêndios, salvamentos e prevenção.'
                },
                                {
                    icon: 'bi bi-fire',
                    title: 'Combate a incêndios',
                    description: 'Estruturas urbanas, áreas de vegetação e veículos recebem resposta rápida graças a protocolos digitais de despacho.'
                },
                {
                    icon: 'bi bi-life-preserver',
                    title: 'Resgate e salvamento',
                    description: 'Equipes especializadas atuam em altura, espaços confinados e ocorrências veiculares com monitoramento centralizado.'
                },
                {
                    icon: 'bi bi-mortarboard',
                    title: 'Prevenção e educação',
                    description: 'Visitas, vistorias, palestras e conteúdos digitais fortalecem a cultura de segurança nas comunidades atendidas.'
                },
                             {
                    icon: 'bi bi-life-preserver',
                    title: 'Busca em estruturas colapsadas',
                    description: 'Protocolos de varredura rápida para localizar vítimas em deslizamentos, desabamentos e áreas de difícil acesso.'
                },
                {
                    icon: 'bi bi-geo-alt',
                    title: 'Rastreamento em áreas rurais',
                    description: 'Suporte em ocorrências de pessoas desaparecidas, com foco em mata fechada e extensões do agreste.'
                },
                    {
                    icon: 'bi bi-heart',
                    title: 'Apoio psicossocial',
                    description: 'Interação com vítimas, familiares e comunidades para reduzir o trauma após grandes ocorrências.'
                }
            ] %}

            <div class="row g-4">
                {% for card in about_pillars %}
                    <div class="col-md-4">
                        {% include 'site/components/feature-card.twig' with {
                            icon: card.icon,
                            title: card.title,
                            description: card.description,
                            card_class: 'h-100 text-center shadow-sm',
                            icon_class: 'mx-auto mb-3',
                            title_class: 'h5 fw-bold mb-2',
                            description_class: 'text-muted mb-0'
                        } %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
