{% extends "layouts/base.twig" %}

{% block title %}Carteirinha Digital - AORE/RN{% endblock %}

{% block styles %}
    {{ parent() }}
    <style>
        .idcard-page-shell {
            min-height: 100vh;
            padding: 1rem 0 1.25rem;
        }

        {% if print_mode|default(false) %}
        .idcard-page-shell {
            min-height: auto;
            padding: 0.6rem 0 0.9rem;
            background: #fff;
        }

        .idcard-page-shell > .container {
            max-width: 210mm;
        }

        .idcard-stage {
            width: 85.6mm !important;
            margin-inline: auto;
        }

        .idcard-deck {
            display: block !important;
            gap: 0 !important;
        }

        .idcard-deck .idcard-panel {
            width: 85.6mm !important;
            height: 53.98mm !important;
            max-width: 85.6mm !important;
            aspect-ratio: auto !important;
            margin: 0 auto 8mm !important;
            overflow: hidden !important;
            box-sizing: border-box !important;
        }

        .idcard-deck .idcard-panel .card-header img {
            margin-inline: 0.35rem !important;
        }

        .idcard-deck .idcard-panel .idcard-header-line-1 {
            font-size: 0.62rem !important;
        }

        .idcard-deck .idcard-panel .idcard-header-line-2 {
            font-size: 0.50rem !important;
        }

        .idcard-deck .idcard-panel .idcard-header-line-3 {
            font-size: 0.46rem !important;
        }

        .idcard-deck .idcard-panel .small {
            font-size: 0.52rem !important;
            line-height: 1.12 !important;
        }

        .idcard-deck .idcard-panel .idcard-photo {
            max-width: 19mm !important;
        }

        .idcard-deck .idcard-panel .idcard-qr {
            width: 16.5mm !important;
            height: 16.5mm !important;
        }

        .idcard-deck .idcard-panel .card-header {
            padding: 2.2mm 2.4mm !important;
        }

        .idcard-deck .idcard-panel .card-footer {
            padding: 1.5mm 2.4mm !important;
            min-height: 0 !important;
        }

        .idcard-deck .idcard-panel .card-body {
            padding: 2.2mm 2.4mm !important;
            overflow: hidden !important;
        }

        /* Frente: força layout em 3 colunas fixas no formato ID-1 */
        #idcard-front .card-body > .row {
            display: grid !important;
            grid-template-columns: 19mm 1fr 16.5mm !important;
            column-gap: 1.8mm !important;
            align-items: start !important;
        }

        #idcard-front .card-body > .row > div:nth-child(1),
        #idcard-front .card-body > .row > div:nth-child(2),
        #idcard-front .card-body > .row > div:nth-child(3) {
            width: auto !important;
            max-width: none !important;
            flex: initial !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        #idcard-front .card-body > .row > div:nth-child(2) .row {
            --bs-gutter-x: 1.6mm !important;
            --bs-gutter-y: 0.8mm !important;
        }

        #idcard-front .card-body > .row > div:nth-child(2) .row > div {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(1),
        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(2),
        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(3),
        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(4),
        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(5),
        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(6),
        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(7) {
            grid-column: auto !important;
        }

        #idcard-front .card-body > .row > div:nth-child(2) .row {
            display: grid !important;
            grid-template-columns: 1fr 1fr !important;
        }

        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(1),
        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(2) {
            grid-column: 1 / -1 !important;
        }

        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(3) {
            grid-column: 1 / 2 !important;
        }

        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(4) {
            grid-column: 2 / 3 !important;
        }

        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(5),
        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(6),
        #idcard-front .card-body > .row > div:nth-child(2) .row > div:nth-child(7) {
            grid-column: 1 / -1 !important;
        }

        #idcard-front .idcard-code {
            font-size: 0.48rem !important;
            line-height: 1.05 !important;
            white-space: normal !important;
            overflow-wrap: anywhere !important;
            word-break: break-word !important;
        }

        /* Verso: densidade maior para caber tudo */
        #idcard-back .card-body .row {
            --bs-gutter-x: 1.6mm !important;
            --bs-gutter-y: 0.8mm !important;
        }

        #idcard-back .card-body .row > div {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        #idcard-back .card-body .border-top {
            margin-top: 0.6mm !important;
            padding-top: 0.8mm !important;
        }
        {% endif %}

        @media (min-width: 768px) {
            .idcard-page-shell {
                min-height: calc(100vh - var(--site-navbar-height-desktop, 80px));
                display: flex;
                align-items: center;
                padding: 1.25rem 0;
            }

            .idcard-page-shell > .container {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                width: 100%;
            }

            .idcard-stage {
                width: min(100%, 760px);
                margin-inline: auto;
            }

            .idcard-stage .idcard-toolbar {
                width: 100%;
            }
        }

        .id-card-iso {
            width: min(100%, 760px);
            aspect-ratio: 85.6 / 53.98;
            border-radius: 1rem;
            overflow: hidden;
            border: 2px solid var(--idcard-border, rgba(15, 81, 50, 0.45));
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
        }

        #idcard-front {
            position: relative;
        }

        .idcard-docline {
            position: absolute;
            top: 5.05rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 4;
            font-size: 0.74rem;
            line-height: 1;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            font-weight: 700;
            color: #1e2a23;
            white-space: nowrap;
            pointer-events: none;
        }

        .id-card-iso .card-header {
            padding: 0.65rem 1rem;
            background: #edf9f2;
            color: #1e2a23;
            border-bottom: none !important;
        }

        .id-card-iso .card-header > .d-flex {
            display: grid !important;
            grid-template-columns: 74px 1fr 66px;
            align-items: center;
            column-gap: 0.1rem;
            width: 100% !important;
        }

        .id-card-iso .card-header .px-2 {
            padding-inline: 0 !important;
        }

        .id-card-iso .card-header img {
            width: 100%;
            height: auto;
            max-height: 74px;
            object-fit: contain;
            margin-inline: 0;
        }

        .id-card-iso .card-header > .d-flex > img:first-child {
            justify-self: end;
            transform: translateX(46px);
        }

        .id-card-iso .card-header > .d-flex > img:last-child {
            justify-self: start;
            transform: translateX(-46px);
        }

        .id-card-iso .card-body {
            flex: 1 1 auto;
            overflow: hidden;
        }

        .id-card-iso.id-card-iso--front .card-body {
            display: flex;
            align-items: center;
        }

        .id-card-iso.id-card-iso--front .card-body > .row {
            width: 100%;
        }

        .id-card-iso .card-footer {
            padding: 1.2mm 2.2mm;
            min-height: 8mm;
            color: #1e2a23;
            background-color: #edf9f2 !important;
            border-top: none !important;
        }

        .id-card-iso .card-body {
            background: #edf9f2;
            color: var(--idcard-body-text, #1e2a23);
        }

        .id-card-iso .card-body strong {
            color: var(--idcard-label-text, #0f5132);
        }

        .id-card-iso .card-body .small strong {
            display: block;
            margin-bottom: 0.12rem;
            line-height: 1.08;
        }

        .idcard-field-value {
            border: 1px solid rgba(15, 81, 50, 0.28);
            border-radius: 0.45rem;
            background: rgba(255, 255, 255, 0.52);
            padding: 0.3rem 0.5rem;
            line-height: 1.15;
            min-height: 1.8em;
        }

        .idcard-signature {
            margin-top: 0.18rem;
            border: 1px dashed rgba(15, 81, 50, 0.35);
            border-radius: 0.45rem;
            background: rgba(255, 255, 255, 0.4);
            padding: 0.16rem 0.34rem;
        }

        .idcard-signature .idcard-signature-title {
            font-size: 0.58rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            font-weight: 700;
            color: #0f5132;
            margin-bottom: 0.12rem;
        }

        .idcard-signature .idcard-signature-line {
            font-size: 0.56rem;
            line-height: 1.1;
            margin-bottom: 0.06rem;
        }

        .idcard-signature .idcard-signature-line strong {
            display: inline !important;
            margin: 0 !important;
            line-height: inherit !important;
        }

        .idcard-signature .idcard-signature-line:last-child {
            margin-bottom: 0;
        }

        .idcard-field-value--code {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .id-card-iso .idcard-header-line-1 {
            font-size: 1.02rem;
            letter-spacing: 0.02em;
            line-height: 1.08;
            color: #1e2a23;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .id-card-iso .idcard-header-line-2 {
            font-size: 0.82rem;
            letter-spacing: 0.02em;
            line-height: 1.08;
            color: #1e2a23;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .id-card-iso .idcard-header-line-3 {
            font-size: 0.78rem;
            letter-spacing: 0.05em;
            line-height: 1.08;
            color: #1e2a23;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .id-card-iso .idcard-qr {
            border-color: var(--idcard-qr-border, #d7dfd9) !important;
        }

        .id-card-iso .idcard-qr-back {
            width: 122px !important;
            height: 122px !important;
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
        }

        .id-card-iso .idcard-back-qr-col {
            position: relative;
        }

        .id-card-iso .idcard-symbol-national,
        .id-card-iso .idcard-symbol-aore {
            width: 100%;
            height: auto;
            object-fit: contain;
        }

        .id-card-iso .idcard-photo {
            max-width: 220px;
            width: 100%;
            aspect-ratio: 4/5;
            object-fit: cover;
        }

        .id-card-iso .idcard-code {
            white-space: nowrap;
            font-size: 0.78rem;
            letter-spacing: 0.01em;
        }

        .idcard-fullscreen-btn {
            display: none;
        }

        .idcard-deck {
            display: grid;
            gap: 1rem;
        }

        .idcard-panel {
            margin: 0 !important;
        }

        .idcard-indicators {
            display: none;
            justify-content: center;
            align-items: center;
            gap: 0.45rem;
            margin-top: 0.7rem;
            margin-bottom: 0.1rem;
        }

        .idcard-indicator {
            appearance: none;
            -webkit-appearance: none;
            display: block;
            flex: 0 0 0.55rem;
            width: 0.55rem;
            height: 0.55rem;
            border: 0;
            border-radius: 999px;
            background: rgba(15, 81, 50, 0.24);
            padding: 0;
            line-height: 0;
            transition: transform 140ms ease, background-color 140ms ease;
        }

        .idcard-indicator.is-active {
            background: rgba(15, 81, 50, 0.78);
            transform: scale(1.15);
        }

        @media (max-width: 991.98px) {
            .id-card-iso {
                aspect-ratio: auto;
            }

            .id-card-iso .card-body {
                overflow: visible;
            }
        }

        @media (max-width: 575.98px) {
            .idcard-fullscreen-btn {
                display: inline-flex;
            }

            .idcard-docline {
                top: 4.35rem;
                font-size: 0.60rem;
                letter-spacing: 0.05em;
            }

            .id-card-iso .card-header {
                padding: 0.55rem 0.45rem;
            }

            .id-card-iso .card-header img {
                margin-inline: 0.35rem;
            }

            .id-card-iso .card-header > .d-flex > img:first-child {
                transform: translateX(28px);
            }

            .id-card-iso .card-header > .d-flex > img:last-child {
                transform: translateX(-28px);
            }

            .id-card-iso .idcard-symbol-national {
                width: 44px;
                height: 44px;
            }

            .id-card-iso .idcard-symbol-aore {
                width: 40px;
                height: 40px;
            }

            .id-card-iso .idcard-header-line-1 {
                font-size: 0.66rem;
                letter-spacing: 0.03em;
            }

            .id-card-iso .idcard-header-line-2 {
                font-size: 0.56rem;
                letter-spacing: 0.02em;
            }

            .id-card-iso .idcard-header-line-3 {
                font-size: 0.52rem;
                letter-spacing: 0.06em;
            }

            .id-card-iso .idcard-photo {
                max-width: 150px;
            }

            .id-card-iso .idcard-qr {
                width: 104px !important;
                height: 104px !important;
            }
        }

        :fullscreen .id-card-iso,
        :-webkit-full-screen .id-card-iso {
            width: min(96vw, 1200px);
        }

        :fullscreen .container,
        :-webkit-full-screen .container {
            max-width: 100% !important;
            padding-left: 0.5rem !important;
            padding-right: 0.5rem !important;
        }

        :fullscreen .idcard-page-shell,
        :-webkit-full-screen .idcard-page-shell {
            padding: 0.45rem 0 0.8rem;
        }

        :fullscreen .id-card-iso,
        :-webkit-full-screen .id-card-iso {
            width: 100%;
            max-width: 100%;
            border-radius: 0.75rem;
        }

        :fullscreen .id-card-iso .card-header img,
        :-webkit-full-screen .id-card-iso .card-header img {
            margin-inline: 0.4rem;
        }

        :fullscreen .id-card-iso .idcard-code,
        :-webkit-full-screen .id-card-iso .idcard-code {
            white-space: normal;
            overflow-wrap: anywhere;
            word-break: break-word;
        }

        @media (max-width: 767.98px) {
            .navbar-site,
            .site-footer {
                display: none !important;
            }

            body.has-public-navbar {
                padding-top: 0 !important;
            }

            body.site-body > main.flex-fill {
                padding: 0 !important;
                background: linear-gradient(180deg, #f2f5f2 0%, #ffffff 100%);
            }

            .idcard-fullscreen-btn {
                display: inline-flex;
            }

            .idcard-deck {
                display: flex;
                gap: 0.75rem;
                padding-inline: 0.75rem;
                scroll-padding-inline: 0.75rem;
                overflow-x: auto;
                overscroll-behavior-x: contain;
                scroll-snap-type: x mandatory;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: none;
            }

            .idcard-deck::-webkit-scrollbar {
                display: none;
            }

            .idcard-deck .idcard-panel {
                flex: 0 0 calc(100% - 1.5rem);
                scroll-snap-align: center;
            }

            .idcard-indicators {
                display: flex;
            }

            .id-card-iso .idcard-code {
                white-space: normal;
                overflow-wrap: anywhere;
                word-break: break-word;
            }
        }

        @media print {
            @page {
                size: A4 portrait;
                margin: 10mm;
            }

            html,
            body {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
                background: #fff !important;
            }

            .navbar-site,
            .site-footer,
            .idcard-toolbar,
            .idcard-indicators {
                display: none !important;
            }

            body.has-public-navbar {
                padding-top: 0 !important;
            }

            .idcard-page-shell {
                min-height: auto !important;
                padding: 0 !important;
            }

            .idcard-page-shell > .container {
                max-width: 760px !important;
                margin: 0 auto !important;
            }

            .idcard-stage {
                width: 100% !important;
            }

            .idcard-deck {
                display: block !important;
                overflow: visible !important;
                gap: 0 !important;
            }

            .idcard-deck .idcard-panel {
                width: 85.6mm !important;
                height: 53.98mm !important;
                max-width: 85.6mm !important;
                aspect-ratio: auto !important;
                margin: 0 auto 8mm !important;
                page-break-inside: avoid;
                break-inside: avoid;
                overflow: hidden !important;
                box-sizing: border-box !important;
            }

            .idcard-deck .idcard-panel .card-header img {
                margin-inline: 0.35rem !important;
            }

            .idcard-deck .idcard-panel .idcard-header-line-1 {
                font-size: 0.62rem !important;
            }

            .idcard-deck .idcard-panel .idcard-header-line-2 {
                font-size: 0.50rem !important;
            }

            .idcard-deck .idcard-panel .idcard-header-line-3 {
                font-size: 0.46rem !important;
            }

            .idcard-deck .idcard-panel .small {
                font-size: 0.52rem !important;
                line-height: 1.12 !important;
            }
        }
    </style>
{% endblock %}

{% block content %}
    <section class="idcard-page-shell">
        <div class="container">
            <div class="idcard-stage">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3 idcard-toolbar">
                    <a href="{{ BASE_URL }}associado" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i>Voltar para área do associado
                    </a>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-primary btn-sm idcard-fullscreen-btn d-md-none {{ print_mode|default(false) ? 'd-none' : '' }}" id="idcardFullscreenBtn">
                            <i class="bi bi-phone-landscape me-1"></i>Tela cheia
                        </button>
                        {% if print_mode|default(false) %}
                            <button type="button" class="btn btn-primary btn-sm d-none d-md-inline-flex" onclick="window.print()">
                                <i class="bi bi-printer me-1"></i>Imprimir
                            </button>
                        {% else %}
                            <a href="{{ BASE_URL }}associado/carteirinha-impressao" target="_blank" rel="noopener" class="btn btn-primary btn-sm d-none d-md-inline-flex">
                                <i class="bi bi-printer me-1"></i>Imprimir
                            </a>
                        {% endif %}
                    </div>
                </div>

                <div class="idcard-deck" id="idcardDeck" aria-label="Carteirinha digital frente e verso">
            <div class="card shadow-sm mx-auto id-card-iso id-card-iso--front idcard-panel" id="idcard-front">
                <div class="card-header">
                    <div class="d-flex align-items-center justify-content-between gap-2 text-center w-100">
                        <img src="{{ BASE_URL }}assets/images/brasaooficialcolorido.png" alt="Selo nacional" class="idcard-symbol-national">
                        <div class="lh-sm flex-grow-1 px-2">
                            <div class="fw-bold text-uppercase idcard-header-line-1">República Federativa do Brasil</div>
                            <div class="fw-semibold text-uppercase idcard-header-line-2">Associação de Oficiais da Reserva do Exército - AORE/RN</div>
                            <div class="fw-semibold text-uppercase idcard-header-line-3">Rio Grande do Norte</div>
                        </div>
                        <img src="{{ BASE_URL }}assets/images/aore1.png" alt="AORE/RN" class="idcard-symbol-aore">
                    </div>
                </div>
                <div class="idcard-docline">Carteira de Identificação de Oficial R/2</div>
                <div class="card-body p-4">
                    <div class="row g-3 align-items-center">
                        <div class="col-6 col-md-3 order-1 order-md-1 text-center align-self-start">
                            <img src="{{ avatarUrl|e('html_attr') }}" alt="{{ snapshot.nome|default('Associado')|e('html_attr') }}" class="img-fluid rounded-3 shadow-sm idcard-photo">
                        </div>
                        <div class="col-12 col-md-9 order-3 order-md-2">
                            <div class="row g-3 small">
                                <div class="col-sm-8">
                                    <strong>Nº do cartão de identificação:</strong>
                                    <div class="idcard-field-value idcard-field-value--code idcard-code">{{ card.card_code|default('-')|e }}</div>
                                </div>
                                <div class="col-sm-4">
                                    <strong>Nº de sócio:</strong>
                                    <div class="idcard-field-value">{{ snapshot.staff_id|default('-')|e }}</div>
                                </div>
                                <div class="col-sm-9">
                                    <strong>Nome:</strong>
                                    <div class="idcard-field-value">{{ snapshot.nome|default('-')|e }}</div>
                                </div>
                                <div class="col-sm-3">
                                    <strong>Posto/Grad:</strong>
                                    <div class="idcard-field-value">{{ snapshot.posto_graduacao|default('-')|e }}</div>
                                </div>
                                <div class="col-sm-6">
                                    <strong>RG:</strong>
                                    <div class="idcard-field-value">{{ snapshot.rg|default('-')|e }}</div>
                                </div>
                                <div class="col-sm-6">
                                    <strong>CPF:</strong>
                                    <div class="idcard-field-value">{{ snapshot.cpf|default('-')|e }}</div>
                                </div>
                                <div class="col-sm-4">
                                    <strong>Data nasc.:</strong>
                                    <div class="idcard-field-value">{{ snapshot.data_nascimento ? snapshot.data_nascimento|date('d/m/Y') : '-' }}</div>
                                </div>
                                <div class="col-sm-8">
                                    <strong>Naturalidade:</strong>
                                    <div class="idcard-field-value">{{ snapshot.cidade|default('-')|e }}/{{ snapshot.uf|default('-')|e }}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-center align-items-center text-center">
                    <div class="small fst-italic" style="font-size: .62rem; letter-spacing: .02em; color: rgba(30, 42, 35, 0.72);">
                        Perpetuum Officium erga Patriam
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mx-auto id-card-iso idcard-panel" id="idcard-back">
                <div class="card-body p-4">
                    <div class="row g-3 small pt-2">
                        <div class="col-sm-8">
                            <div class="row g-3">
                                <div class="col-12">
                                    <strong>Filiação (mãe):</strong>
                                    <div class="idcard-field-value">{{ snapshot.nome_mae|default('-')|e }}</div>
                                </div>
                                <div class="col-12">
                                    <strong>Filiação (pai):</strong>
                                    <div class="idcard-field-value">{{ snapshot.nome_pai|default('-')|e }}</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4 text-center d-flex align-items-start justify-content-center idcard-back-qr-col">
                            <img src="{{ qrUrl|e('html_attr') }}" alt="QR de validação da carteirinha" class="rounded border bg-white p-1 idcard-qr idcard-qr-back">
                        </div>
                        <div class="col-sm-4">
                            <strong>Nacionalidade:</strong>
                            <div class="idcard-field-value">Brasileira</div>
                        </div>
                        <div class="col-sm-4">
                            <strong>Status:</strong>
                            <div class="idcard-field-value">{{ card.status|default('inativa')|capitalize }}</div>
                        </div>
                        <div class="col-sm-8">
                            <strong>Local e data da expedição:</strong>
                            <div class="idcard-field-value">Natal/RN, {{ card.emitida_em ? card.emitida_em|date('d/m/Y') : '-' }}</div>
                        </div>
                        <div class="col-sm-4">
                            <strong>Validade:</strong>
                            <div class="idcard-field-value">{{ card.validade_ate ? card.validade_ate|date('d/m/Y') : 'Indeterminada' }}</div>
                        </div>
                        <div class="col-12 pt-0">
                            <strong>Verificação pública:</strong>
                            <div class="idcard-field-value"><a href="{{ verificationUrl|e('html_attr') }}" target="_blank" rel="noopener">{{ verificationUrl|e }}</a></div>
                            <div class="idcard-signature">
                                <div class="idcard-signature-title">Assinatura eletrônica institucional</div>
                                <div class="idcard-signature-line"><strong>Assinado por:</strong> {{ signature.signer|default('Presidente AORE/RN')|e }}</div>
                                <div class="idcard-signature-line"><strong>Data/hora:</strong> {{ signature.signed_at_label is not empty ? signature.signed_at_label|e : (card.emitida_em ? card.emitida_em|date('d/m/Y H:i') : '-') }}</div>
                                <div class="idcard-signature-line"><strong>Código de integridade:</strong> {{ signature.hash|default('-')|e }}</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-center align-items-center text-center">
                    <div class="small">
                        <div class="text-uppercase fw-semibold" style="font-size: .72rem; letter-spacing: .04em;">Válida em todo o território nacional</div>
                    </div>
                </div>
            </div>
            </div>
                <div class="idcard-indicators d-md-none" id="idcardIndicators" aria-label="Navegação frente e verso">
                    <button type="button" class="idcard-indicator is-active" data-card-index="0" aria-label="Ver frente"></button>
                    <button type="button" class="idcard-indicator" data-card-index="1" aria-label="Ver verso"></button>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block scripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const printMode = {{ print_mode|default(false) ? 'true' : 'false' }};
            const btn = document.getElementById('idcardFullscreenBtn');
            const deck = document.getElementById('idcardDeck');
            const indicators = Array.from(document.querySelectorAll('[data-card-index]'));
            const panels = deck ? Array.from(deck.querySelectorAll('.idcard-panel')) : [];
            const isMobileViewport = () => window.matchMedia('(max-width: 767.98px)').matches;
            const isLandscape = () => window.matchMedia('(orientation: landscape)').matches;

            const setActiveIndicator = (index) => {
                indicators.forEach((dot, i) => {
                    dot.classList.toggle('is-active', i === index);
                });
            };

            const scrollToPanel = (index, behavior = 'smooth') => {
                if (!deck || !panels[index]) return;
                deck.scrollTo({ left: panels[index].offsetLeft, behavior: behavior });
                setActiveIndicator(index);
            };

            const syncIndicatorWithScroll = () => {
                if (!deck || panels.length === 0) return;
                const probe = deck.scrollLeft + (deck.clientWidth / 2);
                let bestIndex = 0;
                let bestDelta = Number.POSITIVE_INFINITY;

                panels.forEach((panel, idx) => {
                    const panelCenter = panel.offsetLeft + (panel.clientWidth / 2);
                    const delta = Math.abs(panelCenter - probe);
                    if (delta < bestDelta) {
                        bestDelta = delta;
                        bestIndex = idx;
                    }
                });

                setActiveIndicator(bestIndex);
            };

            const goToBackOnLandscape = () => {
                if (!deck || !isMobileViewport() || !isLandscape()) return;
                scrollToPanel(1, 'smooth');
            };

            if (deck) {
                deck.addEventListener('scroll', syncIndicatorWithScroll, { passive: true });
            }

            indicators.forEach((dot) => {
                dot.addEventListener('click', () => {
                    const index = Number(dot.getAttribute('data-card-index') || '0');
                    scrollToPanel(index, 'smooth');
                });
            });

            window.addEventListener('orientationchange', function () {
                setTimeout(goToBackOnLandscape, 220);
            });

            window.addEventListener('resize', function () {
                if (isMobileViewport() && isLandscape()) {
                    goToBackOnLandscape();
                }
            });

            if (isMobileViewport() && isLandscape()) {
                setTimeout(goToBackOnLandscape, 120);
            }

            if (printMode) {
                setTimeout(function () {
                    window.print();
                }, 140);
            }

            const openFullscreenMode = async function () {
                const root = document.documentElement;
                const requestFs = root.requestFullscreen || root.webkitRequestFullscreen;
                if (!requestFs) {
                    alert('Não foi possível abrir em tela cheia neste dispositivo.');
                    return;
                }

                try {
                    await requestFs.call(root);
                } catch (err) {
                    alert('Não foi possível abrir em tela cheia neste dispositivo.');
                    return;
                }

                const orientation = screen.orientation;
                if (orientation && orientation.lock) {
                    try {
                        await orientation.lock('landscape');
                        setTimeout(goToBackOnLandscape, 220);
                    } catch (err) {
                        // Alguns navegadores bloqueiam lock de orientação mesmo em fullscreen.
                    }
                }
            };

            if (btn) {
                btn.addEventListener('click', openFullscreenMode);
            }
        });
    </script>
{% endblock %}
