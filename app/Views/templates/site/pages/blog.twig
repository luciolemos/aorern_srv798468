{% extends "layouts/base.twig" %}

{% block title %}Blog - CBMRN{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/blog.css">
{% endblock %}

{% block content %}
    {% set card_list = card_posts|default([]) %}
    {% set show_featured = featured_post is defined and featured_post %}
    {% set has_posts = show_featured or (card_list|length > 0) %}

    {% if has_posts %}
        {% if show_featured %}
        <section class="blog-feature-section site-hero">
            <div class="site-hero-pattern"></div>
            <div class="container position-relative">
                <div class="row justify-content-center g-5">
                    <div class="col-lg-7 hero-content">
                        {% if featured_post.capa_url %}
                            <figure class="blog-feature-cover rounded-4 overflow-hidden mb-4">
                                <img src="{{ featured_post.capa_url }}" alt="Imagem de capa de {{ featured_post.titulo }}" loading="lazy">
                            </figure>
                        {% endif %}
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                            <p class="section-kicker text-white-50 mb-0">Artigo em destaque</p>
                        </div>
                        <h1 class="section-title text-white mb-3">{{ featured_post.titulo }}</h1>
                        <p class="blog-feature-meta mb-4">
                            <span><i class="bi bi-calendar-event me-2"></i>{{ featured_post.criado_em|date('d/m/Y') }}</span>
                            {% if featured_post.autor %}
                                <span class="mx-3">•</span>
                                <span><i class="bi bi-person me-2"></i>{{ featured_post.autor }}</span>
                            {% endif %}
                            <span class="mx-3">•</span>
                            {% if featured_post.categoria_nome %}
                                {% set categoriaCor = featured_post.categoria_cor|default('#df6301') %}
                                <span class="blog-category-badge blog-category-badge-hero" style="background-color: {{ categoriaCor }}; border-color: {{ categoriaCor }}; color: #fff;">
                                    {{ featured_post.categoria_nome }}
                                </span>
                            {% endif %}
                        </p>
                        <p class="section-lead text-white-75 mb-4">{{ featured_post.conteudo|first_paragraph(260) }}</p>
                        <div class="d-flex flex-wrap gap-3 blog-feature-actions">
                            {% include 'site/components/button.twig' with {
                                href: BASE_URL ~ 'blog/' ~ featured_post.slug,
                                label: 'Ler matéria completa',
                                icon: 'bi-arrow-right',
                                icon_position: 'end',
                                variant: 'solid',
                                size: 'lg',
                                button_class: 'fw-bold',
                                attrs: {
                                    'aria-label': 'Ler matéria completa: ' ~ featured_post.titulo
                                }
                            } %}
                            {% include 'site/components/button.twig' with {
                                href: '#ultimos-posts',
                                label: 'Ver mais artigos',
                                icon: 'bi-list-columns-reverse',
                                icon_position: 'end',
                                variant: 'solid',
                                size: 'lg',
                                button_class: 'fw-bold',
                                attrs: { 'aria-label': 'Ver mais artigos no blog' }
                            } %}
                        </div>
                    </div>
                    <div class="col-lg-5 hero-panel-col">
                        {% set feature_items = [] %}
                        {% for post in hero_recent_posts|default([]) %}
                            {% set feature_items = feature_items|merge([
                                {
                                    title: post.titulo,
                                    meta: post.criado_em|date('d/m/Y'),
                                    dot: true,
                                    item_class: 'py-2'
                                }
                            ]) %}
                        {% endfor %}

                        {% include 'site/components/hero-panel.twig' with {
                            badge: '<i class="bi bi-journal-text me-1 text-primary"></i> Últimas publicações',
                            theme: 'light',
                            list_class: 'mb-0',
                            items: feature_items
                        } %}
                    </div>
                </div>
            </div>
        </section>
        {% endif %}

        <section id="ultimos-posts" class="blog-list-section py-5">
            <div class="container-xxl">
                {% include 'site/components/section-header.twig' with {
                    kicker: 'Novidades e artigos',
                    title: 'Últimas publicações',
                    subtitle: 'Conteúdos recentes, operações e bastidores do Corpo de Bombeiros Militar do Rio Grande do Norte.',
                    align: 'center',
                    kicker_class: 'text-muted',
                    title_class: 'text-primary',
                    subtitle_class: 'blog-page-subtitle text-muted',
                    extra_class: 'mb-5'
                } %}

                {% set hasSearch = filters.q|default('')|trim != '' %}
                {% set hasCategory = filters.categoria|default(null) is not empty %}
                {% set filtersActive = hasSearch or hasCategory %}

                <div class="blog-filters-wrapper mb-5">
                    <form action="{{ BASE_URL }}blog" method="get" class="blog-filters row gy-3 gx-4 align-items-end">
                        <div class="col-12 col-md-5 col-lg-5 col-xl-6">
                            <label for="blog-search" class="form-label text-muted text-uppercase small fw-semibold">Buscar no blog</label>
                            <input type="search" id="blog-search" name="q" value="{{ filters.q|default('') }}" class="form-control" placeholder="Digite palavras-chave"
                                   aria-label="Buscar artigos" />
                        </div>
                        <div class="col-12 col-md-4 col-lg-4 col-xl-3">
                            <label for="blog-category" class="form-label text-muted text-uppercase small fw-semibold">Categoria</label>
                            <select id="blog-category" name="categoria" class="form-select" aria-label="Filtrar por categoria">
                                <option value="">Todas as categorias</option>
                                {% for category in categories %}
                                    <option value="{{ category.id }}" {% if filters.categoria|default(null) == category.id %}selected{% endif %}>{{ category.nome }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-12 col-md-3 col-lg-3 col-xl-3 blog-filters-actions">
                            {% include 'site/components/button.twig' with {
                                label: 'Aplicar filtros',
                                variant: 'solid',
                                size: 'md',
                                type: 'submit',
                                button_class: 'fw-semibold px-4'
                            } %}
                            {% if filtersActive %}
                                {% include 'site/components/button.twig' with {
                                    href: BASE_URL ~ 'blog',
                                    label: 'Limpar',
                                    variant: 'neutral-outline',
                                    size: 'md',
                                    button_class: 'fw-semibold px-4'
                                } %}
                            {% endif %}
                        </div>
                    </form>
                </div>

                {% if card_list|length > 0 %}
                    <div class="row g-4">
                        {% for post in card_list %}
                            <div class="col-md-6 col-xl-4">
                                {% include 'site/components/post-card.twig' with {
                                    cover_url: post.capa_url,
                                    cover_alt: 'Imagem de capa de ' ~ post.titulo,
                                    badge_label: 'Artigo',
                                    category_name: post.categoria_nome,
                                    category_color: post.categoria_cor|default('#df6301'),
                                    title: post.titulo,
                                    meta_date: post.criado_em|date('d/m/Y'),
                                    meta_author: post.autor,
                                    excerpt: post.conteudo|first_paragraph(160),
                                    url: BASE_URL ~ 'blog/' ~ post.slug,
                                    cta_aria: 'Ler mais sobre ' ~ post.titulo,
                                    card_class: 'h-100 shadow-sm'
                                } %}
                            </div>
                        {% endfor %}
                    </div>
                    {% if pagination.last_page|default(1) > 1 %}
                        {% set currentPage = pagination.current_page|default(1) %}
                        {% set totalPages = pagination.last_page|default(1) %}
                        {% set windowSize = 5 %}
                        {% set halfWindow = 2 %}
                        {% set startPage = currentPage - halfWindow %}
                        {% if startPage < 1 %}
                            {% set startPage = 1 %}
                        {% endif %}
                        {% set endPage = startPage + windowSize - 1 %}
                        {% if endPage > totalPages %}
                            {% set endPage = totalPages %}
                            {% set startPage = totalPages - windowSize + 1 %}
                            {% if startPage < 1 %}
                                {% set startPage = 1 %}
                            {% endif %}
                        {% endif %}
                        {% set queryPrefix = baseQueryString ? baseQueryString ~ '&' : '' %}

                        <nav class="blog-pagination mt-5" aria-label="Paginação de artigos">
                            <ul class="pagination justify-content-center">
                                <li class="page-item {% if not pagination.has_prev %}disabled{% endif %}">
                                    {% if pagination.has_prev %}
                                        <a class="page-link" href="{{ BASE_URL }}blog?{{ queryPrefix }}page={{ currentPage - 1 }}" aria-label="Página anterior">&laquo;</a>
                                    {% else %}
                                        <span class="page-link" aria-hidden="true">&laquo;</span>
                                    {% endif %}
                                </li>

                                {% for pageNumber in startPage..endPage %}
                                    <li class="page-item {% if pageNumber == currentPage %}active{% endif %}">
                                        {% if pageNumber == currentPage %}
                                            <span class="page-link">{{ pageNumber }}</span>
                                        {% else %}
                                            <a class="page-link" href="{{ BASE_URL }}blog?{{ queryPrefix }}page={{ pageNumber }}">
                                                {{ pageNumber }}
                                            </a>
                                        {% endif %}
                                    </li>
                                {% endfor %}

                                <li class="page-item {% if not pagination.has_next %}disabled{% endif %}">
                                    {% if pagination.has_next %}
                                        <a class="page-link" href="{{ BASE_URL }}blog?{{ queryPrefix }}page={{ currentPage + 1 }}" aria-label="Próxima página">&raquo;</a>
                                    {% else %}
                                        <span class="page-link" aria-hidden="true">&raquo;</span>
                                    {% endif %}
                                </li>
                            </ul>
                        </nav>
                    {% endif %}
                {% else %}
                    <div class="alert alert-info blog-empty-state">
                        <i class="bi bi-info-circle me-2"></i> Publique mais artigos para preencher os cards inferiores.
                    </div>
                {% endif %}
            </div>
        </section>
    {% else %}
        <div class="container py-5">
            <div class="alert alert-info blog-empty-state">
                <i class="bi bi-info-circle me-2"></i> Nenhum post publicado ainda. Volte em breve!
            </div>
            <div class="blog-filters-wrapper mt-4">
                <form action="{{ BASE_URL }}blog" method="get" class="blog-filters row g-3 align-items-end">
                    <div class="col-12 col-md-6 col-lg-6">
                        <label for="blog-search-empty" class="form-label text-muted text-uppercase small fw-semibold">Buscar no blog</label>
                        <input type="search" id="blog-search-empty" name="q" value="{{ filters.q|default('') }}" class="form-control" placeholder="Digite palavras-chave"
                               aria-label="Buscar artigos" />
                    </div>
                    <div class="col-12 col-md-4 col-lg-4">
                        <label for="blog-category-empty" class="form-label text-muted text-uppercase small fw-semibold">Categoria</label>
                        <select id="blog-category-empty" name="categoria" class="form-select" aria-label="Filtrar por categoria">
                            <option value="">Todas as categorias</option>
                            {% for category in categories %}
                                <option value="{{ category.id }}" {% if filters.categoria|default(null) == category.id %}selected{% endif %}>{{ category.nome }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-12 col-md-2 col-lg-2 d-flex flex-column flex-md-row gap-2 justify-content-md-end">
                        {% include 'site/components/button.twig' with {
                            label: 'Aplicar filtros',
                            variant: 'solid',
                            size: 'lg',
                            type: 'submit',
                            button_class: 'fw-bold w-100 w-md-auto'
                        } %}
                        {% if filters.q|default('') or filters.categoria|default(null) %}
                            {% include 'site/components/button.twig' with {
                                href: BASE_URL ~ 'blog',
                                label: 'Limpar',
                                variant: 'neutral-outline',
                                size: 'lg',
                                button_class: 'fw-bold w-100 w-md-auto'
                            } %}
                        {% endif %}
                    </div>
                </form>
            </div>
        </div>
    {% endif %}
{% endblock %}
