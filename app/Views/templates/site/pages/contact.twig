{% set whatsappChannels = [
    {
        label: 'Contato geral',
        icon: 'bi bi-chat-dots-fill',
        href: whatsapp.links.general,
        description: 'Canal inicial para duvidas gerais, orientacoes e atendimento institucional.'
    },
    {
        label: 'Agenda institucional',
        icon: 'bi bi-building-check',
        href: whatsapp.links.technical_visit,
        description: 'Solicitacoes de reunioes, convites, visitas institucionais e alinhamentos formais.'
    },
    {
        label: 'Imprensa',
        icon: 'bi bi-megaphone-fill',
        href: whatsapp.links.press,
        description: 'Demandas jornalisticas, entrevistas, notas oficiais e confirmacao de informacoes.'
    },
    {
        label: 'Eventos e participacao',
        icon: 'bi bi-calendar-event',
        href: whatsapp.links.prevention,
