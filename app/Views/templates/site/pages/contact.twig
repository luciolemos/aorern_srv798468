{% extends "layouts/base.twig" %}

{% block title %}Contato - CBMRN{% endblock %}
{% set whatsappChannels = [
    {
        label: 'Emergencia',
        icon: 'bi bi-exclamation-triangle-fill',
        href: whatsapp.links.emergency,
        description: 'Contato inicial para ocorrencias com necessidade de resposta imediata.'
    },
    {
        label: 'Visita tecnica',
        icon: 'bi bi-building-check',
        href: whatsapp.links.technical_visit,
        description: 'Solicitacoes de agenda institucional, vistoria orientativa e apoio tecnico.'
    },
    {
        label: 'Imprensa',
        icon: 'bi bi-megaphone-fill',
        href: whatsapp.links.press,
        description: 'Demandas jornalisticas, entrevistas, notas e confirmacao de informacoes.'
    },
    {
        label: 'Orientacao preventiva',
        icon: 'bi bi-shield-check',
        href: whatsapp.links.prevention,
        description: 'Duvidas sobre prevencao, seguranca e boas praticas para a comunidade.'
    }
] %}

{% block styles %}
    {{ parent() }}
        <link rel="stylesheet" href="{{ BASE_URL }}assets/css/contact.css">
        <script src="https://www.google.com/recaptcha/api.js" async defer></script>
        <style>
            .contact-social {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
                gap: 0.5rem;
            }
            .contact-social__link {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 0.35rem;
                padding: 0.5rem 0.9rem;
                border-radius: 999px;
                border: 1px solid rgba(0, 0, 0, 0.08);
                font-size: 0.85rem;
                font-weight: 600;
                color: #0f172a;
                text-decoration: none;
                transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
            }
            .contact-social__link i {
                font-size: 1rem;
            }
            .contact-social__link:hover {
                transform: translateY(-2px);
                border-color: rgba(15, 23, 42, 0.25);
                box-shadow: 0 8px 16px rgba(15, 23, 42, 0.12);
            }
            .contact-social__link[data-network="github"] { background: linear-gradient(120deg, rgba(15,23,42,0.08), rgba(15,23,42,0.02)); }
            .contact-social__link[data-network="linkedin"] { background: linear-gradient(120deg, rgba(10,102,194,0.15), rgba(10,102,194,0.05)); }
            .contact-social__link[data-network="twitter"] { background: linear-gradient(120deg, rgba(29,155,240,0.18), rgba(29,155,240,0.05)); }
            .contact-social__link[data-network="instagram"] { background: linear-gradient(120deg, rgba(225,48,108,0.2), rgba(255,196,0,0.12)); }
            .contact-social__link[data-network="facebook"] { background: linear-gradient(120deg, rgba(59,89,152,0.18), rgba(59,89,152,0.05)); }
            .contact-social__link[data-network="whatsapp"] { background: linear-gradient(120deg, rgba(37,211,102,0.2), rgba(7,94,84,0.08)); }
            .contact-whatsapp-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 0.85rem;
            }
            .contact-whatsapp-card {
                display: block;
                padding: 1rem 1.1rem;
                border-radius: 1rem;
                border: 1px solid rgba(15, 23, 42, 0.08);
                background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(243,244,246,0.92));
                color: #0f172a;
                text-decoration: none;
                box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
                transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
            }
            .contact-whatsapp-card:hover {
                transform: translateY(-2px);
                border-color: rgba(37, 211, 102, 0.35);
                box-shadow: 0 16px 28px rgba(15, 23, 42, 0.12);
            }
            .contact-whatsapp-card__icon {
                width: 2.6rem;
                height: 2.6rem;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: linear-gradient(135deg, rgba(37,211,102,0.18), rgba(7,94,84,0.12));
                color: #128c7e;
                margin-bottom: 0.75rem;
            }
            .contact-whatsapp-card__title {
                font-size: 0.98rem;
                font-weight: 700;
                margin-bottom: 0.35rem;
            }
            .contact-whatsapp-card__description {
                font-size: 0.86rem;
                color: #475569;
                margin-bottom: 0;
            }
        </style>
{% endblock %}

{% block content %}
    <section class="contact-hero site-hero">
        <div class="site-hero-pattern"></div>
        <div class="container position-relative">
                 <div class="row justify-content-center g-5">
                    <div class="col-lg-7 hero-content">
                    <p class="section-kicker text-white-50 mb-2">Fale conosco</p>
                    <h1 class="section-title text-white mb-3">Utilize este canal para contato institucional</h1>
                    <p class="section-lead text-white-75 mb-4">O 2º Subgrupamento de Bombeiros Militar atua de forma ininterrupta (24/7), com base em protocolos operacionais claros, integração com demais forças de segurança e uso de tecnologia, visando à redução do tempo de resposta e à ampliação da segurança da população. Este canal está disponível para atendimento a demandas institucionais, solicitações de imprensa, visitas técnicas e orientações preventivas à sociedade.</p>
                    <div class="d-flex flex-wrap gap-3">
                        {% include 'site/components/button.twig' with {
                            href: institutional_contact.emergency.tel,
                            label: 'Ligue ' ~ institutional_contact.emergency.display,
                            icon: 'bi-telephone',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold'
                        } %}
                        {% include 'site/components/button.twig' with {
                            href: '#contato-direto',
                            label: 'Ver contatos diretos',
                            icon: 'bi-envelope',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold'  
                        } %}
                    </div>
                </div>
                    <div class="col-lg-5 hero-panel-col">
                    {% include 'site/components/hero-panel.twig' with {
                        eyebrow: 'Atendimento',
                        title: 'Canais principais',
                        theme: 'light',
                        items: [
                            {
                                icon: 'bi bi-geo-alt-fill',
                                icon_inner_class: 'text-primary fs-5',
                                title: institutional_contact.address.line_1,
                                meta: institutional_contact.address.line_2,
                                item_class: 'py-2'
                            },
                            {
                                icon: 'bi bi-whatsapp',
                                icon_inner_class: 'text-success fs-5',
                                title: whatsapp.display,
                                meta: 'WhatsApp institucional',
                                item_class: 'py-2'
                            },
                            {
                                icon: 'bi bi-envelope-fill',
                                icon_inner_class: 'text-danger fs-5',
                                title: institutional_contact.emails.primary,
                                description_html: '<small class="text-white-50">' ~ institutional_contact.emails.secondary ~ '</small>',
                                item_class: 'py-2'
                            }
                        ]
                    } %}
                </div>
            </div>
        </div>
    </section>

    <section class="contact-body py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-8">
                    {% set contact_summary_cards = [
                        {
                            icon: 'bi bi-fire',
                            title: 'Emergências',
                            description: 'Apenas pelo 193 – disponibilidade 24/7.'
                        },
                        {
                            icon: 'bi bi-people',
                            title: 'Visitas e imprensa',
                            description: 'Agendamentos via formulário ou email.'
                        },
                        {
                            icon: 'bi bi-chat-dots',
                            title: 'Dúvidas gerais',
                            description: 'Respondemos em até 2 dias úteis.'
                        }
                    ] %}
                    <div class="row g-3 mb-4 contact-summary">
                        {% for card in contact_summary_cards %}
                            <div class="col-sm-4">
                                {% include 'site/components/feature-card.twig' with {
                                    icon: card.icon,
                                    title: card.title,
                                    description: card.description,
                                    card_class: 'h-100',
                                    icon_class: 'text-primary'
                                } %}
                            </div>
                        {% endfor %}
                    </div>

                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body p-4">
                            <h2 class="section-title h5 fw-bold mb-2">Atendimento por WhatsApp</h2>
                            <p class="text-muted small mb-4">Selecione o assunto para abrir uma mensagem institucional predefinida e agilizar o encaminhamento adequado.</p>
                            <div class="contact-whatsapp-grid">
                                {% for channel in whatsappChannels %}
                                    <a href="{{ channel.href }}" class="contact-whatsapp-card" target="_blank" rel="noopener noreferrer">
                                        <span class="contact-whatsapp-card__icon">
                                            <i class="{{ channel.icon }}"></i>
                                        </span>
                                        <p class="contact-whatsapp-card__title">{{ channel.label }}</p>
                                        <p class="contact-whatsapp-card__description">{{ channel.description }}</p>
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="contact-form-panel auth-card hero-panel hero-panel--dark">
                        <div class="text-center mb-4">
                            <p class="hero-panel-badge text-white-75"><i class="bi bi-chat-left-text me-2"></i>Envie sua mensagem</p>
                            <h2 class="h4 fw-bold text-white mb-1">Central de atendimento</h2>
                            <p class="text-white-50 small mb-0">Responderemos em até 48h úteis.</p>
                        </div>
                        <form method="POST" class="row g-3 auth-form">
                            <div class="col-md-6">
                                <label for="nome" class="form-label text-white">Nome</label>
                                <input type="text" class="form-control form-control-lg" id="nome" name="nome" required>
                            </div>
                            <div class="col-md-6">
                                <label for="email" class="form-label text-white">Email</label>
                                <input type="email" class="form-control form-control-lg" id="email" name="email" required>
                            </div>
                            <div class="col-12">
                                <label for="mensagem" class="form-label text-white">Mensagem</label>
                                <textarea class="form-control form-control-lg" id="mensagem" name="mensagem" rows="5" required></textarea>
                            </div>
                            <div class="col-12">
                                <div class="g-recaptcha" data-sitekey="6Lf07DwrAAAAAFgUI7kHx81lmTMzKNcggy_S7sgL"></div>
                            </div>
                            <div class="col-12">
                                {% include 'site/components/button.twig' with {
                                    label: 'Enviar mensagem',
                                    icon: 'bi-send',
                                    variant: 'solid',
                                    size: 'lg',
                                    type: 'submit',
                                    button_class: 'w-100 fw-bold'
                                } %}
                            </div>
                        </form>
                    </div>
                </div>
                <div class="col-lg-4" id="contato-direto">
                    <aside class="contact-direct card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <h2 class="section-title h5 fw-bold mb-4">Contato direto</h2>
                            <div class="d-flex align-items-start gap-3 mb-4">
                                <i class="bi bi-geo-alt-fill contact-direct-icon text-primary"></i>
                                <div>
                                    <h3 class="h6 fw-semibold mb-1">Endereço</h3>
                                    <p class="mb-0 small text-muted">{{ institutional_contact.address.line_1 }}<br>{{ institutional_contact.address.line_2 }}</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-start gap-3 mb-4">
                                <i class="bi bi-telephone-fill contact-direct-icon text-success"></i>
                                <div>
                                    <h3 class="h6 fw-semibold mb-1">Telefone</h3>
                                    <p class="mb-0 small">{{ institutional_contact.phone.display }}</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-start gap-3 mb-4">
                                <i class="bi bi-whatsapp contact-direct-icon text-success"></i>
                                <div>
                                    <h3 class="h6 fw-semibold mb-1">WhatsApp</h3>
                                    <p class="mb-0 small">{{ whatsapp.display }}</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-start gap-3 mb-4">
                                <i class="bi bi-envelope-fill contact-direct-icon text-danger"></i>
                                <div>
                                    <h3 class="h6 fw-semibold mb-1">E-mail</h3>
                                    <p class="mb-0 small">{{ institutional_contact.emails.primary }}<br>{{ institutional_contact.emails.secondary }}</p>
                                </div>
                            </div>
                            <hr class="my-4">
                            <div>
                                <h3 class="h6 fw-semibold mb-3">Redes sociais</h3>
                                <div class="contact-social">
                                    <a href="https://github.com/luciolemos/cbmrn_srv798468" class="contact-social__link" data-network="github" target="_blank" title="GitHub">
                                        <i class="bi bi-github"></i>
                                        <span>GitHub</span>
                                    </a>
                                    <a href="https://www.linkedin.com/in/lucciolemos/" class="contact-social__link" data-network="linkedin" target="_blank" title="LinkedIn">
                                        <i class="bi bi-linkedin"></i>
                                        <span>LinkedIn</span>
                                    </a>
                                    <a href="https://x.com/lucciolemos" class="contact-social__link" data-network="twitter" target="_blank" title="Twitter / X">
                                        <i class="bi bi-twitter"></i>
                                        <span>X</span>
                                    </a>
                                    <a href="https://x.com/lucciolemos" class="contact-social__link" data-network="instagram" target="_blank" title="Instagram">
                                        <i class="bi bi-instagram"></i>
                                        <span>Instagram</span>
                                    </a>
                                    <a href="https://www.facebook.com/lucciolemos" class="contact-social__link" data-network="facebook" target="_blank" title="Facebook">
                                        <i class="bi bi-facebook"></i>
                                        <span>Facebook</span>
                                    </a>
                                    <a href="{{ whatsappChannels[3].href }}" class="contact-social__link" data-network="whatsapp" target="_blank" title="WhatsApp">
                                        <i class="bi bi-whatsapp"></i>
                                        <span>WhatsApp</span>
                                    </a>
                                </div>
                               {#  <div class="d-flex gap-2">
                                    {% include 'site/components/button.twig' with {
                                        href: 'https://github.com/luciolemos/cbmrn_srv798468',
                                        label: 'GitHub',
                                        label_hidden: true,
                                        icon: 'bi-github',
                                        icon_class: 'text-dark',
                                        variant: 'outline',
                                        size: 'sm',
                                        button_class: 'btn-icon-only',
                                        target: '_blank',
                                        attrs: {'title': 'GitHub'}
                                    } %}
                                    {% include 'site/components/button.twig' with {
                                        href: 'https://www.linkedin.com/in/lucciolemos/',
                                        label: 'LinkedIn',
                                        label_hidden: true,
                                        icon: 'bi-linkedin',
                                        icon_class: 'text-primary',
                                        variant: 'outline',
                                        size: 'sm',
                                        button_class: 'btn-icon-only',
                                        target: '_blank',
                                        attrs: {'title': 'LinkedIn'}
                                    } %}
                                    {% include 'site/components/button.twig' with {
                                        href: 'https://x.com/lucciolemos',
                                        label: 'Twitter',
                                        label_hidden: true,
                                        icon: 'bi-twitter',
                                        icon_class: 'text-primary',
                                        variant: 'outline',
                                        size: 'sm',
                                        button_class: 'btn-icon-only',
                                        target: '_blank',
                                        attrs: {'title': 'Twitter'}
                                    } %}
                                </div> #}
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-map py-5">
        <div class="container">
            {% include 'site/components/section-header.twig' with {
                title: 'Nossa localização',
                align: 'center',
                heading_level: 2,
                extra_class: 'mb-3'
            } %}
            <div class="ratio ratio-21x9 rounded overflow-hidden shadow-sm">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d935.4089977755553!2d-35.21094443955298!3d-6.270164616892321!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x7b287007fdbe0f7%3A0xc0a709485b5e7305!2scorpo%20de%20bombeiros%20militar%202%2F2%20GBM!5e1!3m2!1spt-BR!2sbr!4v1764530435730!5m2!1spt-BR!2sbr" width="600" height="450" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </section>
{% endblock %}
