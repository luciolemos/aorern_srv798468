{% block styles %}
    {{ parent() }}
        <link rel="stylesheet" href="{{ BASE_URL }}assets/css/contact.css?v=20260304-panel2">
        <script src="https://www.google.com/recaptcha/api.js" async defer></script>
        <style>
            .contact-social {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
                gap: 0.5rem;
            }
            .contact-social__link {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 0.35rem;
                padding: 0.5rem 0.9rem;
                border-radius: 999px;
                border: 1px solid rgba(0, 0, 0, 0.08);
                font-size: 0.85rem;
                font-weight: 600;
                color: #0f172a;
                text-decoration: none;
                transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
            }
            .contact-social__link i {
                font-size: 1rem;
            }
            .contact-social__link:hover {
                transform: translateY(-2px);
                border-color: rgba(15, 23, 42, 0.25);
                box-shadow: 0 8px 16px rgba(15, 23, 42, 0.12);
            }
            .contact-social__link[data-network="github"] { background: linear-gradient(120deg, rgba(15,23,42,0.08), rgba(15,23,42,0.02)); }
            .contact-social__link[data-network="linkedin"] { background: linear-gradient(120deg, rgba(10,102,194,0.15), rgba(10,102,194,0.05)); }
            .contact-social__link[data-network="twitter"] { background: linear-gradient(120deg, rgba(29,155,240,0.18), rgba(29,155,240,0.05)); }
            .contact-social__link[data-network="instagram"] { background: linear-gradient(120deg, rgba(225,48,108,0.2), rgba(255,196,0,0.12)); }
            .contact-social__link[data-network="facebook"] { background: linear-gradient(120deg, rgba(59,89,152,0.18), rgba(59,89,152,0.05)); }
            .contact-social__link[data-network="whatsapp"] { background: linear-gradient(120deg, rgba(37,211,102,0.2), rgba(7,94,84,0.08)); }
            .contact-whatsapp-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 0.85rem;
            }
            .contact-whatsapp-card {
                display: block;
                padding: 1rem 1.1rem;
                border-radius: 1rem;
                border: 1px solid rgba(15, 23, 42, 0.08);
                background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(243,244,246,0.92));
                color: #0f172a;
                text-decoration: none;
                box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
                transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
            }
            .contact-whatsapp-card:hover {
                transform: translateY(-2px);
                border-color: rgba(37, 211, 102, 0.35);
                box-shadow: 0 16px 28px rgba(15, 23, 42, 0.12);
            }
            .contact-whatsapp-card__icon {
                width: 2.6rem;
                height: 2.6rem;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: linear-gradient(135deg, rgba(37,211,102,0.18), rgba(7,94,84,0.12));
                color: #128c7e;
                margin-bottom: 0.75rem;
            }
            .contact-whatsapp-card__title {
                font-size: 0.98rem;
                font-weight: 700;
                margin-bottom: 0.35rem;
            }
            .contact-whatsapp-card__description {
                font-size: 0.86rem;
                color: #475569;
                margin-bottom: 0;
            }
        </style>
{% endblock %}

{% block scripts %}
    {{ parent() }}
    <script>
        (function () {
            var BASE_WIDTH = 304;
            var BASE_HEIGHT = 78;

            function applyRecaptchaWidth() {
                var wrappers = document.querySelectorAll('.recaptcha-wrap .g-recaptcha');
                wrappers.forEach(function (captcha) {
                    var host = captcha.parentElement;
                    var inner = captcha.firstElementChild;
                    if (!host || !inner) {
                        return;
                    }

                    var availableWidth = host.clientWidth;
                    if (!availableWidth) {
                        return;
                    }

                    var scale = Math.min(1, availableWidth / BASE_WIDTH);
                    inner.style.transformOrigin = 'center top';
                    inner.style.transform = 'scale(' + scale + ')';

                    captcha.style.width = BASE_WIDTH + 'px';
                    captcha.style.height = (BASE_HEIGHT * scale) + 'px';
                    host.style.minHeight = (BASE_HEIGHT * scale) + 'px';
                });
            }

            function waitAndApply(attempt) {
                var rendered = document.querySelector('.recaptcha-wrap .g-recaptcha > div');
                applyRecaptchaWidth();
                if (!rendered && attempt < 30) {
                    window.setTimeout(function () {
                        waitAndApply(attempt + 1);
                    }, 200);
                }
            }

            document.addEventListener('DOMContentLoaded', function () {
                waitAndApply(0);
                window.addEventListener('resize', applyRecaptchaWidth);
            });
        })();
    </script>
{% endblock %}

{% block content %}
    <section class="contact-hero site-hero hero-form-layout">
        <div class="site-hero-pattern d-none d-lg-block"></div>
        <div class="container position-relative">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6 hero-content">
                    <p class="section-kicker text-white-50 mb-2">Fale conosco</p>
                    <h1 class="section-title text-white mb-3">Utilize este canal para contato institucional</h1>
                    <p class="section-lead text-white-75 mb-4">Este canal foi organizado para atender demandas institucionais da AORE/RN, incluindo informações gerais, comunicação com associados, solicitações de agenda, assuntos de imprensa e temas relacionados a eventos e atividades da associação.</p>
                    <div class="d-flex flex-wrap gap-3">
                        {% include 'site/components/button.twig' with {
                            href: whatsapp.links.general,
                            label: 'WhatsApp',
                            icon: 'bi-whatsapp',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold',
                            target: '_blank'
                        } %}
                        {% include 'site/components/button.twig' with {
                            href: '#contato-direto',
                            label: 'Ver contatos diretos',
                            icon: 'bi-envelope',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold'  
                        } %}
                    </div>
                </div>
                    <div class="col-lg-5 ms-lg-auto hero-panel-col">
                        <div class="contact-form-panel auth-card auth-card--light hero-panel hero-panel--light">
                            <div class="text-start mb-3">
                                <p class="hero-panel-badge text-white-75"><i class="bi bi-chat-left-text me-2"></i>Envie sua mensagem</p>
                            </div>
                            {% if contact_status.ok %}
                                <div class="alert alert-success border-0 shadow-sm" role="alert">
                                    Mensagem enviada com sucesso. Verifique a caixa de entrada configurada para o teste.
                                </div>
                            {% elseif contact_status.error == 'recaptcha' %}
                                <div class="alert alert-warning border-0 shadow-sm" role="alert">
                                    Confirme o reCAPTCHA para enviar a mensagem.
                                </div>
                            {% elseif contact_status.error == 'invalid_email' %}
                                <div class="alert alert-warning border-0 shadow-sm" role="alert">
                                    Informe um e-mail valido para receber retorno.
                                </div>
                            {% elseif contact_status.error %}
                                <div class="alert alert-danger border-0 shadow-sm" role="alert">
                                    Nao foi possivel enviar a mensagem. Tente novamente.
                                </div>
                            {% endif %}
                            <form method="POST" action="{{ BASE_URL }}contact/send" class="row g-3 auth-form auth-form--light">
                                <div class="col-12 mt-0">
                                    <label for="nome" class="form-label text-white">Nome <span class="text-warning">*</span></label>
                                    <input type="text"
                                           class="form-control form-control-lg"
                                           id="nome"
                                           name="nome"
                                           placeholder="Seu nome completo"
                                           autocomplete="name"
                                           minlength="3"
                                           maxlength="120"
                                           title="Informe seu nome completo."
                                           required>
                                </div>
                                <div class="col-12">
                                    <label for="email" class="form-label text-white">Email <span class="text-warning">*</span></label>
                                    <input type="email"
                                           class="form-control form-control-lg"
                                           id="email"
                                           name="email"
                                           placeholder="voce@exemplo.com"
                                           autocomplete="email"
                                           inputmode="email"
                                           maxlength="160"
                                           title="Informe um e-mail valido para retorno."
                                           required>
                                </div>
                                <div class="col-12">
                                    <label for="mensagem" class="form-label text-white">Mensagem <span class="text-warning">*</span></label>
                                    <textarea class="form-control form-control-lg"
                                              id="mensagem"
                                              name="mensagem"
                                              rows="5"
                                              placeholder="Descreva sua solicitacao, duvida ou assunto institucional."
                                              minlength="10"
                                              maxlength="2000"
                                              oninput="document.getElementById('mensagemCounter').textContent = this.value.length + '/2000';"
                                              title="Escreva uma mensagem com pelo menos 10 caracteres."
                                              required></textarea>
                                    <div class="d-flex justify-content-end mt-2">
                                        <small id="mensagemCounter" class="text-white-50">0/2000</small>
                                    </div>
                                </div>
                                <div class="col-12 recaptcha-wrap">
                                    <div class="g-recaptcha" data-sitekey="{{ RECAPTCHA_SITE_KEY }}" data-theme="light" data-size="normal"></div>
                                </div>
                                <div class="col-12">
                                    {% include 'site/components/button.twig' with {
                                        label: 'Enviar mensagem',
                                        icon: 'bi-send',
                                        variant: 'solid',
                                        size: 'lg',
                                        type: 'submit',
                                        button_class: 'w-100 fw-bold'
                                    } %}
                                </div>
                            </form>
                        </div>
                </div>
            </div>
        </div>
    </section>

