{% extends "layouts/base.twig" %}

{% block title %}Erro interno - CBMRN{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/error-pages.css">
{% endblock %}

{% block content %}
    <section class="error-shell">
        <div class="container">
            <div class="error-panel">
                <div class="error-panel__body">
                    <div class="row align-items-center g-4">
                        <div class="col-lg-7">
                            <div class="error-code">
                                <i class="bi bi-exclamation-octagon-fill"></i>
                                <span>Erro 500</span>
                            </div>
                            <h1 class="error-title">Falha interna no processamento da requisicao</h1>
                            <p class="error-lead">
                                O sistema encontrou uma condicao inesperada e nao conseguiu concluir a operacao. O evento foi registrado para analise tecnica. Tente novamente em instantes.
                            </p>
                            <div class="error-meta">
                                <div class="error-meta__item">
                                    <i class="bi bi-cpu"></i>
                                    <span>Servico temporariamente indisponivel</span>
                                </div>
                                <div class="error-meta__item">
                                    <i class="bi bi-telephone"></i>
                                    <span>Canal emergencial: {{ institutional_contact.emergency.display }}</span>
                                </div>
                            </div>
                            <div class="error-actions">
                                {% include 'site/components/button.twig' with {
                                    href: BASE_URL,
                                    label: 'Retornar ao inicio',
                                    icon: 'bi-house-door',
                                    variant: 'solid',
                                    size: 'lg',
                                    button_class: 'fw-bold'
                                } %}
                                {% include 'site/components/button.twig' with {
                                    href: BASE_URL ~ 'contact',
                                    label: 'Falar com a equipe',
                                    icon: 'bi-envelope',
                                    variant: 'outline',
                                    size: 'lg',
                                    button_class: 'fw-bold'
                                } %}
                            </div>
                        </div>
                        <div class="col-lg-5">
                            <div class="error-visual text-center">
                                <img src="{{ BASE_URL }}assets/images/brasao_cbmrn_oficial.png" alt="Brasao institucional do CBMRN" class="error-badge">
                                <p class="error-note">CBMRN · Integridade operacional e continuidade de servico</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
