{% extends "layouts/base.twig" %}

{% block title %}Página não encontrada - AORE/RN{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/error-pages.css">
{% endblock %}

{% block content %}
    <section class="error-shell">
        <div class="container">
            <div class="error-panel">
                <div class="error-panel__body">
                    <div class="row align-items-center g-4">
                        <div class="col-lg-7">
                            <div class="error-code">
                                <i class="bi bi-signpost-2-fill"></i>
                                <span>Erro 404</span>
                            </div>
                            <h1 class="error-title">A rota informada nao foi localizada</h1>
                            <p class="error-lead">
                                O endereco solicitado nao corresponde a uma pagina ativa do portal institucional. Verifique o link informado ou retorne ao ponto inicial de navegacao.
                            </p>
                            <div class="error-meta">
                                <div class="error-meta__item">
                                    <i class="bi bi-compass"></i>
                                    <span>Conteudo removido, URL invalida ou digitacao incorreta</span>
                                </div>
                                <div class="error-meta__item">
                                    <i class="bi bi-envelope"></i>
                                    <span>{{ institutional_contact.emails.primary }}</span>
                                </div>
                            </div>
                            <div class="error-actions">
                                {% include 'site/components/button.twig' with {
                                    href: BASE_URL,
                                    label: 'Voltar ao portal',
                                    icon: 'bi-house-door',
                                    variant: 'solid',
                                    size: 'lg',
                                    button_class: 'fw-bold'
                                } %}
                                {% include 'site/components/button.twig' with {
                                    href: BASE_URL ~ 'contact',
                                    label: 'Ir para contato',
                                    icon: 'bi-envelope',
                                    variant: 'outline',
                                    size: 'lg',
                                    button_class: 'fw-bold'
                                } %}
                            </div>
                        </div>
                        <div class="col-lg-5">
                            <div class="error-visual text-center">
                                <img src="{{ BASE_URL }}assets/images/aore1.png" alt="Brasão institucional da AORE/RN" class="error-badge">
                                <p class="error-note">Portal institucional da AORE/RN</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
