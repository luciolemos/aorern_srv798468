{% extends "layouts/base.twig" %}

{% block title %}{{ post.titulo }} - CBMRN{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/blog.css">
{% endblock %}

{% block content %}
    <div class="container-xxl py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">
                <article>
                    <header class="mb-4">
                        <h1 class="fw-bold mb-3" style="color: #df6301;">{{ post.titulo }}</h1>
                        <div class="text-muted mb-3">
                            <small>
                                <i class="bi bi-calendar-event"></i> {{ post.criado_em|date('d/m/Y') }}
                                {% if post.autor %}
                                    | <i class="bi bi-person"></i> {{ post.autor }}
                                {% endif %}
                            </small>
                        </div>
                        {% if post.categoria_nome %}
                            {% set categoriaCor = post.categoria_cor|default('#df6301') %}
                            <div class="mb-2">
                                <span class="blog-category-badge blog-category-badge-card" style="background-color: {{ categoriaCor }}; border-color: {{ categoriaCor }}; color: #fff;">
                                    <i class="bi bi-tag me-1"></i>{{ post.categoria_nome }}
                                </span>
                            </div>
                        {% endif %}
                    </header>

                    {% set shareUrl = BASE_URL ~ 'blog/' ~ post.slug %}

                    {% if post.capa_url %}
                        <figure class="post-cover rounded-4 overflow-hidden shadow-sm mb-4">
                            <img src="{{ post.capa_url }}" alt="Imagem de capa de {{ post.titulo }}" class="img-fluid" loading="lazy">
                        </figure>
                    {% endif %}

                    <div class="post-content mb-5" style="line-height: 1.8; font-size: 1.1rem;">
                        {{ post.conteudo|raw }}
                    </div>

                    <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                        {% if previousPost %}
                            {% include 'site/components/button.twig' with {
                                href: BASE_URL ~ 'blog/' ~ previousPost.slug,
                                label: 'Artigo anterior',
                                icon: 'bi-arrow-left',
                                variant: 'outline',
                                size: 'lg',
                                button_class: 'fw-bold'
                            } %}
                        {% endif %}
                        {% if nextPost %}
                            {% include 'site/components/button.twig' with {
                                href: BASE_URL ~ 'blog/' ~ nextPost.slug,
                                label: 'Próximo artigo',
                                icon: 'bi-arrow-right',
                                icon_position: 'end',
                                variant: 'solid',
                                size: 'lg',
                                button_class: 'fw-bold'
                            } %}
                        {% endif %}
                    </div>

                    <div class="post-share-card card border-0 shadow-sm mt-4">
                        <div class="card-body d-flex flex-column flex-md-row align-items-md-center gap-3">
                            <div>
                                <p class="text-muted text-uppercase small fw-semibold mb-1">Compartilhar</p>
                                <p class="mb-0 text-muted">Divulgue este conteúdo nas suas redes.</p>
                            </div>
                            <div class="d-flex flex-wrap gap-2 ms-md-auto">
                                {% include 'site/components/button.twig' with {
                                    href: 'https://www.facebook.com/sharer/sharer.php?u=' ~ shareUrl|url_encode,
                                    label: 'Facebook',
                                    icon: 'bi-facebook',
                                    icon_class: 'text-white',
                                    variant: 'solid',
                                    size: 'lg',
                                    button_class: 'share-btn share-btn-facebook',
                                    target: '_blank',
                                    rel: 'noopener',
                                    attrs: {'title': 'Facebook'}
                                } %}
                                {% include 'site/components/button.twig' with {
                                    href: 'https://twitter.com/intent/tweet?url=' ~ shareUrl|url_encode ~ '&text=' ~ post.titulo|url_encode,
                                    label: 'Twitter',
                                    icon: 'bi-twitter',
                                    icon_class: 'text-white',
                                    variant: 'solid',
                                    size: 'lg',
                                    button_class: 'share-btn share-btn-twitter',
                                    target: '_blank',
                                    rel: 'noopener',
                                    attrs: {'title': 'Twitter / X'}
                                } %}
                                {% include 'site/components/button.twig' with {
                                    href: 'https://api.whatsapp.com/send?text=' ~ (post.titulo ~ ' - ' ~ shareUrl)|url_encode,
                                    label: 'WhatsApp',
                                    icon: 'bi-whatsapp',
                                    icon_class: 'text-white',
                                    variant: 'solid',
                                    size: 'lg',
                                    button_class: 'share-btn share-btn-whatsapp',
                                    target: '_blank',
                                    rel: 'noopener',
                                    attrs: {'title': 'WhatsApp'}
                                } %}
                                {% include 'site/components/button.twig' with {
                                    href: 'https://www.linkedin.com/shareArticle?mini=true&url=' ~ shareUrl|url_encode ~ '&title=' ~ post.titulo|url_encode,
                                    label: 'LinkedIn',
                                    icon: 'bi-linkedin',
                                    icon_class: 'text-white',
                                    variant: 'solid',
                                    size: 'lg',
                                    button_class: 'share-btn share-btn-linkedin',
                                    target: '_blank',
                                    rel: 'noopener',
                                    attrs: {'title': 'LinkedIn'}
                                } %}
                            </div>
                        </div>
                    </div>
                </article>

                <section class="mt-5 pt-4 border-top">
                    <h2 class="h5 fw-bold text-primary mb-3">
                        <i class="bi bi-chat-dots-fill me-2"></i>Comentários
                    </h2>
                    <div id="giscus-container" class="bg-light rounded-3 shadow-sm p-3">
                        <script src="https://giscus.app/client.js"
                                data-repo="luciolemos/mvc"
                                data-repo-id="R_kgDOOrqc9g"
                                data-category="Show and tell"
                                data-category-id="DIC_kwDOOrqc9s4CqRCQ"
                                data-mapping="pathname"
                                data-strict="0"
                                data-reactions-enabled="1"
                                data-emit-metadata="0"
                                data-input-position="top"
                                data-theme="light"
                                data-lang="pt"
                                crossorigin="anonymous"
                                async>
                        </script>
                    </div>
                </section>
            </div>
        </div>
    </div>
{% endblock %}
