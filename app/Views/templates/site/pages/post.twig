{% extends "layouts/base.twig" %}

{% block title %}{{ post.titulo }} - AORE/RN{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/blog.css">
{% endblock %}

{% block content %}
    <div id="fb-root"></div>
    <div class="container-xxl py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">
                <article>
                    <header class="mb-4">
                        <h1 class="fw-bold mb-3" style="color: #556b2f;">{{ post.titulo }}</h1>
                        <div class="text-muted mb-3">
                            <small>
                                <i class="bi bi-calendar-event"></i> {{ post.criado_em|date('d/m/Y') }}
                                {% if post.autor %}
                                    <span class="mx-3">•</span> <i class="bi bi-person"></i> {{ post.autor }}
                                {% endif %}
                                <span class="mx-3">•</span>
                                {% if post.categoria_nome %}
                                   {% set categoriaCor = post.categoria_cor|default('#556b2f') %}
                                     
                                         <span class="blog-category-badge blog-category-badge-card" style="background-color: {{ categoriaCor }}; border-color: {{ categoriaCor }}; color: #fff;">
                                           <i class="bi bi-tag me-1"></i>{{ post.categoria_nome }}
                                        </span>
                                    
                                   {% endif %}
                            </small>                  
                        </div>

                    </header>

                    {% set canonicalPath = current_path ?: ('blog/' ~ post.slug) %}
                    {% set shareUrl = BASE_URL ~ canonicalPath %}

                    {% if post.capa_url %}
                        <figure class="post-cover rounded-4 overflow-hidden shadow-sm mb-4">
                            <img src="{{ post.capa_url }}" alt="Imagem de capa de {{ post.titulo }}" class="img-fluid" loading="lazy">
                        </figure>
                    {% endif %}

                    <div class="post-content mb-5" style="line-height: 1.8; font-size: 1.1rem;">
                        {{ post.conteudo|raw }}
                    </div>

                    <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                        {% if previousPost %}
                            {% include 'site/components/button.twig' with {
                                href: BASE_URL ~ 'blog/' ~ previousPost.slug,
                                label: 'Artigo anterior',
                                icon: 'bi-arrow-left',
                                variant: 'outline',
                                size: 'lg',
                                button_class: 'fw-bold'
                            } %}
                        {% endif %}
                        {% if nextPost %}
                            {% include 'site/components/button.twig' with {
                                href: BASE_URL ~ 'blog/' ~ nextPost.slug,
                                label: 'Próximo artigo',
                                icon: 'bi-arrow-right',
                                icon_position: 'end',
                                variant: 'solid',
                                size: 'lg',
                                button_class: 'fw-bold'
                            } %}
                        {% endif %}
                    </div>

                    <div class="post-share-card card border-0 shadow-sm mt-4">
                        <div class="card-body d-flex flex-column flex-md-row align-items-md-center gap-3">
                            <div>
                                <p class="text-muted text-uppercase small fw-semibold mb-1">Compartilhar</p>
                                <p class="mb-0 text-muted">Divulgue este conteúdo nas suas redes.</p>
                            </div>
                            <div class="d-flex flex-wrap gap-3 ms-md-auto">
                                <a class="share-icon" href="https://www.facebook.com/sharer/sharer.php?u={{ shareUrl|url_encode }}" target="_blank" rel="noopener" aria-label="Compartilhar no Facebook">
                                    <i class="bi bi-facebook"></i>
                                </a>
                                <a class="share-icon" href="https://twitter.com/intent/tweet?url={{ shareUrl|url_encode }}&text={{ post.titulo|url_encode }}" target="_blank" rel="noopener" aria-label="Compartilhar no Twitter/X">
                                    <i class="bi bi-twitter"></i>
                                </a>
                                <a class="share-icon" href="https://api.whatsapp.com/send?text={{ (post.titulo ~ ' - ' ~ shareUrl)|url_encode }}" target="_blank" rel="noopener" aria-label="Compartilhar no WhatsApp">
                                    <i class="bi bi-whatsapp"></i>
                                </a>
                                <a class="share-icon" href="https://www.linkedin.com/shareArticle?mini=true&url={{ shareUrl|url_encode }}&title={{ post.titulo|url_encode }}" target="_blank" rel="noopener" aria-label="Compartilhar no LinkedIn">
                                    <i class="bi bi-linkedin"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </article>

        

                <section class="mt-5 pt-4 border-top">
                    <h2 class="h5 fw-bold text-primary mb-3">
                        <i class="bi bi-chat-left-text me-2"></i>Comentários (Facebook)
                    </h2>
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="fb-comments" data-href="{{ shareUrl }}" data-width="100%" data-numposts="5" data-order-by="reverse_time"></div>
                        </div>
                    </div>
                </section>

                <section class="mt-5 pt-4 border-top">
                    <h2 class="h5 fw-bold text-primary mb-3">
                        <i class="bi bi-chat-dots-fill me-2"></i>Comentários (GitHub)
                    </h2>
                    <div class="alert alert-light border shadow-sm mb-0" role="status">
                        Os comentários estão temporariamente indisponíveis enquanto o repositório
                        <strong>luciolemos/aorern_srv798468</strong> não tiver Discussions habilitado e configurado para o Giscus.
                    </div>
                </section>
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
    {{ parent() }}
    <script async defer crossorigin="anonymous" src="https://connect.facebook.net/pt_BR/sdk.js#xfbml=1&version=v19.0"></script>
{% endblock %}
