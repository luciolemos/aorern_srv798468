{% extends 'layouts/base.twig' %}

{% block title %}Documentação Técnica - AORE/RN{% endblock %}

{% block content %}
<section class="py-5">
    <div class="container-fluid px-3 px-md-4 docs-page">
        <div class="mb-4">
            <span class="badge docs-badge mb-3"><i class="bi bi-shield-lock me-1"></i>Acesso restrito ao administrador</span>
            <h1 class="h3 fw-bold mb-1">Documentação técnica do projeto</h1>
            <p class="text-muted mb-0">Leitura centralizada dos arquivos Markdown do sistema.</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-4 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-light border-bottom">
                        <h2 class="h6 mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Sumário</h2>
                    </div>
                    <div class="card-body p-0">
                        {% if documents is empty %}
                            <div class="p-3 text-muted small">Nenhum documento Markdown encontrado.</div>
                        {% else %}
                            <div class="list-group list-group-flush">
                                {% set currentCategory = '' %}
                                {% for doc in documents %}
                                    {% if doc.category != currentCategory %}
                                        {% set currentCategory = doc.category %}
                                        <div class="px-3 pt-3 pb-1 small fw-bold text-uppercase text-muted">{{ currentCategory }}</div>
                                    {% endif %}
                                    <a href="{{ BASE_URL }}docs/doc/{{ doc.slug|e('html_attr') }}"
                                       class="list-group-item list-group-item-action border-0 py-2 px-3 small {{ selectedDoc and selectedDoc.slug == doc.slug ? 'active' : '' }}">
                                        {{ doc.title }}
                                    </a>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-lg-8 col-xl-9">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h2 class="h5 mb-0 fw-bold">{{ selectedDoc.title|default('Sem documento selecionado') }}</h2>
                        {% if selectedDoc %}
                            <small class="text-muted">{{ selectedDoc.relative_path }}</small>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        {% if selectedDoc %}
                            <pre class="docs-content mb-0">{{ selectedDocContent|default('')|e }}</pre>
                        {% else %}
                            <p class="text-muted mb-0">Selecione um documento no sumário para visualizar o conteúdo.</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block styles %}
    {{ parent() }}
    <style>
        .docs-page .list-group-item.active {
            background: rgba(85, 107, 47, 0.14);
            color: #21310f;
            font-weight: 600;
            border-left: 3px solid #556b2f !important;
        }

        .docs-content {
            white-space: pre-wrap;
            word-break: break-word;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 0.9rem;
            line-height: 1.5;
            color: #1f2f16;
            background: rgba(248, 249, 250, 0.9);
            border: 1px solid rgba(15, 31, 51, 0.08);
            border-radius: 0.75rem;
            padding: 1rem;
            max-height: 72vh;
            overflow: auto;
        }

        .docs-badge {
            background: linear-gradient(135deg, #4f6a24 0%, #2f4314 100%);
            color: #fff;
            border-radius: 999px;
            padding: 0.5rem 0.85rem;
            font-weight: 600;
        }
    </style>
{% endblock %}
