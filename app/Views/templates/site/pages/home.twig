    <section class="home-occurrence-metrics home-highlights home-section py-5">
      {% set ocorrenciaCards = ocorrenciasPorTipo|default([]) %}
      {% if ocorrenciaCards|length > 0 %}
        
        <div class="container">
            <div class="row align-items-center g-4">
                    <div class="col-lg-6">
                        {% include 'site/components/section-header.twig' with {
                        kicker: 'Tecnologia e pessoas',
                        title: 'Integração entre dados, equipes e frota',
                        subtitle: 'Acompanhamos cada fase da ocorrência com dashboards em tempo real, garantindo comunicação entre o centro de operações, o efetivo em campo e as defesas civis municipais.',
                        kicker_class: 'text-muted',
                        subtitle_class: 'text-muted',
                        extra_class: 'mb-4'
                    } %}
                        {# <p class="text-uppercase text-muted small fw-semibold mb-1">Monitoramento operacional</p>
                        <h3 class="h4 fw-bold mb-2">Ocorrências por tipo</h3>
                        <p class="text-muted mb-0">Atualizado a partir do Livro de Ocorrências. Destaque imediato para as frentes com maior demanda.</p> #}
                         <p class="text-muted mb-0">Indicadores de desempenho do 2º Subgrupamento de Bombeiros Militar</p>
                         {% if ocorrenciasPeriodoDescricao is defined %}
                             <p class="text-muted small mb-0">{{ ocorrenciasPeriodoDescricao }}</p>
                         {% endif %}
                    </div>
                    <div class="col-lg-6 text-lg-end">
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL ~ 'admin/livro-ocorrencias',
                            label: 'Abrir painel completo',
                            icon: 'bi-speedometer2',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'd-none d-lg-inline-flex ms-lg-auto',
                            target: '_blank',
                            attrs: {
                                rel: 'noopener'
                            }
                        } %}
                    </div>
                </div>
                {% set civicoRef = 'ação cívico-social'|lower %}
                {% set civicoCardMatch = null %}
                {% set outrosCards = [] %}
                {% for ocorrencia in ocorrenciaCards %}
                    {% set tipoNome = ocorrencia.tipo|default('') %}
                    {% set tipoNormalized = tipoNome|lower %}
                    {% if civicoCardMatch is null and tipoNormalized == civicoRef %}
                        {% set civicoCardMatch = ocorrencia %}
                    {% else %}
                        {% set outrosCards = outrosCards|merge([ocorrencia]) %}
                    {% endif %}
                {% endfor %}

                {% set civicoCard = civicoCardMatch ?? {
                    tipo: 'Ação cívico-social',
                    total: 0,
                    meta: 'Projetos educativos e apoio às comunidades'
                } %}

                {% if civicoCard.meta is not defined or civicoCard.meta is empty %}
                    {% set civicoCard = civicoCard|merge({ meta: 'Projetos educativos e apoio às comunidades' }) %}
                {% endif %}

                {% set cardsComCivico = outrosCards|merge([civicoCard]) %}
                {% set cardRows = cardsComCivico|batch(4, null) %}
                {% for row in cardRows %}
                    <div class="row g-3 g-md-4 mt-2 mt-md-4">
                        {% for ocorrencia in row %}
                            {% if ocorrencia %}
                                <div class="col-12 col-sm-6 col-xl-3">
                                    <article class="occurrence-card h-100">
                                        <p class="occurrence-card-label text-uppercase small mb-1">{{ ocorrencia.tipo|default('Não classificada') }}</p>
                                        <p class="occurrence-card-value mb-0">{{ ocorrencia.total }}</p>
                                        <p class="occurrence-card-meta text-muted mb-0">{{ ocorrencia.meta|default('Registros recentes') }}</p>
                                    </article>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endfor %}
                <div class="row mt-3 d-lg-none">
                    <div class="col text-center">
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL ~ 'admin/livro-ocorrencias',
                            label: 'Abrir painel completo',
                            icon: 'bi-speedometer2',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold text-white',
                            target: '_blank',
                            attrs: {
                                rel: 'noopener'
                            }
                        } %}
                    </div>
                </div>
            </div>       
      {% endif %}
     </section>

     <section class="home-occurrence-map home-section py-5">
        <div class="container">
            <div class="row align-items-center g-4">
                <div class="col-lg-4">
                    {% include 'site/components/section-header.twig' with {
                        kicker: 'Mapa operacional',
                        title: 'Ocorrências por município',
                        subtitle: 'Visualize onde os atendimentos do 2º Subgrupamento de Bombeiros Militar se concentram e acompanhe o pulso regional em tempo real.',
                        align: 'start',
                        kicker_class: 'text-muted text-uppercase small',
                        title_class: 'text-primary',
                        subtitle_class: 'text-muted',
                        extra_class: 'mb-4'
                    } %}
                    <div class="occurrence-map-controls d-flex flex-wrap align-items-end gap-3 mb-3">
                        <div class="occurrence-map-control">
                            <label for="occurrence-map-year" class="small text-muted mb-1">Ano</label>
                            <select id="occurrence-map-year" class="form-select form-select-sm" data-map-year-select>
                                {% for yearOption in mapYearOptions|default([mapYear]) %}
                                    <option value="{{ yearOption }}" {% if yearOption == mapYear %}selected{% endif %}>{{ yearOption }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        {% if mapTipoOptions is defined and mapTipoOptions|length > 0 %}
                            <div class="occurrence-map-control flex-grow-1">
                                <label for="occurrence-map-type" class="small text-muted mb-1">Tipo</label>
                                <select id="occurrence-map-type" class="form-select form-select-sm" data-map-type-select>
                                    <option value="">Todos os tipos</option>
                                    {% for tipoOption in mapTipoOptions %}
                                        <option value="{{ tipoOption.id }}">{{ tipoOption.nome }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        {% endif %}
                        {% if mapStatusOptions is defined and mapStatusOptions|length > 0 %}
                            <div class="occurrence-map-control flex-grow-1">
                                <label for="occurrence-map-status" class="small text-muted mb-1">Status</label>
                                <select id="occurrence-map-status" class="form-select form-select-sm" data-map-status-select>
                                    <option value="">Todos os status</option>
                                    {% for statusValue, statusLabel in mapStatusOptions %}
                                        <option value="{{ statusValue }}">{{ statusLabel }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        {% endif %}
                    </div>
                    <div class="occurrence-map-summary" data-map-summary>
                        <p class="mb-1 fw-semibold">Carregando painel dinâmico...</p>
                        <p class="mb-0 text-muted small">Conectando aos registros consolidados do livro.</p>
                    </div>
                    <ul class="occurrence-map-top list-unstyled mt-3" data-map-top-list>
                        <li class="text-muted small">Os municípios com maior volume aparecerão aqui.</li>
                    </ul>
                    <p class="occurrence-map-status small text-muted mt-3" data-map-status role="status">Mapa pronto para atualização.</p>
                </div>
                <div class="col-lg-8">
                    <div class="occurrence-map-wrapper">
                        <div class="occurrence-map-canvas">
                            <div id="occurrence-map"
                                 data-endpoint="{{ BASE_URL }}ocorrencias/mapa-municipios"
                                 data-initial-year="{{ mapYear }}"
                                   data-maps-enabled="{{ GOOGLE_MAPS_API_KEY ? '1' : '0' }}"
                                   data-badge-src="{{ BASE_URL }}assets/images/brasao_cbmrn_oficial.png"></div>
                            <div class="occurrence-map-fallback {{ GOOGLE_MAPS_API_KEY ? 'd-none' : '' }}" data-map-fallback>
                                <p class="fw-semibold mb-1">Mapa em modo reduzido</p>
                                <p class="mb-2 small text-muted">Informe a variável <span class="occurrence-map-key">GOOGLE_MAPS_API_KEY</span> no arquivo .env para liberar os marcadores do Google Maps.</p>
                                <p class="mb-0 text-muted small">Os totais seguem disponíveis na lista lateral.</p>
                            </div>
                        </div>
                        <div class="occurrence-map-legend mt-3 d-flex flex-wrap align-items-center gap-2">
                            <span class="legend-badge legend-badge-low">Baixa</span>
                            <span class="legend-badge legend-badge-medium">Moderada</span>
                            <span class="legend-badge legend-badge-high">Alta</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
     </section>

