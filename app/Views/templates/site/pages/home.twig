{% extends "layouts/base.twig" %}

{% block title %}AORE/RN - Associação dos Oficiais da Reserva do Exército{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/home.css?v=20260307-sponsors1">     
{% endblock %}

{% block scripts %}
    {{ parent() }}
    <script>
        (function () {
            const carouselEl = document.getElementById('homeSponsorsCarousel');
            if (!carouselEl) return;

            const thumbs = Array.from(document.querySelectorAll('.home-sponsor-thumb[data-bs-slide-to]'));
            if (!thumbs.length) return;

            carouselEl.addEventListener('slide.bs.carousel', function (event) {
                const nextIndex = Number(event.to);
                thumbs.forEach((thumb, index) => {
                    const isActive = index === nextIndex;
                    thumb.classList.toggle('active', isActive);
                    if (isActive) {
                        thumb.setAttribute('aria-current', 'true');
                    } else {
                        thumb.removeAttribute('aria-current');
                    }
                });
            });
        })();
    </script>
{% endblock %}

{% block content %}
    <section class="home-hero site-hero">
        <div class="site-hero-pattern"></div>
        <div class="container-fluid position-relative px-3 px-md-4">
            <div class="row justify-content-center">
                <div class="col-xl-9 col-lg-10">
                    <div class="hero-content text-center home-hero-intro">
                        <div class="home-hero-logo mb-4">
                            <img src="{{ BASE_URL }}assets/images/aorern-medalhao-verde-aorer6-oficial-3200_1.png" alt="Identidade visual da AORE/RN" class="img-fluid home-hero-logo-image">
                        </div>
                        {# <p class="home-hero-subtitle text-white mb-2">Associação dos Oficiais da Reserva do Exército</p> #}
                        <h1 class="home-hero-title text-white mb-3">AORE/RN</h1>
                        <p class="home-hero-motto mb-4"><i>Perpetuum Officium erga Patriam</i></p>
                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center home-hero-actions">
                            {% include 'site/components/button.twig' with {
                                href: BASE_URL ~ 'about',
                                label: 'Conheça',
                                icon: 'bi-shield-check',
                                variant: 'outline',
                                size: 'lg',
                                button_class: 'fw-bold home-hero-btn home-hero-btn--secondary'
                            } %}
                            {% include 'site/components/button.twig' with {
                                href: whatsapp.links.general,
                                label: 'WhatsApp',
                                icon: 'bi-whatsapp',
                                variant: 'outline',
                                size: 'lg',
                                button_class: 'fw-bold home-hero-btn home-hero-btn--secondary',
                                target: '_blank'
                            } %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-about home-section py-5">
        <div class="container">
            <div class="row align-items-center g-4">
                <div class="col-lg-7">
                    {% include 'site/components/section-header.twig' with {
                        kicker: 'Identidade institucional',
                        title: 'Uma associação que mantém vivo o elo entre o Exército Brasileiro e seus oficiais da reserva',
                        subtitle: 'A AORE/RN congrega oficiais formados pelos Núcleos e Centros de Preparação de Oficiais da Reserva, fortalecendo a camaradagem, o espírito de corpo e a identidade institucional dos oficiais R/2 no Rio Grande do Norte.',
