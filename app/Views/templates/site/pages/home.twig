    <section class="home-k9 home-section py-5">
        <div class="container">
            <div class="row align-items-center gy-4">
                <div class="col-lg-6">
                    <img src="{{ BASE_URL }}assets/images/caes/malinois_1600_1600.jpg"
                         alt="Esquadrão com cães farejadores do CBMRN"
                         class="img-fluid home-k9-image shadow-sm">
                </div>
                <div class="col-lg-6">
                    {% include 'site/components/section-header.twig' with {
                        kicker: 'Esquadrão de Cães de Combate',
                        title: 'Operações com apoio canino especializado',
                        subtitle: "O 2º Subgrupamento conta com cães treinados para busca, salvamento e apoio psicossocial. Os binômios realizam treinamentos semanais, garantindo prontidão para ocorrências urbanas e rurais. " ~
                                  "Os treinamentos são realizados de forma sistemática, com rotinas que englobam socialização, obediência, condicionamento físico, ambientação a cenários simulados, pistas de escombros, trilhas rurais e exercícios de resiliência comportamental. " ~
                                  "Essas práticas garantem não apenas a prontidão operacional da tropa, mas também o bem-estar físico e emocional dos cães, condição indispensável para o desempenho seguro e eficaz das missões.",
                        kicker_class: 'text-muted',
                        title_class: 'text-primary',
                        subtitle_class: 'text-muted',
                        extra_class: 'mb-4'
                    } %}

                    <ul class="list-unstyled home-k9-list icon-list mb-4">
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true">
                                <i class="bi bi-shield-check"></i>
                            </span>
                            <span>Protocolos de segurança e bem-estar animal</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true">
                                <i class="bi bi-geo-alt"></i>
                            </span>
                            <span>Prontidão para missões em toda a Região Agreste e Litoral Sul,</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true">
                                <i class="bi bi-heart-pulse"></i>
                            </span>
                            <span>Atuação em ações educativas com a comunidade</span>
                        </li>
                    </ul>
                    {% include 'site/components/button.twig' with {
                        href: BASE_URL ~ 'esquadrao',
                        label: 'Saiba mais',
                        icon: 'bi-arrow-right',
                        icon_position: 'end',                       
                        variant: 'solid',
                                    size: 'lg',
                       
                    } %}
                </div>
            </div>
        </div>
    </section>

