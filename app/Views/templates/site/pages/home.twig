                        kicker_class: 'text-muted mb-2',
                        title_class: 'text-primary mb-3',
                        subtitle_class: 'text-muted mb-4'
                    } %}

                    <ul class="list-unstyled home-k9-list icon-list mb-0">
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true">
                                <i class="bi bi-people"></i>
                            </span>
                            <span>Congrega Oficiais da Reserva do Exército, valorizando o vínculo duradouro entre os integrantes da ativa e os oficiais licenciados.</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true">
                                <i class="bi bi-bank"></i>
                            </span>
                            <span>Preserva valores, tradições e a cultura militar do Exército Brasileiro por meio de ações institucionais permanentes.</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true">
                                <i class="bi bi-award"></i>
                            </span>
                            <span>Promove solenidades, eventos comemorativos, encontros de integração e cerimônias de reconhecimento entre associados.</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true">
                                <i class="bi bi-shield-check"></i>
                            </span>
                            <span>Atua na valorização institucional dos oficiais da reserva, na defesa de seus direitos e no estímulo à participação cívica e social.</span>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-5">
                    <div class="bg-white shadow-sm rounded-4 p-4 p-lg-5 h-100 border">
                        <p class="text-uppercase small fw-semibold text-muted mb-2">Dados institucionais</p>
                        <h3 class="h4 fw-bold text-primary mb-4">Base administrativa e identidade jurídica</h3>
                        <dl class="row mb-0 g-3">
                            <dt class="col-sm-4 text-muted">Nome</dt>
                            <dd class="col-sm-8 mb-0">Associação dos Oficiais da Reserva do Exército do Rio Grande do Norte</dd>
                            <dt class="col-sm-4 text-muted">Sigla</dt>
                            <dd class="col-sm-8 mb-0">AORE/RN</dd>
                            <dt class="col-sm-4 text-muted">CNPJ</dt>
                            <dd class="col-sm-8 mb-0">70.145.065/0001-00</dd>
                            <dt class="col-sm-4 text-muted">Sede</dt>
                            <dd class="col-sm-8 mb-0">Natal/RN, nas dependências do 16º Batalhão de Infantaria Motorizado, bairro Tirol</dd>
                            <dt class="col-sm-4 text-muted">Natureza</dt>
                            <dd class="col-sm-8 mb-0">Entidade civil privada, sem fins lucrativos</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-k9 home-section py-5">
        <div class="container">
            {% include 'site/components/section-header.twig' with {
                kicker: 'Frentes de atuação',
                title: 'Como a AORE/RN atua no plano institucional e associativo',
                subtitle: 'A associação combina memória, representação, integração e reconhecimento para manter ativos os valores adquiridos na formação militar e ampliar a presença cívica dos oficiais da reserva no estado.',
                align: 'center',
                kicker_class: 'text-muted',
                title_class: 'text-primary',
                subtitle_class: 'text-muted',
                extra_class: 'mb-5'
            } %}

            {% set home_cards = [
                {
                    icon: 'bi bi-flag',
                    title: 'Preservação de valores e tradições',
                    description: 'Mantém viva a cultura militar do Exército Brasileiro por meio de ritos, memória institucional, datas comemorativas e práticas associativas permanentes.'
                },
                {
                    icon: 'bi bi-people-fill',
                    title: 'Camaradagem e espírito de corpo',
                    description: 'Fortalece a convivência entre oficiais R/2, promovendo integração, amizade cívica e identidade comum entre gerações de reservistas.'
                },
                {
                    icon: 'bi bi-briefcase',
                    title: 'Representação e valorização',
                    description: 'Desenvolve ações voltadas à valorização dos oficiais da reserva, à defesa de seus direitos e à participação responsável na vida social e institucional.'
                },
                {
                    icon: 'bi bi-building-check',
                    title: 'Parcerias com organizações militares',
                    description: 'Atua em cooperação com o 16º BIMtz e outras organizações para realizar solenidades, encontros e atividades de integração entre ativa e reserva.'
                }
            ] %}

            <div class="row g-4">
                {% for card in home_cards %}
                    <div class="col-md-6 col-xl-3">
                        {% include 'site/components/feature-card.twig' with {
                            icon: card.icon,
                            title: card.title,
                            description: card.description,
                            card_class: 'h-100 text-center shadow-sm',
                            icon_class: 'mx-auto mb-3',
                            title_class: 'h5 fw-bold mb-2',
                            description_class: 'text-muted mb-0'
                        } %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="home-testimonials home-section py-5">
        <div class="container">
            <div class="row g-4 align-items-stretch">
                <div class="col-lg-7">
                    {% include 'site/components/section-header.twig' with {
                        kicker: 'Vida associativa',
                        title: 'Atividades que reforçam o vínculo permanente com a Pátria',
                        subtitle: 'A AORE/RN promove ações que ultrapassam a convivência social: estrutura encontros institucionais, solenidades cívico-militares, celebrações comemorativas e iniciativas de reconhecimento ao mérito associativo.',
                        align: 'start',
                        kicker_class: 'text-muted',
                        title_class: 'text-primary',
                        subtitle_class: 'text-muted',
                        extra_class: 'mb-4'
                    } %}

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="bg-white border rounded-4 p-4 h-100 shadow-sm">
                                <h3 class="h5 fw-bold mb-3">Integração institucional</h3>
                                <ul class="text-muted mb-0 ps-3">
                                    <li>Encontros e reuniões entre associados, oficiais da ativa e convidados.</li>
                                    <li>Solenidades e datas alusivas à memória do Exército Brasileiro.</li>
                                    <li>Participação em agendas cívicas, sociais e comemorativas no estado.</li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-white border rounded-4 p-4 h-100 shadow-sm">
                                <h3 class="h5 fw-bold mb-3">Reconhecimento ao mérito</h3>
                                <ul class="text-muted mb-0 ps-3">
                                    <li>Outorga de honrarias a associados que tenham prestado relevantes serviços.</li>
                                    <li>Valorização pública de trajetórias marcadas por disciplina e liderança.</li>
                                    <li>Registro e preservação da contribuição institucional dos reservistas.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="bg-white shadow-sm rounded-4 p-4 p-lg-5 h-100 border">
                        <p class="text-uppercase small fw-semibold text-muted mb-2">Honraria institucional</p>
                        <h3 class="h4 fw-bold text-primary mb-3">Medalha Reserva Ativa</h3>
                        <p class="text-muted mb-3">
                            A AORE/RN realiza cerimônias de reconhecimento e outorga de honrarias destinadas a distinguir associados que tenham prestado relevantes serviços à associação e à sociedade.
                        </p>
                        <p class="text-muted mb-4">
                            Mais do que um símbolo, a Medalha Reserva Ativa expressa a continuidade do compromisso com a disciplina, a lealdade, a liderança e o serviço à Pátria, mesmo após o licenciamento.
                        </p>
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL ~ 'about',
                            label: 'Ler apresentação institucional',
                            icon: 'bi-arrow-right',
                            icon_position: 'end',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold'
                        } %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {% if colaboradores is defined and colaboradores|length > 0 %}
    <section class="home-sponsors home-section py-5">
        <div class="container">
            {% include 'site/components/section-header.twig' with {
                kicker: 'Rede de apoio',
                title: 'Colaboradores da AORE/RN',
                subtitle: 'Empresas e instituições que contribuem para fortalecer as ações da associação.',
                align: 'center',
                kicker_class: 'text-muted',
                title_class: 'text-primary',
                subtitle_class: 'text-muted home-sponsors-subtitle-nowrap',
                extra_class: 'mb-4'
            } %}

            <div class="home-sponsors-shell">
                <div id="homeSponsorsCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="6500">
                    <div class="carousel-inner">
                        {% for patrocinador in colaboradores %}
                            <div class="carousel-item {% if loop.first %}active{% endif %}">
                                <article class="home-sponsor-feature-card"
                                    style="
                                        --sponsor-title-color: {{ patrocinador.texto_cor_titulo|default('#FFFFFF')|e('html_attr') }};
                                        --sponsor-description-color: {{ patrocinador.texto_cor_descricao|default('#FFFFFF')|e('html_attr') }};
                                        --sponsor-icon-color: {{ patrocinador.icone_cor|default('#FFFFFF')|e('html_attr') }};
                                    ">
                                    <div class="home-sponsor-feature-media">
                                        <img class="home-sponsor-feature-banner" src="{{ patrocinador.banner_url|default(patrocinador.logo_url|default(BASE_URL ~ 'assets/images/conscrito.png')) }}" alt="Banner de {{ patrocinador.nome|e('html_attr') }}" loading="lazy">
                                        {% if patrocinador.exibir_texto_banner %}
                                            <div class="home-sponsor-feature-title">
                                                <div class="home-sponsor-feature-title-text">{{ patrocinador.nome }}</div>
                                                <div class="home-sponsor-feature-subtitle">{{ patrocinador.descricao_curta|default('Empresa colaboradora da AORE/RN.') }}</div>
                                                <div class="home-sponsor-social-inline">
                                                    {% if patrocinador.whatsapp %}
                                                        <a class="home-sponsor-social-icon" href="https://wa.me/{{ patrocinador.whatsapp }}?text={{ 'Olá! Vim pelo site da AORE/RN e gostaria de informações.'|url_encode }}" target="_blank" rel="noopener" aria-label="WhatsApp">
                                                            <i class="bi bi-whatsapp"></i>
                                                        </a>
                                                    {% endif %}
                                                    <a class="home-sponsor-social-icon" href="{{ patrocinador.instagram|e('html_attr') }}" target="_blank" rel="noopener" aria-label="Instagram da empresa">
                                                        <i class="bi bi-instagram"></i>
                                                    </a>
                                                    {% if patrocinador.site %}
                                                        <a class="home-sponsor-social-icon" href="{{ patrocinador.site|e('html_attr') }}" target="_blank" rel="noopener" aria-label="Site da empresa" title="{{ patrocinador.site|e('html_attr') }}">
                                                            <i class="bi bi-globe2"></i>
                                                        </a>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            <div class="home-sponsor-feature-content">
                                                <div class="home-sponsor-actions-placeholder" aria-hidden="true"></div>
                                            </div>
                                        {% endif %}
                                    </div>
                                </article>
                            </div>
                        {% endfor %}
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#homeSponsorsCarousel" data-bs-slide="prev" aria-label="Anterior">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#homeSponsorsCarousel" data-bs-slide="next" aria-label="Próximo">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                </div>

                <div class="home-sponsors-thumbs" role="tablist" aria-label="Selecionar patrocinador">
                    {% for patrocinador in colaboradores %}
                        <button
                            class="home-sponsor-thumb {% if loop.first %}active{% endif %}"
                            type="button"
                            data-bs-target="#homeSponsorsCarousel"
                            data-bs-slide-to="{{ loop.index0 }}"
                            {% if loop.first %}aria-current="true"{% endif %}
                            aria-label="Exibir {{ patrocinador.nome|e('html_attr') }}"
                        >
                            <img src="{{ patrocinador.logo_url|default(BASE_URL ~ 'assets/images/conscrito.png') }}" alt="" loading="lazy">
                            <span>{{ patrocinador.nome }}</span>
                        </button>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>
    {% endif %}

    <section class="home-services home-section py-5">
        <div class="container">
            <div class="row align-items-center g-3">
                <div class="col-lg-8">
                    {% include 'site/components/section-header.twig' with {
                        kicker: 'Canal institucional',
                        title: 'Entre em contato com a AORE/RN',
                        subtitle: 'Fale com a associação para informações institucionais, participação em atividades, integração entre oficiais da reserva e assuntos administrativos.',
                        heading_level: 3,
                        kicker_class: 'text-muted',
                        title_class: 'text-primary',
                        subtitle_class: 'text-muted',
                        extra_class: 'mb-0'
                    } %}
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="home-cta-actions d-flex gap-3 gap-md-4 flex-column flex-md-row justify-content-center justify-content-lg-end">
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL ~ 'contact',
                            label: 'Entrar em contato',
                            icon: 'bi-envelope',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'flex-fill flex-md-grow-0 fw-bold'
                        } %}
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL ~ 'institucional',
                            label: 'Área institucional',
                            icon: 'bi-building-gear',
                            variant: 'outline',
                            size: 'lg',
                            button_class: 'flex-fill flex-md-grow-0 fw-bold'
                        } %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {% if official_documents is defined and official_documents|length > 0 %}
    <section class="home-documents home-section py-5 bg-light">
        <div class="container">
            {% include 'site/components/section-header.twig' with {
                kicker: 'Documentos Oficiais',
                title: 'Acervo essencial da AORE/RN',
                subtitle: 'Acesso rápido ao selo institucional, ao hino e a outros arquivos oficiais já publicados no novo módulo administrativo.',
                align: 'center',
                kicker_class: 'text-muted',
                title_class: 'text-primary',
                subtitle_class: 'text-muted',
                extra_class: 'mb-5'
            } %}
            <div class="row g-4">
                {% for documento in official_documents %}
                    {% set documento_titulo = (documento.titulo|default(''))
                        |replace({'AORERN': 'AORE/RN', 'Aorern': 'AORE/RN', 'aorern': 'AORE/RN'}) %}
                    {% set documento_resumo = (documento.resumo|default('Documento institucional publicado para consulta e uso oficial.'))
                        |replace({'AORERN': 'AORE/RN', 'Aorern': 'AORE/RN', 'aorern': 'AORE/RN'}) %}
                    <div class="col-md-6 col-xl-4">
                        <article class="feature-card h-100 shadow-sm">
                            <div class="feature-card-icon mb-3">
                                <i class="bi bi-file-earmark-text"></i>
                            </div>
                            <h3 class="h5 fw-bold mb-2">{{ documento_titulo }}</h3>
                            <p class="text-muted mb-3">{{ documento_resumo }}</p>
                            {% include 'site/components/button.twig' with {
                                href: documento.arquivo_url ?: (documento.link_externo ?: BASE_URL ~ 'institucional/documentos'),
                                label: 'Abrir documento',
                                icon: 'bi-box-arrow-up-right',
                                icon_position: 'end',
                                variant: 'link',
                                size: 'md',
                                button_class: 'text-decoration-none ps-0 fw-semibold',
                                attrs: {
                                    'target': '_blank',
                                    'rel': 'noopener'
                                }
                            } %}
                        </article>
                    </div>
                {% endfor %}
            </div>
            <div class="text-center mt-4">
                {% include 'site/components/button.twig' with {
                    href: BASE_URL ~ 'institucional/documentos',
                    label: 'Ver todos os documentos',
                    icon: 'bi-folder2-open',
                    variant: 'outline',
                    size: 'lg',
                    button_class: 'fw-bold'
                } %}
            </div>
        </div>
    </section>
    {% endif %}
{% endblock %}
