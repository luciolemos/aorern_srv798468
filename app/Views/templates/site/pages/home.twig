    <section class="home-occurrence-metrics home-highlights home-section py-5">
      {% set ocorrenciaCards = ocorrenciasPorTipo|default([]) %}
      {% if ocorrenciaCards|length > 0 %}
        
        <div class="container">
            <div class="row align-items-center g-4">
                    <div class="col-lg-6">
                        {% include 'site/components/section-header.twig' with {
                        kicker: 'Tecnologia e pessoas',
                        title: 'Integração entre dados, equipes e frota',
                        subtitle: 'Acompanhamos cada fase da ocorrência com dashboards em tempo real, garantindo comunicação entre o centro de operações, o efetivo em campo e as defesas civis municipais.',
                        kicker_class: 'text-muted',
                        subtitle_class: 'text-muted',
                        extra_class: 'mb-4'
                    } %}
                        {# <p class="text-uppercase text-muted small fw-semibold mb-1">Monitoramento operacional</p>
                        <h3 class="h4 fw-bold mb-2">Ocorrências por tipo</h3>
                        <p class="text-muted mb-0">Atualizado a partir do Livro de Ocorrências. Destaque imediato para as frentes com maior demanda.</p> #}
                         <p class="text-muted mb-0">Indicadores de desempenho do 2º Subgrupamento de Bombeiros Militar</p>
                    </div>
                    <div class="col-lg-6 text-lg-end">
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL ~ 'admin/livro-ocorrencias',
                            label: 'Abrir painel completo',
                            icon: 'bi-speedometer2',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'd-none d-lg-inline-flex ms-lg-auto',
                            target: '_blank',
                            attrs: {
                                rel: 'noopener'
                            }
                        } %}
                    </div>
                </div>
                {% set cardRows = ocorrenciaCards|batch(4, null) %}
                {% for row in cardRows %}
                    <div class="row g-3 g-md-4 mt-2 mt-md-4">
                        {% for ocorrencia in row %}
                            {% if ocorrencia %}
                                <div class="col-12 col-sm-6 col-xl-3">
                                    <article class="occurrence-card h-100">
                                        <p class="occurrence-card-label text-uppercase small mb-1">{{ ocorrencia.tipo|default('Não classificada') }}</p>
                                        <p class="occurrence-card-value mb-0">{{ ocorrencia.total }}</p>
                                        <p class="occurrence-card-meta text-muted mb-0">{{ ocorrencia.meta|default('Registros recentes') }}</p>
                                    </article>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endfor %}
                <div class="row mt-3 d-lg-none">
                    <div class="col text-center">
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL ~ 'admin/livro-ocorrencias',
                            label: 'Abrir painel completo',
                            icon: 'bi-speedometer2',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold text-white',
                            target: '_blank',
                            attrs: {
                                rel: 'noopener'
                            }
                        } %}
                    </div>
                </div>
            </div>       
      {% endif %}
     </section>

