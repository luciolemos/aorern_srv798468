{% block scripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const isMobileViewport = window.matchMedia('(max-width: 767.98px)').matches;
            if (isMobileViewport) {
                document.querySelectorAll('.js-carteirinha-link[data-mobile-url]').forEach(function (el) {
                    const mobileUrl = el.getAttribute('data-mobile-url');
                    if (mobileUrl) {
                        el.setAttribute('href', mobileUrl);
                    }
                });
            }

            const binds = [
                {
                    input: document.getElementById('associadoAvatarInput'),
                    preview: document.getElementById('associadoAvatarPreview'),
                }
            ];

            binds.forEach(function (pair) {
                if (!pair.input || !pair.preview) {
                    return;
                }

                let previewUrl = null;
                pair.input.addEventListener('change', function () {
                    const file = this.files && this.files[0] ? this.files[0] : null;
                    if (!file || !file.type.startsWith('image/')) {
                        return;
                    }

                    if (previewUrl) {
                        URL.revokeObjectURL(previewUrl);
                    }

                    previewUrl = URL.createObjectURL(file);
                    pair.preview.src = previewUrl;
                });
            });

            const birthdayModal = document.getElementById('memberBirthdayGreetingModal');
            if (birthdayModal) {
                const recipientId = document.getElementById('memberBirthdayGreetingRecipientId');
                const recipientLabel = document.getElementById('memberBirthdayGreetingRecipientLabel');
                const messageField = document.getElementById('memberBirthdayGreetingMessage');
                const defaultMessage = `Nesta data especial, desejamos saúde, felicidade, realizações e contínuo sucesso em sua trajetória pessoal e profissional, mantendo sempre vivos os valores de honra, disciplina, camaradagem e compromisso com a Pátria, que marcam a formação do oficial da reserva.

Receba o reconhecimento e o abraço fraterno de todos que integram a família AORE/RN.

Parabéns e muitas felicidades!

Administração
AORE/RN – Associação dos Oficiais da Reserva do Exército

Perpetuum Officium erga Patriam
(Dever permanente para com a Pátria)`;

                birthdayModal.addEventListener('show.bs.modal', function (event) {
                    const trigger = event.relatedTarget;
                    if (!trigger) {
                        return;
                    }

                    const id = trigger.getAttribute('data-recipient-id') || '';
                    const name = trigger.getAttribute('data-recipient-name') || 'Associado';
                    const email = trigger.getAttribute('data-recipient-email') || '';

                    recipientId.value = id;
                    recipientLabel.textContent = email ? (name + ' <' + email + '>') : name;
                    messageField.value = defaultMessage;
                });
            }

            document.querySelectorAll('.js-toggle-password').forEach(function (button) {
                button.addEventListener('click', function () {
                    const targetId = button.getAttribute('data-target');
                    if (!targetId) {
                        return;
                    }

                    const input = document.getElementById(targetId);
                    if (!input) {
                        return;
                    }

                    const showing = input.type === 'text';
                    input.type = showing ? 'password' : 'text';
                    button.setAttribute('aria-pressed', showing ? 'false' : 'true');

                    const icon = button.querySelector('i');
                    if (icon) {
                        icon.classList.toggle('bi-eye', showing);
                        icon.classList.toggle('bi-eye-slash', !showing);
                    }
                });
            });
        });
    </script>
{% endblock %}
