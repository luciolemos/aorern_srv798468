{% extends "layouts/base.twig" %}

{% block title %}Esquadrão com Cães - CBMRN{% endblock %}

{% block styles %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ BASE_URL }}assets/css/esquadrao.css">
{% endblock %}

{% block content %}
    {% set esquadraoMetrics %}
        <div class="esquadrao-metrics-grid">
            <div>
                <p class="display-5 fw-bold text-white mb-0">05</p>
                <small class="text-white-50 text-uppercase">binômios ativos</small>
            </div>
            <div>
                <p class="display-5 fw-bold text-white mb-0">12</p>
                <small class="text-white-50 text-uppercase">ocorrências 2024</small>
            </div>
            <div>
                <p class="display-5 fw-bold text-white mb-0">30+</p>
                <small class="text-white-50 text-uppercase">ações educativas</small>
            </div>
            <div>
                <p class="display-5 fw-bold text-white mb-0">100%</p>
                <small class="text-white-50 text-uppercase">treinamento semanal</small>
            </div>
        </div>
        <p class="hero-panel-footnote text-white-50 mt-4 mb-0">Disponibilidade 24/7 para missões de busca, salvamento e apoio à comunidade.</p>
    {% endset %}

    <section class="esquadrao-hero site-hero">
        <div class="site-hero-pattern"></div>
        <div class="container position-relative">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 hero-content">
                    <p class="section-kicker text-white-50 mb-2">Esquadrão de cães do 2º Subgrupamento de Bombeiros Militar</p>
                    <h1 class="section-title text-white mb-3">Binômios preparados para busca, salvamento e apoio à comunidade</h1>
                    <p class="section-lead text-white-75 mb-4">Os binômios do 2º SGB mantêm disponibilidade para atendimento de ocorrências em 
                    toda a área de atuação sob sua jurisdição, podendo ser mobilizados para buscas de pessoas desaparecidas, apoio em desastres naturais, 
                    avaliação de estruturas colapsadas e suporte emocional em situações de crise. Além das atividades operacionais, o esquadrão 
                    desenvolve ações educativas, palestras e campanhas de prevenção para fortalecer o vínculo com a comunidade.</p>
                    <div class="d-flex flex-wrap gap-3 about-hero-actions">
                        {% include 'site/components/button.twig' with {
                            href: 'https://wa.me/5584988389889',
                            label: 'Acionar equipe',
                            icon: 'bi-whatsapp',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold',
                            target: '_blank'
                        } %}
                        {% include 'site/components/button.twig' with {
                            href: BASE_URL ~ 'contact',
                            label: 'Solicitar visita',
                            icon: 'bi-envelope',
                            variant: 'solid',
                            size: 'lg',
                            button_class: 'fw-bold text-dark',
                        } %}
                    </div>
                </div>
                <div class="col-lg-6 hero-panel-col">
                    {% include 'site/components/hero-panel.twig' with {
                        eyebrow: 'Indicadores do esquadrão',
                        title: 'Nossa prontidão anual',
                        description: 'Acompanhamos os números de missões, treinamentos e ações educativas para garantir resposta rápida em todo o litoral sul.',
                        theme: 'dark',
                        panel_class: 'esquadrao-panel',
                        body_html: esquadraoMetrics
                    } %}
                </div>
            </div>
        </div>
    </section>

    <section class="esquadrao-overview section-spacing">
        <div class="container">
            <div class="row align-items-center g-4">

                <div class="col-lg-6">
                    <img src="{{ BASE_URL }}assets/images/caes/malinois_1600_1600.jpg"
                         alt="Esquadrão com cães farejadores do CBMRN"
                         class="img-fluid home-k9-image rounded-2 shadow-sm">
                </div>
                <div class="col-lg-6">
                            {% include 'site/components/section-header.twig' with {
                            kicker: 'Treinamento contínuo',
                            title: 'Protocolo de preparo focado em busca, salvamento e apoio emocional',
                            subtitle: 'Os cães são treinados para responder comandos em ambientes urbanos, rurais, áreas de mata e situações com múltiplas vítimas. Cada binômio segue rotinas de condicionamento físico, olfativo e socialização.',
                            align: 'feft',
                            kicker_class: 'text-muted mb-2',
                            title_class: 'section-title text-primary mb-3',
                            subtitle_class: 'section-lead text-muted mb-0',
                            extra_class: 'mb-4'
            } %}
                    {# <p class="section-kicker text-primary mb-2">Treinamento contínuo</p>
                    <h2 class="section-title mb-3">Protocolo de preparo focado em busca, salvamento e apoio emocional</h2>
                    <p class="section-lead text-muted mb-4">Os cães são treinados para responder comandos em ambientes urbanos, rurais, áreas de mata e situações com múltiplas vítimas. Cada binômio segue rotinas de condicionamento físico, olfativo e socialização.</p> #}
                    <ul class="esquadrao-checklist icon-list">
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Simulados mensais com cenários reais do litoral sul</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Treinamento em técnicas de busca e salvamento com instrutores certificados</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Exercícios de socialização para interações seguras com vítimas</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Capacitação em apoio psicossocial para atendimento a vítimas</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Protocolos de segurança e bem-estar acompanhados por veterinários</span>
                        </li>
{#                         <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Integração com equipes de resgate em altura, mergulho e salvamento veicular</span>
                        </li> #}
{#                         <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Atuação em ações de prevenção e educação em escolas e eventos</span>
                        </li> #}
{#                         <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Participação em operações de busca e salvamento em áreas urbanas e rurais</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-soft" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Treinamento em técnicas de apoio psicossocial para interações com vítimas</span>
                        </li> #}
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="esquadrao-capabilities section-spacing">
        <div class="container">
            {% include 'site/components/section-header.twig' with {
                kicker: 'Capacidades operacionais',
                title: 'Frentes de atuação do esquadrão',
                subtitle: 'Cães preparados para dar suporte às guarnições em diferentes fases da ocorrência.',
                align: 'center',
                kicker_class: 'text-muted mb-2',
                title_class: 'section-title text-primary mb-3',
                subtitle_class: 'section-lead text-muted mb-0',
                extra_class: 'mb-5'
            } %}

            {% set esquadrao_capabilities = [
                {
                    icon: 'bi bi-life-preserver',
                    title: 'Busca em estruturas colapsadas',
                    description: 'Protocolos de varredura rápida para localizar vítimas em deslizamentos, desabamentos e áreas de difícil acesso.'
                },
                {
                    icon: 'bi bi-geo-alt',
                    title: 'Rastreamento em áreas rurais',
                    description: 'Suporte em ocorrências de pessoas desaparecidas, com foco em mata fechada e extensões do agreste.'
                },
                    {
                    icon: 'bi bi-heart',
                    title: 'Apoio psicossocial',
                    description: 'Interação com vítimas, familiares e comunidades para reduzir o trauma após grandes ocorrências.'
                }
            ] %}

            <div class="row g-4">
                {% for card in esquadrao_capabilities %}
                    <div class="col-md-4">
                        {% include 'site/components/feature-card.twig' with {
                            icon: card.icon,
                            title: card.title,
                            description: card.description,
                            card_class: 'h-100 text-center esquadrao-feature-card',
                            icon_class: 'mx-auto mb-3',
                            title_class: 'h5 fw-bold mb-2',
                            description_class: 'text-muted mb-0'
                        } %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="esquadrao-protocols section-spacing text-white">
        <div class="container">
            <div class="row align-items-center g-4">
                <div class="col-lg-6">
                    <h2 class="section-title text-white mb-3">Logística e bem-estar dos cães</h2>
                    <p class="section-lead text-white-75 mb-4">Os binômios contam com acompanhamento veterinário, alimentação balanceada e equipamentos específicos para transporte seguro em viaturas e aeronaves.</p>
                    <ul class="esquadrao-checklist icon-list text-white mb-4">
                        <li class="icon-list-item">
                            <span class="icon-circle icon-ghost" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Kennels climatizados e kits individuais para cada animal</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-ghost" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Rotina de avaliação física e behavioral</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-ghost" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Documentação sanitária e chips de identificação atualizados</span>
                        </li>
                        <li class="icon-list-item">
                            <span class="icon-circle icon-ghost" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                            <span>Cinotécnicos qualificados e treinados</span>
                        </li>
                    </ul>
{#                     {% include 'site/components/button.twig' with {
                        href: BASE_URL ~ 'contact',
                        label: 'Solicitar demonstração',
                        variant: 'solid',
                        size: 'lg',
                        button_class: 'fw-bold text-dark'
                    } %} #}
                </div>
                <div class="col-lg-6">
                    <div class="esquadrao-gallery row g-3">
                         <div class="col-lg-6">
                    <img src="{{ BASE_URL }}assets/images/caes/malinois_1080_1433.jpg"
                         alt="Esquadrão com cães farejadores do CBMRN"
                         class="img-fluid home-k9-image rounded-2 shadow-sm">
                   </div>
{#                    <div class="col-lg-6">
                    <img src="{{ BASE_URL }}assets/images/caes/malinois1.jpg"
                         alt="Esquadrão com cães farejadores do CBMRN"
                         class="img-fluid home-k9-image rounded-2 shadow-sm">
                   </div> #}
                   <div class="col-lg-6">
                    <img src="{{ BASE_URL }}assets/images/caes/malinois_1080_1433.png"
                         alt="Esquadrão com cães farejadores do CBMRN"
                         class="img-fluid home-k9-image rounded-2 shadow-sm">
                   </div>
{#                     <div class="col-lg-6">
                    <img src="{{ BASE_URL }}assets/images/caes/malinois7.jpg"
                         alt="Esquadrão com cães farejadores do CBMRN"
                         class="img-fluid home-k9-image rounded-2 shadow-sm">
                   </div> #}
                </div>
            </div>
        </div>
    </section>

    <section class="esquadrao-cta section-spacing">
        <div class="container">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <p class="section-kicker text-primary mb-2">Parcerias e visitas</p>
                    <h2 class="section-title mb-3">Quer apresentar o esquadrão para sua comunidade?</h2>
                    <p class="section-lead text-muted mb-0">O 2º SGB/2º GBM realiza palestras, demonstrações e treinamentos compartilhados com escolas, universidades e defesas civis municipais.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    {% include 'site/components/button.twig' with {
                        href: BASE_URL ~ 'contact',
                        label: 'Agendar presença',
                        icon: 'bi-calendar-event',
                        icon_position: 'end',
                        variant: 'solid',
                        size: 'lg',
                        button_class: 'fw-bold'
                    } %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
