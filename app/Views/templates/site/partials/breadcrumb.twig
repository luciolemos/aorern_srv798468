<nav class="inst-breadcrumb" aria-label="breadcrumb">
    <ol class="breadcrumb mb-0 align-items-center gap-1 flex-wrap">
        {% for item in breadcrumbs %}
            {% if loop.last or not item.url %}
                <li class="breadcrumb-item active text-uppercase fw-semibold" aria-current="page">
                    <span>{{ item.label }}</span>
                </li>
            {% else %}
                <li class="breadcrumb-item text-uppercase fw-semibold">
                    <a href="{{ item.url }}">{{ item.label }}</a>
                </li>
            {% endif %}
        {% endfor %}
    </ol>
</nav>
