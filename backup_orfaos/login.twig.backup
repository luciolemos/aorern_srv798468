{% extends "layouts/base.twig" %}

{% block title %}Login - CBMRN{% endblock %}

{% block content %}
    <div class="container py-5" style="min-height: calc(100vh - 75px - 200px);">
        <div class="row">
            <div class="col-lg-4 offset-lg-4">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-5">
                        <h2 class="text-center fw-bold mb-5" style="color: #df6301;">Login</h2>
                        
                        {% if success %}
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                {{ success }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endif %}

                        {% if error %}
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                {{ error }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endif %}
                        
                        <form method="POST" action="{{ BASE_URL }}login/authenticate">
                            <div class="mb-3">
                                <label for="email" class="form-label fw-bold">Email</label>
                                <input type="email" class="form-control form-control-lg" id="email" name="email" required>
                            </div>
                            <div class="mb-4">
                                <label for="password" class="form-label fw-bold">Senha</label>
                                <input type="password" class="form-control form-control-lg" id="password" name="password" required>
                            </div>
                            <button type="submit" class="btn btn-lg w-100 fw-bold text-white mb-3" style="background-color: #df6301;">Entrar</button>
                        </form>
                        
                        <p class="text-center mt-4">
                            Não tem uma conta? <a href="{{ BASE_URL }}/register" class="fw-bold text-decoration-none" style="color: #df6301;">Registre-se aqui</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
