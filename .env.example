APP_ENV=production
SESSION_TIMEOUT=600
DB_HOST=127.0.0.1
DB_NAME=your_database
DB_USER=your_user
DB_PASS="change_me"

RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
